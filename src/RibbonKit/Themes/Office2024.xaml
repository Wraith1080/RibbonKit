<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:RibbonKit.Controls"
    xmlns:layout="clr-namespace:RibbonKit.Layout">

    <!-- ============================================================
         Shared control templates. Colors and metrics come from the
         token layer via {DynamicResource}: a theme (Themes/Tokens.*.xaml)
         supplies those tokens in Application.Resources, so switching the
         token dictionary re-colors every control at runtime WITHOUT
         duplicating a single template. Merge a token dictionary in
         App.xaml (default: Themes/Tokens.Office2024.xaml).
         ============================================================ -->

    <!-- ============================================================
         Ribbon
         ============================================================ -->
    <Style TargetType="{x:Type controls:Ribbon}">
        <Setter Property="Background" Value="{DynamicResource RibbonKit.Brushes.Ribbon.Background}" />
        <Setter Property="Foreground" Value="{DynamicResource RibbonKit.Brushes.Text.Primary}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:Ribbon}">
                    <!-- The backstage overlay is hosted in the window's adorner layer
                         by the Ribbon class itself (see BackstageAdorner), not here. -->
                    <Border Background="{TemplateBinding Background}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <controls:RibbonTabControl
                                Grid.Row="0"
                                ItemsSource="{TemplateBinding Tabs}"
                                SelectedItem="{Binding SelectedTab, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}" />
                            <!-- Quick access row shown when QuickAccessPosition=BelowRibbon.
                                 Styled as an extender chip that tucks under the ribbon
                                 card (Office 2024); flat themes render a plain strip. -->
                            <Border x:Name="QatBelowHost"
                                    Grid.Row="1"
                                    HorizontalAlignment="Stretch"
                                    Margin="{DynamicResource RibbonKit.Metrics.QatExtenderMargin}"
                                    Padding="8,2"
                                    Background="{DynamicResource RibbonKit.Brushes.Ribbon.ContentBackground}"
                                    BorderBrush="{DynamicResource RibbonKit.Brushes.Ribbon.Border}"
                                    BorderThickness="{DynamicResource RibbonKit.Metrics.QatExtenderBorderThickness}"
                                    CornerRadius="{DynamicResource RibbonKit.Metrics.QatExtenderCornerRadius}"
                                    Effect="{DynamicResource RibbonKit.Effects.ContentShadow}"
                                    Visibility="Collapsed">
                                <!-- ItemsSource bound only by the BelowRibbon trigger. -->
                                <ItemsControl x:Name="QatBelowItems"
                                              Focusable="False"
                                              Margin="4,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </Border>

                            <!-- Design-time-only backstage preview surface. At runtime the
                                 backstage is hosted in the WINDOW's adorner layer (see
                                 Ribbon.UpdateBackstageOverlay); that path needs a real Window,
                                 which the XAML designer doesn't provide, so the Ribbon routes the
                                 backstage into this in-template host instead while in design mode.
                                 Stays Collapsed and empty at runtime — the code only fills it under
                                 DesignerProperties.GetIsInDesignMode. MinHeight just gives the
                                 preview room on the surface; it has no effect while Collapsed. -->
                            <Border x:Name="PART_DesignBackstageHost"
                                    Grid.Row="0"
                                    Grid.RowSpan="2"
                                    Visibility="Collapsed"
                                    MinHeight="440"
                                    Background="{DynamicResource RibbonKit.Brushes.Backstage.ContentBackground}" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="QuickAccessPosition" Value="BelowRibbon">
                            <Setter TargetName="QatBelowHost" Property="Visibility" Value="Visible" />
                            <Setter TargetName="QatBelowItems" Property="ItemsSource">
                                <Setter.Value>
                                    <Binding Path="QuickAccessItems"
                                             RelativeSource="{RelativeSource AncestorType={x:Type controls:Ribbon}}" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <!-- Minimized + QAT below: the ribbon body card is collapsed, so the
                             QAT bar is left standing alone under the tab strip. Make it a
                             self-contained floating card — round ALL corners (not just the
                             bottom), border it all the way around, and give it the small top
                             gap the card used to occupy — matching Office. It reverts to the
                             flush-connected strip automatically when the ribbon is restored.
                             Flat themes (2019/2013) point these tokens at their strip values,
                             so nothing changes shape for them. -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="QuickAccessPosition" Value="BelowRibbon" />
                                <Condition Property="IsMinimized" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="QatBelowHost" Property="CornerRadius"
                                    Value="{DynamicResource RibbonKit.Metrics.QatExtenderCornerRadiusMinimized}" />
                            <Setter TargetName="QatBelowHost" Property="BorderThickness"
                                    Value="{DynamicResource RibbonKit.Metrics.QatExtenderBorderThicknessMinimized}" />
                            <Setter TargetName="QatBelowHost" Property="Margin"
                                    Value="{DynamicResource RibbonKit.Metrics.QatExtenderMarginMinimized}" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         RibbonTabControl — tab strip on top, groups row below
         ============================================================ -->
    <Style TargetType="{x:Type controls:RibbonTabControl}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:RibbonTabControl}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <!-- Application (File) button: opens the backstage; hidden
                                 when the hosting Ribbon has no Backstage assigned -->
                            <ToggleButton x:Name="ApplicationButton"
                                          Grid.Column="0"
                                          Margin="{DynamicResource RibbonKit.Metrics.ApplicationButtonMargin}"
                                          Content="{Binding ApplicationButtonHeader, RelativeSource={RelativeSource AncestorType={x:Type controls:Ribbon}}}"
                                          IsChecked="{Binding IsBackstageOpen, RelativeSource={RelativeSource AncestorType={x:Type controls:Ribbon}}, Mode=TwoWay}">
                                <ToggleButton.Style>
                                    <Style TargetType="{x:Type ToggleButton}">
                                        <Setter Property="Foreground" Value="{DynamicResource RibbonKit.Brushes.ApplicationButton.Foreground}" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type ToggleButton}">
                                                    <!-- The File tab hovers exactly like the other tabs:
                                                         same Tab.HoverBackground + Tab.HoverUnderline tokens,
                                                         so its hover style tracks the theme automatically. -->
                                                    <Grid>
                                                        <Border x:Name="Chrome"
                                                                Background="{DynamicResource RibbonKit.Brushes.ApplicationButton.Background}"
                                                                CornerRadius="{DynamicResource RibbonKit.Metrics.TabCornerRadius}"
                                                                Padding="14,7,14,9"
                                                                SnapsToDevicePixels="True">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center" />
                                                        </Border>
                                                        <Rectangle x:Name="HoverUnderline"
                                                                   Height="2.5"
                                                                   RadiusX="1.25"
                                                                   RadiusY="1.25"
                                                                   Margin="10,0"
                                                                   VerticalAlignment="Bottom"
                                                                   Fill="{DynamicResource RibbonKit.Brushes.ApplicationButton.HoverUnderline}"
                                                                   Visibility="Collapsed" />
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Chrome" Property="Background"
                                                                    Value="{DynamicResource RibbonKit.Brushes.ApplicationButton.HoverBackground}" />
                                                            <Setter TargetName="HoverUnderline" Property="Visibility" Value="Visible" />
                                                        </Trigger>
                                                        <!-- Backstage open: File highlights in accent, like Office -->
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="Chrome" Property="Background"
                                                                    Value="{DynamicResource RibbonKit.Brushes.Accent}" />
                                                            <Setter TargetName="HoverUnderline" Property="Visibility" Value="Collapsed" />
                                                            <Setter Property="Foreground" Value="#FFFFFF" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Backstage, RelativeSource={RelativeSource AncestorType={x:Type controls:Ribbon}}}"
                                                         Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ToggleButton.Style>
                            </ToggleButton>
                            <!-- Quick access strip in the tab row (QuickAccessPosition=TabRow).
                                 ItemsSource is bound ONLY by the TabRow trigger below, never
                                 by default — the same live QAT UIElements can have only one
                                 parent, so exactly one host (tab-row or below-ribbon) may
                                 bind at a time. -->
                            <ItemsControl x:Name="QatTabRowHost"
                                          Grid.Column="1"
                                          Focusable="False"
                                          VerticalAlignment="Center"
                                          Visibility="Collapsed"
                                          Margin="2,4,4,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                            <Grid Grid.Column="2">
                                <TabPanel IsItemsHost="True"
                                          Margin="{DynamicResource RibbonKit.Metrics.TabStripMargin}"
                                          Background="Transparent" />
                                <!-- Shared selection underline that GLIDES between tabs
                                     (RibbonTabControl positions/animates it). Replaces the
                                     per-tab SelectionIndicator/ContextualSelectionIndicator for
                                     the accent underline; flat themes (2019/2013) leave
                                     Tab.SelectedUnderline Transparent, so it's invisible there
                                     and those themes keep their pill/fill selection. Width +
                                     TranslateTransform.X are animated (X glide + width) — a lone
                                     marker in its own cell, so animating Width re-arranges only
                                     itself and never cascades a ribbon re-layout. -->
                                <Rectangle x:Name="PART_TabMarker"
                                           Height="3" Width="0"
                                           RadiusX="1.5" RadiusY="1.5"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Top"
                                           IsHitTestVisible="False"
                                           Opacity="0"
                                           Fill="{DynamicResource RibbonKit.Brushes.Tab.SelectedUnderline}">
                                    <Rectangle.RenderTransform>
                                        <TranslateTransform x:Name="PART_TabMarkerTranslate" />
                                    </Rectangle.RenderTransform>
                                </Rectangle>
                            </Grid>
                            <!-- Minimize chevron: toggles Ribbon.IsMinimized -->
                            <ToggleButton x:Name="MinimizeToggle"
                                          Grid.Column="3"
                                          Width="24" Height="22"
                                          Margin="0,6,8,0"
                                          VerticalAlignment="Center"
                                          ToolTip="Minimize the Ribbon"
                                          IsChecked="{Binding IsMinimized, RelativeSource={RelativeSource AncestorType={x:Type controls:Ribbon}}, Mode=TwoWay}">
                                <ToggleButton.Style>
                                    <Style TargetType="{x:Type ToggleButton}">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type ToggleButton}">
                                                    <Border x:Name="Chrome"
                                                            Background="Transparent"
                                                            CornerRadius="{DynamicResource RibbonKit.Metrics.ControlCornerRadius}"
                                                            SnapsToDevicePixels="True">
                                                        <Grid>
                                                            <Path x:Name="ChevronUp"
                                                                  Data="M0,3.5 L3.5,0 L7,3.5"
                                                                  Stroke="{DynamicResource RibbonKit.Brushes.TabStrip.Foreground}"
                                                                  StrokeThickness="1.5"
                                                                  StrokeStartLineCap="Round"
                                                                  StrokeEndLineCap="Round"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center" />
                                                            <Path x:Name="ChevronDown"
                                                                  Data="M0,0 L3.5,3.5 L7,0"
                                                                  Stroke="{DynamicResource RibbonKit.Brushes.TabStrip.Foreground}"
                                                                  StrokeThickness="1.5"
                                                                  StrokeStartLineCap="Round"
                                                                  StrokeEndLineCap="Round"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"
                                                                  Visibility="Collapsed" />
                                                        </Grid>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Chrome" Property="Background"
                                                                    Value="{DynamicResource RibbonKit.Brushes.TabStrip.ControlHoverBackground}" />
                                                        </Trigger>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="ChevronUp" Property="Visibility" Value="Collapsed" />
                                                            <Setter TargetName="ChevronDown" Property="Visibility" Value="Visible" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ToggleButton.Style>
                            </ToggleButton>
                        </Grid>
                        <!-- Ribbon body. Office 2024/365 renders it as a floating rounded
                             "card" (inset margin, rounded on all corners, bordered all
                             around) over the light ribbon band. Flat themes (2019/2013)
                             zero the margin and radius and use a top/bottom-only border,
                             collapsing it back to a full-width strip — all via tokens. -->
                        <Border x:Name="ContentHost"
                                Grid.Row="1"
                                Background="{DynamicResource RibbonKit.Brushes.Ribbon.ContentBackground}"
                                BorderBrush="{DynamicResource RibbonKit.Brushes.Ribbon.Border}"
                                BorderThickness="{DynamicResource RibbonKit.Metrics.ContentBorderThickness}"
                                CornerRadius="{DynamicResource RibbonKit.Metrics.ContentCornerRadius}"
                                Margin="{DynamicResource RibbonKit.Metrics.ContentMargin}"
                                Effect="{DynamicResource RibbonKit.Effects.ContentShadow}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter ContentSource="SelectedContent" Margin="6,2" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- The ribbon body's Visibility while minimized is managed in code
                             (Ribbon.OnIsMinimizedChanged) so it can slide up + fade out before
                             collapsing, and slide back in on restore. -->
                        <DataTrigger Binding="{Binding QuickAccessPosition, RelativeSource={RelativeSource AncestorType={x:Type controls:Ribbon}}}"
                                     Value="TabRow">
                            <Setter TargetName="QatTabRowHost" Property="Visibility" Value="Visible" />
                            <Setter TargetName="QatTabRowHost" Property="ItemsSource">
                                <Setter.Value>
                                    <Binding Path="QuickAccessItems"
                                             RelativeSource="{RelativeSource AncestorType={x:Type controls:Ribbon}}" />
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                        <!-- When the QAT sits below the ribbon, the card squares its bottom
                             corners and drops its bottom margin so the full-width QAT bar
                             connects flush underneath. -->
                        <DataTrigger Binding="{Binding QuickAccessPosition, RelativeSource={RelativeSource AncestorType={x:Type controls:Ribbon}}}"
                                     Value="BelowRibbon">
                            <Setter TargetName="ContentHost" Property="CornerRadius"
                                    Value="{DynamicResource RibbonKit.Metrics.ContentCornerRadiusTop}" />
                            <Setter TargetName="ContentHost" Property="Margin"
                                    Value="{DynamicResource RibbonKit.Metrics.ContentMarginQatBelow}" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         RibbonTab — header in the strip; selected tab gets the
         Office 2024 accent underline
         ============================================================ -->
    <Style TargetType="{x:Type controls:RibbonTab}">
        <Setter Property="Foreground" Value="{DynamicResource RibbonKit.Brushes.TabStrip.Foreground}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:RibbonTab}">
                    <Grid>
                        <Border x:Name="HeaderChrome"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                CornerRadius="{DynamicResource RibbonKit.Metrics.TabCornerRadius}"
                                Padding="12,7,12,9">
                            <Grid>
                                <!-- Normal header text: theme foreground (and selected
                                     foreground while selected). -->
                                <ContentPresenter x:Name="HeaderText"
                                                  ContentSource="Header"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                                <!-- Contextual header text: tinted by the tab's ContextualBrush,
                                     muted until selected. Only shown for contextual tabs. -->
                                <ContentPresenter x:Name="ContextualHeaderText"
                                                  ContentSource="Header"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"
                                                  TextElement.Foreground="{TemplateBinding ContextualBrush}"
                                                  Opacity="{DynamicResource RibbonKit.Metrics.ContextualUnselectedOpacity}"
                                                  Visibility="Collapsed" />
                            </Grid>
                        </Border>
                        <!-- The template carries BOTH an underline and a fill for hover and
                             for selection; a theme picks its style by making the unwanted
                             token Transparent (2024 = underlines; 2019 = fills/pills).
                             IsHitTestVisible="False" on all three indicators: they overlay
                             HeaderChrome (the hover trigger's SourceName). If they were
                             hit-testable, hovering directly on the underline would steal the
                             hit from HeaderChrome — dropping its IsMouseOver, hiding the
                             underline, which hands the hit back to HeaderChrome, and so on:
                             an endless flicker. Transparent-to-mouse indicators keep the hit
                             on HeaderChrome underneath. -->
                        <Rectangle x:Name="HoverIndicator"
                                   Height="2.5"
                                   RadiusX="1.25"
                                   RadiusY="1.25"
                                   Margin="10,0"
                                   VerticalAlignment="Bottom"
                                   IsHitTestVisible="False"
                                   Fill="{DynamicResource RibbonKit.Brushes.Tab.HoverUnderline}"
                                   Visibility="Collapsed" />
                        <Rectangle x:Name="SelectionIndicator"
                                   Height="3"
                                   RadiusX="1.5"
                                   RadiusY="1.5"
                                   Margin="10,0"
                                   VerticalAlignment="Bottom"
                                   IsHitTestVisible="False"
                                   Fill="{DynamicResource RibbonKit.Brushes.Tab.SelectedUnderline}"
                                   Visibility="Collapsed" />
                        <!-- Selected contextual tab's underline, tinted the same as its
                             header text. Height is a theme token (2024 = 3, flat themes = 0)
                             so only underline themes show it. -->
                        <Rectangle x:Name="ContextualSelectionIndicator"
                                   Height="{DynamicResource RibbonKit.Metrics.ContextualUnderlineHeight}"
                                   RadiusX="1.5"
                                   RadiusY="1.5"
                                   Margin="10,0"
                                   VerticalAlignment="Bottom"
                                   IsHitTestVisible="False"
                                   Fill="{TemplateBinding ContextualBrush}"
                                   Visibility="Collapsed" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- Contextual tabs render their header via the tinted presenter. -->
                        <Trigger Property="IsContextual" Value="True">
                            <Setter TargetName="HeaderText" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="ContextualHeaderText" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <!-- Hover shows the fill AND the underline; each theme zeroes the
                             one it doesn't use. SourceName scoping matters — TabItem.IsMouseOver
                             is also true over the tab CONTENT, which would flicker the header. -->
                        <Trigger SourceName="HeaderChrome" Property="IsMouseOver" Value="True">
                            <Setter TargetName="HeaderChrome" Property="Background"
                                    Value="{DynamicResource RibbonKit.Brushes.Tab.HoverBackground}" />
                            <Setter TargetName="HoverIndicator" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="HeaderChrome" Property="Background"
                                    Value="{DynamicResource RibbonKit.Brushes.Tab.SelectedBackground}" />
                            <!-- Office 2013/Metro: the active tab is outlined on top and
                                 sides (no bottom) so it connects into the ribbon body.
                                 Other themes keep this Transparent / zero-thickness. -->
                            <Setter TargetName="HeaderChrome" Property="BorderBrush"
                                    Value="{DynamicResource RibbonKit.Brushes.Tab.SelectedBorderBrush}" />
                            <Setter TargetName="HeaderChrome" Property="BorderThickness"
                                    Value="{DynamicResource RibbonKit.Metrics.TabSelectedBorderThickness}" />
                            <!-- Selection underline is now the shared gliding PART_TabMarker
                                 (in the RibbonTabControl template), not this per-tab rectangle. -->
                            <Setter TargetName="HoverIndicator" Property="Visibility" Value="Collapsed" />
                            <Setter Property="Foreground"
                                    Value="{DynamicResource RibbonKit.Brushes.Tab.SelectedForeground}" />
                        </Trigger>
                        <!-- Selected contextual tab: full-strength tint, tinted underline,
                             and the normal accent underline hidden in its favor. -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsContextual" Value="True" />
                                <Condition Property="IsSelected" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="ContextualHeaderText" Property="Opacity" Value="1" />
                            <!-- The selected contextual tab's tinted underline is now drawn by
                                 the shared gliding PART_TabMarker (tinted to ContextualBrush). -->
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         RibbonGroupsHost — hosts groups on the adaptive panel
         ============================================================ -->
    <Style TargetType="{x:Type controls:RibbonGroupsHost}">
        <Setter Property="Focusable" Value="False" />
        <!-- StaticResource: resolved at parse time from this dictionary, so the fixed
             row height can never fail to apply. ClipToBounds stops any over-tall group
             content from painting over the document area. -->
        <Setter Property="Height" Value="{DynamicResource RibbonKit.Metrics.GroupsRowHeight}" />
        <Setter Property="ClipToBounds" Value="True" />
        <Setter Property="KeyboardNavigation.DirectionalNavigation" Value="Continue" />
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <layout:RibbonGroupsPanel />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:RibbonGroupsHost}">
                    <ItemsPresenter />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         RibbonGroup — items row + group name; collapses to a single
         flyout button (Office 2024 behavior) when width runs out
         ============================================================ -->
    <Style TargetType="{x:Type controls:RibbonGroup}">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="KeyboardNavigation.DirectionalNavigation" Value="Continue" />
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:RibbonGroup}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Normal (expanded) content. The inner grid is re-homed into
                             the flyout by RibbonGroup while the popup is open. -->
                        <Decorator x:Name="PART_NormalHost" Grid.Column="0">
                            <Grid Margin="4,2,4,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ItemsPresenter Grid.Row="0" VerticalAlignment="Center" />
                                <Grid Grid.Row="1" Margin="2,3,2,4">
                                    <ContentPresenter ContentSource="Header"
                                                      HorizontalAlignment="Center"
                                                      TextElement.FontSize="11"
                                                      TextElement.Foreground="{DynamicResource RibbonKit.Brushes.Text.Secondary}" />
                                    <!-- ↘ dialog launcher, shown via ShowDialogLauncher -->
                                    <Button x:Name="PART_DialogLauncher"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Width="18" Height="14"
                                            Visibility="Collapsed"
                                            ToolTip="More options"
                                            Command="{TemplateBinding DialogLauncherCommand}">
                                        <Button.Style>
                                            <Style TargetType="{x:Type Button}">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="{x:Type Button}">
                                                            <Border x:Name="Chrome"
                                                                    Background="Transparent"
                                                                    CornerRadius="{DynamicResource RibbonKit.Metrics.SmallControlCornerRadius}"
                                                                    SnapsToDevicePixels="True">
                                                                <Path Data="M1,1 H3.5 M1,1 V3.5 M2.5,2.5 L7,7 M7,7 V4.5 M7,7 H4.5"
                                                                      Stroke="{DynamicResource RibbonKit.Brushes.Text.Secondary}"
                                                                      StrokeThickness="1.2"
                                                                      StrokeStartLineCap="Round"
                                                                      StrokeEndLineCap="Round"
                                                                      HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center" />
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Chrome" Property="Background"
                                                                            Value="{DynamicResource RibbonKit.Brushes.Control.HoverBackground}" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </Grid>
                        </Decorator>

                        <!-- Collapsed representation: one button with icon, name, chevron.
                             The style is inlined so it can never miss a resource lookup. -->
                        <ToggleButton x:Name="PART_CollapsedButton"
                                      Grid.Column="0"
                                      Margin="1"
                                      Visibility="Collapsed">
                            <ToggleButton.Style>
                                <Style TargetType="{x:Type ToggleButton}">
                                    <Setter Property="Focusable" Value="True" />
                                    <Setter Property="Foreground"
                                            Value="{DynamicResource RibbonKit.Brushes.Text.Primary}" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type ToggleButton}">
                                                <Border x:Name="Chrome"
                                                        Background="Transparent"
                                                        CornerRadius="{DynamicResource RibbonKit.Metrics.ControlCornerRadius}"
                                                        SnapsToDevicePixels="True">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Chrome" Property="Background"
                                                                Value="{DynamicResource RibbonKit.Brushes.Control.HoverBackground}" />
                                                    </Trigger>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Chrome" Property="Background"
                                                                Value="{DynamicResource RibbonKit.Brushes.Control.PressedBackground}" />
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="Chrome" Property="Background"
                                                                Value="{DynamicResource RibbonKit.Brushes.Control.PressedBackground}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ToggleButton.Style>
                            <StackPanel Orientation="Vertical" Margin="8,4">
                                <Image Source="{TemplateBinding Icon}"
                                       Width="32" Height="32"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding Header, RelativeSource={RelativeSource TemplatedParent}}"
                                           TextAlignment="Center"
                                           Margin="0,4,0,0" />
                                <Path Data="M0,0 L3.5,3.5 L7,0"
                                      Stroke="{DynamicResource RibbonKit.Brushes.Text.Secondary}"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      HorizontalAlignment="Center"
                                      Margin="0,3,0,1" />
                            </StackPanel>
                        </ToggleButton>

                        <!-- Flyout that hosts the group's full content while collapsed -->
                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               StaysOpen="True"
                               Placement="Bottom"
                               PlacementTarget="{Binding ElementName=PART_CollapsedButton}"
                               IsOpen="{Binding IsChecked, ElementName=PART_CollapsedButton, Mode=TwoWay}">
                            <!-- AdornerDecorator wraps the host so the re-homed flyout content
                                 (set as PART_PopupHost.Child at runtime) has an adorner layer
                                 for KeyTip badges. -->
                            <AdornerDecorator>
                                <Border x:Name="PART_PopupHost"
                                        Background="{DynamicResource RibbonKit.Brushes.Ribbon.ContentBackground}"
                                        BorderBrush="{DynamicResource RibbonKit.Brushes.ScreenTip.Border}"
                                        BorderThickness="1"
                                        CornerRadius="{DynamicResource RibbonKit.Metrics.PopupCornerRadius}"
                                        Padding="6,4"
                                        Margin="4,2,8,8">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.25" />
                                    </Border.Effect>
                                </Border>
                            </AdornerDecorator>
                        </Popup>

                        <Rectangle Grid.Column="1"
                                   Width="1"
                                   Margin="1,10"
                                   Fill="{DynamicResource RibbonKit.Brushes.Group.Separator}" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="SizeState" Value="Collapsed">
                            <Setter TargetName="PART_NormalHost" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="PART_CollapsedButton" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="ShowDialogLauncher" Value="True">
                            <Setter TargetName="PART_DialogLauncher" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         RibbonButton — Large / Medium / Small layouts via triggers
         ============================================================ -->
    <Style TargetType="{x:Type controls:RibbonButton}">
        <Setter Property="Foreground" Value="{DynamicResource RibbonKit.Brushes.Text.Primary}" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:RibbonButton}">
                    <Border x:Name="Chrome"
                            Background="Transparent"
                            CornerRadius="{DynamicResource RibbonKit.Metrics.ControlCornerRadius}"
                            Margin="1"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <!-- Hover/press cross-fade layers: opacity is animated 0<->1 over the
                                 Hover duration token, so the highlight eases instead of snapping.
                                 Behind the content, non-hit-testable. -->
                            <Border x:Name="HoverWash"
                                    Background="{DynamicResource RibbonKit.Brushes.Control.HoverBackground}"
                                    CornerRadius="{DynamicResource RibbonKit.Metrics.ControlCornerRadius}"
                                    Opacity="0" IsHitTestVisible="False" />
                            <Border x:Name="PressWash"
                                    Background="{DynamicResource RibbonKit.Brushes.Control.PressedBackground}"
                                    CornerRadius="{DynamicResource RibbonKit.Metrics.ControlCornerRadius}"
                                    Opacity="0" IsHitTestVisible="False" />
                            <!-- Large: 32px icon over wrapped label -->
                            <StackPanel x:Name="LargeLayout"
                                        Orientation="Vertical"
                                        Margin="6,8,6,0"
                                        VerticalAlignment="Center">
                                <Image x:Name="LargeImage"
                                       Source="{TemplateBinding LargeIcon}"
                                       Width="32" Height="32"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center" />
                                <TextBlock Text="{TemplateBinding Header}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="76"
                                           MinHeight="32"
                                           MaxHeight="48"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                            <!-- Medium: 16px icon + label in a row -->
                            <StackPanel x:Name="MediumLayout"
                                        Orientation="Horizontal"
                                        Margin="4,2"
                                        VerticalAlignment="Center"
                                        Visibility="Collapsed">
                                <Image Source="{TemplateBinding Icon}"
                                       Width="16" Height="16"
                                       Stretch="Uniform"
                                       VerticalAlignment="Center" />
                                <TextBlock Text="{TemplateBinding Header}"
                                           Margin="5,0,2,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <!-- Small: 16px icon only. Tight vertical margin so a stack of
                                 three small buttons plus the group caption fits the fixed
                                 groups row. Two renderings: the normal colour icon, and a
                                 flat white silhouette shown when Ribbon.QatOnColoredSurface
                                 is set (QAT on a colored title bar / strip). -->
                            <Grid x:Name="SmallLayout"
                                  Margin="5,3"
                                  VerticalAlignment="Center"
                                  Visibility="Collapsed">
                                <Image x:Name="SmallImage"
                                       Source="{TemplateBinding Icon}"
                                       Width="16" Height="16"
                                       Stretch="Uniform" />
                                <Rectangle x:Name="SmallImageTint" Width="16" Height="16"
                                           Fill="#FFFFFF"
                                           Visibility="Collapsed">
                                    <Rectangle.OpacityMask>
                                        <ImageBrush ImageSource="{Binding Icon, RelativeSource={RelativeSource TemplatedParent}}" />
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                            </Grid>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- QAT on a colored surface (accent title bar / colored strip): draw
                             the icon as a white silhouette instead of its full colour. -->
                        <Trigger Property="controls:Ribbon.QatOnColoredSurface" Value="True">
                            <Setter TargetName="SmallImage" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="SmallImageTint" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="LargeIcon" Value="{x:Null}">
                            <Setter TargetName="LargeImage" Property="Source"
                                    Value="{Binding Icon, RelativeSource={RelativeSource TemplatedParent}}" />
                        </Trigger>
                        <Trigger Property="Size" Value="Medium">
                            <Setter TargetName="LargeLayout" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="MediumLayout" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="Size" Value="Small">
                            <Setter TargetName="LargeLayout" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="SmallLayout" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <!-- Hover/press highlight is a cross-fade of HoverWash/PressWash, driven in
                             code (RibbonButton.OnPropertyChanged -> RibbonMotion.FadeWash) so it
                             honors the animation level / reduced-motion — template storyboards can't
                             read the runtime Duration tokens (a DynamicResource makes the storyboard
                             un-freezable). Off a colored surface only; the QAT-on-colored variants
                             below stay instant. -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                        <!-- On a colored surface, hover/press with the surrounding band's brushes
                             (caption/tab) instead of the neutral control brushes. Pressed comes
                             AFTER hover so it wins while the button is held. -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="controls:Ribbon.QatOnColoredSurface" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Chrome" Property="Background"
                                    Value="{DynamicResource RibbonKit.Brushes.Qat.ColoredHoverBackground}" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsPressed" Value="True" />
                                <Condition Property="controls:Ribbon.QatOnColoredSurface" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Chrome" Property="Background"
                                    Value="{DynamicResource RibbonKit.Brushes.Qat.ColoredPressedBackground}" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         RibbonScreenTip — rich tooltip
         ============================================================ -->
    <Style TargetType="{x:Type controls:RibbonScreenTip}">
        <Setter Property="Background" Value="{DynamicResource RibbonKit.Brushes.ScreenTip.Background}" />
        <Setter Property="Foreground" Value="{DynamicResource RibbonKit.Brushes.Text.Primary}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:RibbonScreenTip}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{DynamicResource RibbonKit.Brushes.ScreenTip.Border}"
                            BorderThickness="1"
                            CornerRadius="{DynamicResource RibbonKit.Metrics.ControlCornerRadius}"
                            Padding="10,8"
                            MaxWidth="300">
                        <StackPanel>
                            <TextBlock x:Name="TitleText"
                                       Text="{TemplateBinding Title}"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                            <TextBlock x:Name="DescriptionText"
                                       Text="{TemplateBinding Description}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0"
                                       Foreground="{DynamicResource RibbonKit.Brushes.Text.Secondary}" />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Title" Value="{x:Null}">
                            <Setter TargetName="TitleText" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Description" Value="{x:Null}">
                            <Setter TargetName="DescriptionText" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="DescriptionText" Property="Margin" Value="0" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         RibbonToggleButton — like RibbonButton + checked accent tint
         ============================================================ -->
    <Style TargetType="{x:Type controls:RibbonToggleButton}">
        <Setter Property="Foreground" Value="{DynamicResource RibbonKit.Brushes.Text.Primary}" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:RibbonToggleButton}">
                    <Border x:Name="Chrome"
                            Background="Transparent"
                            CornerRadius="{DynamicResource RibbonKit.Metrics.ControlCornerRadius}"
                            Margin="1"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <!-- Checked / hover / press cross-fade layers. Checked eases over the
                                 ToggleState token; hover/press over the Hover token. Checked+hover
                                 composes (check wash + hover wash) rather than a separate brush.
                                 Behind the content, non-hit-testable. -->
                            <Border x:Name="CheckWash"
                                    Background="{DynamicResource RibbonKit.Brushes.Control.CheckedBackground}"
                                    CornerRadius="{DynamicResource RibbonKit.Metrics.ControlCornerRadius}"
                                    Opacity="0" IsHitTestVisible="False" />
                            <Border x:Name="HoverWash"
                                    Background="{DynamicResource RibbonKit.Brushes.Control.HoverBackground}"
                                    CornerRadius="{DynamicResource RibbonKit.Metrics.ControlCornerRadius}"
                                    Opacity="0" IsHitTestVisible="False" />
                            <Border x:Name="PressWash"
                                    Background="{DynamicResource RibbonKit.Brushes.Control.PressedBackground}"
                                    CornerRadius="{DynamicResource RibbonKit.Metrics.ControlCornerRadius}"
                                    Opacity="0" IsHitTestVisible="False" />
                            <StackPanel x:Name="LargeLayout"
                                        Orientation="Vertical"
                                        Margin="6,8,6,0"
                                        VerticalAlignment="Center">
                                <Image x:Name="LargeImage"
                                       Source="{TemplateBinding LargeIcon}"
                                       Width="32" Height="32"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center" />
                                <TextBlock Text="{TemplateBinding Header}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="76"
                                           MinHeight="32"
                                           MaxHeight="48"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                            <StackPanel x:Name="MediumLayout"
                                        Orientation="Horizontal"
                                        Margin="4,2"
                                        VerticalAlignment="Center"
                                        Visibility="Collapsed">
                                <Image Source="{TemplateBinding Icon}"
                                       Width="16" Height="16"
                                       Stretch="Uniform"
                                       VerticalAlignment="Center" />
                                <TextBlock Text="{TemplateBinding Header}"
                                           Margin="5,0,2,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <Grid x:Name="SmallLayout"
                                  Width="16" Height="16"
                                  Margin="5,3"
                                  VerticalAlignment="Center"
                                  Visibility="Collapsed">
                                <Image x:Name="SmallImage"
                                       Source="{TemplateBinding Icon}"
                                       Width="16" Height="16"
                                       Stretch="Uniform" />
                                <Rectangle x:Name="SmallImageTint" Width="16" Height="16"
                                           Fill="#FFFFFF"
                                           Visibility="Collapsed">
                                    <Rectangle.OpacityMask>
                                        <ImageBrush ImageSource="{Binding Icon, RelativeSource={RelativeSource TemplatedParent}}" />
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                            </Grid>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="LargeIcon" Value="{x:Null}">
                            <Setter TargetName="LargeImage" Property="Source"
                                    Value="{Binding Icon, RelativeSource={RelativeSource TemplatedParent}}" />
                        </Trigger>
                        <Trigger Property="Size" Value="Medium">
                            <Setter TargetName="LargeLayout" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="MediumLayout" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="Size" Value="Small">
                            <Setter TargetName="LargeLayout" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="SmallLayout" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <!-- Hover/press/checked highlight is a cross-fade of HoverWash/PressWash/
                             CheckWash, driven in code (RibbonToggleButton.OnPropertyChanged ->
                             RibbonMotion.FadeWash) so it honors the animation level / reduced-motion.
                             Checked+hover composes the check wash under the hover wash. Off a colored
                             surface only; the QAT-on-colored variants below stay instant. -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                        <!-- QAT on a colored surface: white silhouette icon, and band-based
                             hover/pressed/checked so the toggle blends like the plain buttons.
                             These come LAST so they win; checked/pressed after hover. -->
                        <Trigger Property="controls:Ribbon.QatOnColoredSurface" Value="True">
                            <Setter TargetName="SmallImage" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="SmallImageTint" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="controls:Ribbon.QatOnColoredSurface" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Chrome" Property="Background"
                                    Value="{DynamicResource RibbonKit.Brushes.Qat.ColoredHoverBackground}" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True" />
                                <Condition Property="controls:Ribbon.QatOnColoredSurface" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Chrome" Property="Background"
                                    Value="{DynamicResource RibbonKit.Brushes.Qat.ColoredPressedBackground}" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsPressed" Value="True" />
                                <Condition Property="controls:Ribbon.QatOnColoredSurface" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Chrome" Property="Background"
                                    Value="{DynamicResource RibbonKit.Brushes.Qat.ColoredPressedBackground}" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         RibbonDropDownButton — button that opens a menu flyout
         ============================================================ -->
    <Style TargetType="{x:Type controls:RibbonDropDownButton}">
        <Setter Property="Foreground" Value="{DynamicResource RibbonKit.Brushes.Text.Primary}" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:RibbonDropDownButton}">
                    <Grid>
                        <ToggleButton x:Name="PART_Toggle"
                                      IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                            <ToggleButton.Style>
                                <Style TargetType="{x:Type ToggleButton}">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type ToggleButton}">
                                                <Border x:Name="Chrome"
                                                        Background="Transparent"
                                                        CornerRadius="{DynamicResource RibbonKit.Metrics.ControlCornerRadius}"
                                                        Margin="1"
                                                        SnapsToDevicePixels="True">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Chrome" Property="Background"
                                                                Value="{DynamicResource RibbonKit.Brushes.Control.HoverBackground}" />
                                                    </Trigger>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Chrome" Property="Background"
                                                                Value="{DynamicResource RibbonKit.Brushes.Control.PressedBackground}" />
                                                    </Trigger>
                                                    <!-- On a colored QAT surface, hover with the band's brush (matches
                                                         RibbonButton) instead of the neutral gray. The checked (OPEN)
                                                         state comes AFTER hover and uses the pressed brush, so the open
                                                         dropdown holds ONE stable background regardless of IsMouseOver —
                                                         which is what was flickering. -->
                                                    <MultiTrigger>
                                                        <MultiTrigger.Conditions>
                                                            <Condition Property="IsMouseOver" Value="True" />
                                                            <Condition Property="controls:Ribbon.QatOnColoredSurface" Value="True" />
                                                        </MultiTrigger.Conditions>
                                                        <Setter TargetName="Chrome" Property="Background"
                                                                Value="{DynamicResource RibbonKit.Brushes.Qat.ColoredHoverBackground}" />
                                                    </MultiTrigger>
                                                    <MultiTrigger>
                                                        <MultiTrigger.Conditions>
                                                            <Condition Property="IsChecked" Value="True" />
                                                            <Condition Property="controls:Ribbon.QatOnColoredSurface" Value="True" />
                                                        </MultiTrigger.Conditions>
                                                        <Setter TargetName="Chrome" Property="Background"
                                                                Value="{DynamicResource RibbonKit.Brushes.Qat.ColoredPressedBackground}" />
                                                    </MultiTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ToggleButton.Style>
                            <Grid>
                                <StackPanel x:Name="LargeLayout"
                                            Orientation="Vertical"
                                            Margin="6,8,6,0"
                                            VerticalAlignment="Center">
                                    <Image x:Name="LargeImage"
                                           Source="{TemplateBinding LargeIcon}"
                                           Width="32" Height="32"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Center" />
                                    <!-- The dropdown chevron is INLINE at the end of the label (like
                                         Word) after whitespace, so it wraps with the last word and
                                         adds NO extra row — the button then matches a plain large
                                         button's height instead of being taller. -->
                                    <TextBlock TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="76"
                                               MinHeight="32"
                                               MaxHeight="48"
                                               Margin="0,4,0,0"><Run Text="{Binding Header, RelativeSource={RelativeSource TemplatedParent}}" /><Run FontFamily="Segoe MDL2 Assets" FontSize="9" Foreground="{DynamicResource RibbonKit.Brushes.Text.Secondary}" Text="  &#xE70D;" /></TextBlock>
                                </StackPanel>
                                <StackPanel x:Name="MediumLayout"
                                            Orientation="Horizontal"
                                            Margin="4,2"
                                            VerticalAlignment="Center"
                                            Visibility="Collapsed">
                                    <Image Source="{TemplateBinding Icon}"
                                           Width="16" Height="16"
                                           Stretch="Uniform"
                                           VerticalAlignment="Center" />
                                    <TextBlock Text="{TemplateBinding Header}"
                                               Margin="5,0,2,0"
                                               VerticalAlignment="Center" />
                                    <Path Data="M0,0 L3.5,3.5 L7,0"
                                          Stroke="{DynamicResource RibbonKit.Brushes.Text.Secondary}"
                                          StrokeThickness="1.5"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          VerticalAlignment="Center"
                                          Margin="2,2,1,0" />
                                </StackPanel>
                                <StackPanel x:Name="SmallLayout"
                                            Orientation="Horizontal"
                                            Margin="3,0"
                                            VerticalAlignment="Center"
                                            Visibility="Collapsed">
                                    <!-- Two renderings: the normal colour icon, and a flat white
                                         silhouette shown when the QAT sits on a colored surface
                                         (accent title bar / strip) — matches RibbonButton. -->
                                    <Grid Width="16" Height="16" Margin="2,3" VerticalAlignment="Center">
                                        <Image x:Name="SmallImage"
                                               Source="{TemplateBinding Icon}"
                                               Width="16" Height="16"
                                               Stretch="Uniform" />
                                        <Rectangle x:Name="SmallImageTint" Width="16" Height="16"
                                                   Fill="#FFFFFF"
                                                   Visibility="Collapsed">
                                            <Rectangle.OpacityMask>
                                                <ImageBrush ImageSource="{Binding Icon, RelativeSource={RelativeSource TemplatedParent}}" />
                                            </Rectangle.OpacityMask>
                                        </Rectangle>
                                    </Grid>
                                    <Path x:Name="SmallChevron"
                                          Data="M0,0 L3.5,3.5 L7,0"
                                          Stroke="{DynamicResource RibbonKit.Brushes.Text.Secondary}"
                                          StrokeThickness="1.5"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          VerticalAlignment="Center"
                                          Margin="1,2,1,0" />
                                </StackPanel>
                            </Grid>
                        </ToggleButton>
                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               StaysOpen="True"
                               Placement="Bottom"
                               IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                            <Border x:Name="PART_MenuHost"
                                    Background="{DynamicResource RibbonKit.Brushes.Ribbon.ContentBackground}"
                                    BorderBrush="{DynamicResource RibbonKit.Brushes.ScreenTip.Border}"
                                    BorderThickness="1"
                                    CornerRadius="{DynamicResource RibbonKit.Metrics.PopupCornerRadius}"
                                    Padding="4"
                                    Margin="4,2,8,8">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.25" />
                                </Border.Effect>
                                <!-- AdornerDecorator gives the popup its own adorner layer so
                                     KeyTip badges can render over the menu items. -->
                                <AdornerDecorator>
                                    <ItemsPresenter />
                                </AdornerDecorator>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="LargeIcon" Value="{x:Null}">
                            <Setter TargetName="LargeImage" Property="Source"
                                    Value="{Binding Icon, RelativeSource={RelativeSource TemplatedParent}}" />
                        </Trigger>
                        <Trigger Property="Size" Value="Medium">
                            <Setter TargetName="LargeLayout" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="MediumLayout" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="Size" Value="Small">
                            <Setter TargetName="LargeLayout" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="SmallLayout" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <!-- QAT on a colored surface: white silhouette icon + white chevron. -->
                        <Trigger Property="controls:Ribbon.QatOnColoredSurface" Value="True">
                            <Setter TargetName="SmallImage" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="SmallImageTint" Property="Visibility" Value="Visible" />
                            <Setter TargetName="SmallChevron" Property="Stroke" Value="#FFFFFF" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         RibbonSplitButton — command part + chevron dropdown part
         ============================================================ -->
    <Style TargetType="{x:Type controls:RibbonSplitButton}">
        <Setter Property="Foreground" Value="{DynamicResource RibbonKit.Brushes.Text.Primary}" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:RibbonSplitButton}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="PART_Primary"
                                Grid.Column="0"
                                Command="{TemplateBinding Command}"
                                CommandParameter="{TemplateBinding CommandParameter}">
                            <Button.Style>
                                <Style TargetType="{x:Type Button}">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type Button}">
                                                <Border x:Name="Chrome"
                                                        Background="Transparent"
                                                        CornerRadius="{DynamicResource RibbonKit.Metrics.SplitLeftCornerRadius}"
                                                        Margin="1,1,0,1"
                                                        SnapsToDevicePixels="True">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Chrome" Property="Background"
                                                                Value="{DynamicResource RibbonKit.Brushes.Control.HoverBackground}" />
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="Chrome" Property="Background"
                                                                Value="{DynamicResource RibbonKit.Brushes.Control.PressedBackground}" />
                                                    </Trigger>
                                                    <MultiTrigger>
                                                        <MultiTrigger.Conditions>
                                                            <Condition Property="IsMouseOver" Value="True" />
                                                            <Condition Property="controls:Ribbon.QatOnColoredSurface" Value="True" />
                                                        </MultiTrigger.Conditions>
                                                        <Setter TargetName="Chrome" Property="Background"
                                                                Value="{DynamicResource RibbonKit.Brushes.Qat.ColoredHoverBackground}" />
                                                    </MultiTrigger>
                                                    <MultiTrigger>
                                                        <MultiTrigger.Conditions>
                                                            <Condition Property="IsPressed" Value="True" />
                                                            <Condition Property="controls:Ribbon.QatOnColoredSurface" Value="True" />
                                                        </MultiTrigger.Conditions>
                                                        <Setter TargetName="Chrome" Property="Background"
                                                                Value="{DynamicResource RibbonKit.Brushes.Qat.ColoredPressedBackground}" />
                                                    </MultiTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <Grid>
                                <StackPanel x:Name="LargeLayout"
                                            Orientation="Vertical"
                                            Margin="6,8,6,0"
                                            VerticalAlignment="Center">
                                    <Image x:Name="LargeImage"
                                           Source="{TemplateBinding LargeIcon}"
                                           Width="32" Height="32"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Center" />
                                    <TextBlock Text="{TemplateBinding Header}"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="76"
                                               MinHeight="32"
                                               MaxHeight="48"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                                <StackPanel x:Name="MediumLayout"
                                            Orientation="Horizontal"
                                            Margin="4,2"
                                            VerticalAlignment="Center"
                                            Visibility="Collapsed">
                                    <Image Source="{TemplateBinding Icon}"
                                           Width="16" Height="16"
                                           Stretch="Uniform"
                                           VerticalAlignment="Center" />
                                    <TextBlock Text="{TemplateBinding Header}"
                                               Margin="5,0,2,0"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <Grid x:Name="SmallLayout"
                                      Width="16" Height="16"
                                      Margin="5,3"
                                      VerticalAlignment="Center"
                                      Visibility="Collapsed">
                                    <Image x:Name="SmallImage"
                                           Source="{TemplateBinding Icon}"
                                           Width="16" Height="16"
                                           Stretch="Uniform" />
                                    <Rectangle x:Name="SmallImageTint" Width="16" Height="16"
                                               Fill="#FFFFFF"
                                               Visibility="Collapsed">
                                        <Rectangle.OpacityMask>
                                            <ImageBrush ImageSource="{Binding Icon, RelativeSource={RelativeSource TemplatedParent}}" />
                                        </Rectangle.OpacityMask>
                                    </Rectangle>
                                </Grid>
                            </Grid>
                        </Button>
                        <ToggleButton x:Name="PART_Toggle"
                                      Grid.Column="1"
                                      Width="15"
                                      IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                            <ToggleButton.Style>
                                <Style TargetType="{x:Type ToggleButton}">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type ToggleButton}">
                                                <Border x:Name="Chrome"
                                                        Background="Transparent"
                                                        CornerRadius="{DynamicResource RibbonKit.Metrics.SplitRightCornerRadius}"
                                                        Margin="0,1,1,1"
                                                        SnapsToDevicePixels="True">
                                                    <Path x:Name="ToggleChevron"
                                                          Data="M0,0 L3.5,3.5 L7,0"
                                                          Stroke="{DynamicResource RibbonKit.Brushes.Text.Secondary}"
                                                          StrokeThickness="1.5"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Chrome" Property="Background"
                                                                Value="{DynamicResource RibbonKit.Brushes.Control.HoverBackground}" />
                                                    </Trigger>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Chrome" Property="Background"
                                                                Value="{DynamicResource RibbonKit.Brushes.Control.PressedBackground}" />
                                                    </Trigger>
                                                    <!-- Colored QAT surface: white chevron + band hover/open state. -->
                                                    <Trigger Property="controls:Ribbon.QatOnColoredSurface" Value="True">
                                                        <Setter TargetName="ToggleChevron" Property="Stroke" Value="#FFFFFF" />
                                                    </Trigger>
                                                    <MultiTrigger>
                                                        <MultiTrigger.Conditions>
                                                            <Condition Property="IsMouseOver" Value="True" />
                                                            <Condition Property="controls:Ribbon.QatOnColoredSurface" Value="True" />
                                                        </MultiTrigger.Conditions>
                                                        <Setter TargetName="Chrome" Property="Background"
                                                                Value="{DynamicResource RibbonKit.Brushes.Qat.ColoredHoverBackground}" />
                                                    </MultiTrigger>
                                                    <MultiTrigger>
                                                        <MultiTrigger.Conditions>
                                                            <Condition Property="IsChecked" Value="True" />
                                                            <Condition Property="controls:Ribbon.QatOnColoredSurface" Value="True" />
                                                        </MultiTrigger.Conditions>
                                                        <Setter TargetName="Chrome" Property="Background"
                                                                Value="{DynamicResource RibbonKit.Brushes.Qat.ColoredPressedBackground}" />
                                                    </MultiTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ToggleButton.Style>
                        </ToggleButton>
                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               StaysOpen="True"
                               Placement="Bottom"
                               IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                            <Border x:Name="PART_MenuHost"
                                    Background="{DynamicResource RibbonKit.Brushes.Ribbon.ContentBackground}"
                                    BorderBrush="{DynamicResource RibbonKit.Brushes.ScreenTip.Border}"
                                    BorderThickness="1"
                                    CornerRadius="{DynamicResource RibbonKit.Metrics.PopupCornerRadius}"
                                    Padding="4"
                                    Margin="4,2,8,8">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.25" />
                                </Border.Effect>
                                <!-- AdornerDecorator gives the popup its own adorner layer so
                                     KeyTip badges can render over the menu items. -->
                                <AdornerDecorator>
                                    <ItemsPresenter />
                                </AdornerDecorator>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="LargeIcon" Value="{x:Null}">
                            <Setter TargetName="LargeImage" Property="Source"
                                    Value="{Binding Icon, RelativeSource={RelativeSource TemplatedParent}}" />
                        </Trigger>
                        <Trigger Property="Size" Value="Medium">
                            <Setter TargetName="LargeLayout" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="MediumLayout" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="Size" Value="Small">
                            <Setter TargetName="LargeLayout" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="SmallLayout" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <!-- QAT on a colored surface: white silhouette primary icon (chevron is
                             whitened in the toggle's own template). -->
                        <Trigger Property="controls:Ribbon.QatOnColoredSurface" Value="True">
                            <Setter TargetName="SmallImage" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="SmallImageTint" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         RibbonMenuItem — row inside dropdown flyouts
         ============================================================ -->
    <Style TargetType="{x:Type controls:RibbonMenuItem}">
        <Setter Property="Foreground" Value="{DynamicResource RibbonKit.Brushes.Text.Primary}" />
        <Setter Property="MinWidth" Value="160" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:RibbonMenuItem}">
                    <Border x:Name="Chrome"
                            Background="Transparent"
                            CornerRadius="{DynamicResource RibbonKit.Metrics.ControlCornerRadius}"
                            Padding="6,5"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Image Grid.Column="0"
                                   Source="{TemplateBinding Icon}"
                                   Width="16" Height="16"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Text="{TemplateBinding Header}"
                                       VerticalAlignment="Center"
                                       Margin="2,0,8,0" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background"
                                    Value="{DynamicResource RibbonKit.Brushes.Control.HoverBackground}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Chrome" Property="Background"
                                    Value="{DynamicResource RibbonKit.Brushes.Control.PressedBackground}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         RibbonComboBox — optional label + compact selection box
         (the Office font-family / font-size pattern)
         ============================================================ -->
    <Style TargetType="{x:Type controls:RibbonComboBox}">
        <Setter Property="Foreground" Value="{DynamicResource RibbonKit.Brushes.Text.Primary}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="{x:Type ComboBoxItem}">
                    <Setter Property="Foreground" Value="{DynamicResource RibbonKit.Brushes.Text.Primary}" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                                <Border x:Name="Chrome"
                                        Background="Transparent"
                                        CornerRadius="{DynamicResource RibbonKit.Metrics.ControlCornerRadius}"
                                        Padding="7,4"
                                        SnapsToDevicePixels="True">
                                    <ContentPresenter VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter TargetName="Chrome" Property="Background"
                                                Value="{DynamicResource RibbonKit.Brushes.Control.HoverBackground}" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Chrome" Property="Background"
                                                Value="{DynamicResource RibbonKit.Brushes.Control.CheckedBackground}" />
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.4" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:RibbonComboBox}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="HeaderText"
                                   Text="{TemplateBinding Header}"
                                   VerticalAlignment="Center"
                                   Margin="2,0,6,0" />
                        <!-- MinHeight gives the input box vertical breathing room: without it
                             the box collapses to the text height and reads as cramped. -->
                        <Grid Width="{TemplateBinding InputWidth}" MinHeight="24">
                            <Border x:Name="Chrome"
                                    Background="#FFFFFF"
                                    BorderBrush="{DynamicResource RibbonKit.Brushes.ScreenTip.Border}"
                                    BorderThickness="1"
                                    CornerRadius="{DynamicResource RibbonKit.Metrics.ControlCornerRadius}"
                                    SnapsToDevicePixels="True" />
                            <ToggleButton x:Name="DropToggle"
                                          ClickMode="Press"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <ToggleButton.Style>
                                    <Style TargetType="{x:Type ToggleButton}">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type ToggleButton}">
                                                    <Border Background="Transparent">
                                                        <Path Data="M0,0 L3.5,3.5 L7,0"
                                                              Stroke="{DynamicResource RibbonKit.Brushes.Text.Secondary}"
                                                              StrokeThickness="1.5"
                                                              StrokeStartLineCap="Round"
                                                              StrokeEndLineCap="Round"
                                                              HorizontalAlignment="Right"
                                                              VerticalAlignment="Center"
                                                              Margin="0,0,7,0" />
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ToggleButton.Style>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Margin="8,0,22,0"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" />
                            <TextBox x:Name="PART_EditableTextBox"
                                     Visibility="Hidden"
                                     Margin="5,1,21,1"
                                     Padding="0"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     VerticalContentAlignment="Center"
                                     Focusable="True" />
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Border Background="{DynamicResource RibbonKit.Brushes.Ribbon.ContentBackground}"
                                        BorderBrush="{DynamicResource RibbonKit.Brushes.ScreenTip.Border}"
                                        BorderThickness="1"
                                        CornerRadius="{DynamicResource RibbonKit.Metrics.ControlCornerRadius}"
                                        Padding="3"
                                        Margin="4,2,8,8"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.25" />
                                    </Border.Effect>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Header" Value="{x:Null}">
                            <Setter TargetName="HeaderText" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="IsEditable" Value="True">
                            <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible" />
                            <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush"
                                    Value="{DynamicResource RibbonKit.Brushes.Text.Secondary}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush"
                                    Value="{DynamicResource RibbonKit.Brushes.Accent}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Modern (Office 2024) backstage palette — a light rail with neutral highlights.
         The selection bar and selected-item text use the live theme accent. -->
    <SolidColorBrush x:Key="RibbonKit.Brushes.Backstage.Modern.NavBackground" Color="#F5F4F3" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Backstage.Modern.Foreground" Color="#201F1E" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Backstage.Modern.ItemHover" Color="#EDEBE9" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Backstage.Modern.ItemSelected" Color="#E1DFDD" />
    <!-- Translucent variants used when Backstage.Translucent is on (to reveal Mica). -->
    <SolidColorBrush x:Key="RibbonKit.Brushes.Backstage.Modern.NavBackgroundTranslucent" Color="#CCF5F4F3" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Backstage.ContentTranslucent" Color="#E6FFFFFF" />

    <!-- ============================================================
         Backstage — navigation column (back button + tabs) + content.
         Two looks via the inherited Backstage.Design property: Classic
         (solid accent column, default) and Modern (the light 2024 rail).
         ============================================================ -->
    <Style TargetType="{x:Type controls:Backstage}">
        <Setter Property="Background" Value="{DynamicResource RibbonKit.Brushes.Backstage.ContentBackground}" />
        <!-- Nav-column foreground (back arrow + item text). White for the accent column;
             the Modern trigger switches it to dark for the light rail. -->
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:Backstage}">
                    <Grid x:Name="RootGrid" Background="{TemplateBinding Background}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="NavColumnDef" Width="220" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="NavColumn" Grid.Column="0"
                                Background="{DynamicResource RibbonKit.Brushes.Accent}">
                            <DockPanel LastChildFill="True">
                                <Button x:Name="PART_BackButton"
                                        DockPanel.Dock="Top"
                                        Width="36" Height="36"
                                        Margin="20,20,20,24"
                                        HorizontalAlignment="Left"
                                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type controls:Backstage}}}"
                                        ToolTip="Back">
                                    <Button.Style>
                                        <Style TargetType="{x:Type Button}">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="{x:Type Button}">
                                                        <Grid Background="Transparent">
                                                            <!-- Foreground-tinted hover disc: subtle on
                                                                 both the accent column and the light rail. -->
                                                            <Ellipse x:Name="HoverFill"
                                                                     Fill="{TemplateBinding Foreground}"
                                                                     Opacity="0" />
                                                            <Ellipse Stroke="{TemplateBinding Foreground}"
                                                                     StrokeThickness="1.5"
                                                                     Fill="Transparent" />
                                                            <!-- Symmetric bounds so centering is exact -->
                                                            <Path Data="M12,6 H0 M0,6 L5,1 M0,6 L5,11"
                                                                  Stroke="{TemplateBinding Foreground}"
                                                                  StrokeThickness="2"
                                                                  StrokeStartLineCap="Round"
                                                                  StrokeEndLineCap="Round"
                                                                  StrokeLineJoin="Round"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center" />
                                                        </Grid>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="HoverFill" Property="Opacity" Value="0.15" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <!-- Top items pack from the top, Bottom items pin to the bottom
                                     (Word's Account / Options footer), with a divider between. The
                                     bottom margin keeps footer items off the window's bottom edge. -->
                                <controls:BackstageNavPanel
                                          IsItemsHost="True"
                                          Background="Transparent"
                                          Margin="0,0,0,14"
                                          SeparatorBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type controls:Backstage}}}" />
                            </DockPanel>
                        </Border>
                        <Border x:Name="ContentArea" Grid.Column="1"
                                Background="{DynamicResource RibbonKit.Brushes.Backstage.ContentBackground}"
                                Padding="42,32">
                            <ContentPresenter ContentSource="SelectedContent" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- Modern (2024): a narrower, light rail with dark foreground. -->
                        <Trigger Property="controls:Backstage.Design" Value="Modern">
                            <Setter Property="Foreground"
                                    Value="{StaticResource RibbonKit.Brushes.Backstage.Modern.Foreground}" />
                            <Setter TargetName="NavColumn" Property="Background"
                                    Value="{StaticResource RibbonKit.Brushes.Backstage.Modern.NavBackground}" />
                            <Setter TargetName="NavColumnDef" Property="Width" Value="200" />
                        </Trigger>

                        <!-- Translucent (reveal a window Mica/Acrylic backdrop behind the
                             backstage): clear the root fill and soften the content panel. Placed
                             AFTER the Modern trigger so the translucent nav brush wins. -->
                        <Trigger Property="Translucent" Value="True">
                            <Setter TargetName="RootGrid" Property="Background" Value="Transparent" />
                            <Setter TargetName="ContentArea" Property="Background"
                                    Value="{StaticResource RibbonKit.Brushes.Backstage.ContentTranslucent}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="controls:Backstage.Design" Value="Modern" />
                                <Condition Property="Translucent" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="NavColumn" Property="Background"
                                    Value="{StaticResource RibbonKit.Brushes.Backstage.Modern.NavBackgroundTranslucent}" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         BackstageTabItem — nav row in the accent column
         ============================================================ -->
    <Style TargetType="{x:Type controls:BackstageTabItem}">
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:BackstageTabItem}">
                    <Grid SnapsToDevicePixels="True">
                        <!-- Accent selection bar on the left edge (Modern only). -->
                        <Rectangle x:Name="SelBar"
                                   Width="3"
                                   HorizontalAlignment="Left"
                                   Margin="0,5"
                                   RadiusX="1.5" RadiusY="1.5"
                                   Fill="{DynamicResource RibbonKit.Brushes.Accent}"
                                   Visibility="Collapsed" />
                        <Border x:Name="Chrome"
                                Background="Transparent"
                                CornerRadius="0"
                                Padding="26,11">
                            <StackPanel Orientation="Horizontal">
                                <!-- Reserved icon column: a foreground-tinted silhouette of
                                     the item's Icon. When no Icon is set the mask is empty, so
                                     the 16px slot stays blank and every item stays aligned. -->
                                <Grid Width="16" Height="16" Margin="0,0,12,0" VerticalAlignment="Center">
                                    <Rectangle Fill="{TemplateBinding Foreground}">
                                        <Rectangle.OpacityMask>
                                            <ImageBrush ImageSource="{Binding Icon, RelativeSource={RelativeSource TemplatedParent}}" />
                                        </Rectangle.OpacityMask>
                                    </Rectangle>
                                </Grid>
                                <ContentPresenter ContentSource="Header"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                            </StackPanel>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- Classic (accent column): full-width fills. -->
                        <Trigger SourceName="Chrome" Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background"
                                    Value="{DynamicResource RibbonKit.Brushes.Backstage.ItemHoverBackground}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Chrome" Property="Background"
                                    Value="{DynamicResource RibbonKit.Brushes.Backstage.ItemSelectedBackground}" />
                        </Trigger>

                        <!-- Modern (2024): dark text, an inset rounded highlight, and an
                             accent bar + accent text on the selected item. These come AFTER
                             the classic triggers so they win when the design is Modern. -->
                        <Trigger Property="controls:Backstage.Design" Value="Modern">
                            <Setter Property="Foreground"
                                    Value="{StaticResource RibbonKit.Brushes.Backstage.Modern.Foreground}" />
                            <Setter TargetName="Chrome" Property="CornerRadius" Value="4" />
                            <Setter TargetName="Chrome" Property="Margin" Value="8,1" />
                            <Setter TargetName="Chrome" Property="Padding" Value="14,9" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="controls:Backstage.Design" Value="Modern" />
                                <Condition SourceName="Chrome" Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Chrome" Property="Background"
                                    Value="{StaticResource RibbonKit.Brushes.Backstage.Modern.ItemHover}" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="controls:Backstage.Design" Value="Modern" />
                                <Condition Property="IsSelected" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Chrome" Property="Background"
                                    Value="{StaticResource RibbonKit.Brushes.Backstage.Modern.ItemSelected}" />
                            <Setter TargetName="SelBar" Property="Visibility" Value="Visible" />
                            <Setter Property="Foreground"
                                    Value="{DynamicResource RibbonKit.Brushes.Accent}" />
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         RibbonGalleryItem — selectable tile with hover/selected chrome
         ============================================================ -->
    <Style TargetType="{x:Type controls:RibbonGalleryItem}">
        <Setter Property="Foreground" Value="{DynamicResource RibbonKit.Brushes.Text.Primary}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:RibbonGalleryItem}">
                    <!-- MinHeight sets the tile row height; the presenter centers the
                         (naturally-sized) content inside it. -->
                    <Border x:Name="Chrome"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="1"
                            CornerRadius="{DynamicResource RibbonKit.Metrics.ControlCornerRadius}"
                            Margin="1"
                            Padding="5,3"
                            MinHeight="48"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background"
                                    Value="{DynamicResource RibbonKit.Brushes.Control.HoverBackground}" />
                            <Setter TargetName="Chrome" Property="BorderBrush"
                                    Value="{DynamicResource RibbonKit.Brushes.Group.Separator}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Chrome" Property="Background"
                                    Value="{DynamicResource RibbonKit.Brushes.Control.CheckedBackground}" />
                            <Setter TargetName="Chrome" Property="BorderBrush"
                                    Value="{DynamicResource RibbonKit.Brushes.Accent}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         RibbonGallery — wrapped tiles (for use inside flyouts)
         ============================================================ -->
    <Style TargetType="{x:Type controls:RibbonGallery}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <WrapPanel />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:RibbonGallery}">
                    <Border Background="{TemplateBinding Background}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      MaxHeight="340">
                            <ItemsPresenter />
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         InRibbonGallery — strip + scroll/expand buttons + overlay popup
         ============================================================ -->
    <Style TargetType="{x:Type controls:InRibbonGallery}">
        <Setter Property="Foreground" Value="{DynamicResource RibbonKit.Brushes.Text.Primary}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <!-- Height = exactly one tile row (48 min-height incl. border + 2 margin = 50)
             + the 4px strip margins. The viewport equals the row height EXACTLY, so
             no second-row sliver is visible or hoverable in the strip. -->
        <Setter Property="Height" Value="54" />
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <WrapPanel />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:InRibbonGallery}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="17" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.ColumnSpan="2"
                                Background="#FFFFFF"
                                BorderBrush="{DynamicResource RibbonKit.Brushes.ScreenTip.Border}"
                                BorderThickness="1"
                                CornerRadius="{DynamicResource RibbonKit.Metrics.ControlCornerRadius}"
                                SnapsToDevicePixels="True" />
                        <Decorator x:Name="PART_ContentHost" Grid.Column="0" Margin="2">
                            <Grid>
                                <ScrollViewer x:Name="PART_ScrollViewer"
                                              VerticalScrollBarVisibility="Hidden"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Focusable="False">
                                    <!-- MaxWidth caps wrapping at the strip's width even when
                                         re-homed into the (unconstrained) popup, so the
                                         expanded gallery wraps into rows instead of one line -->
                                    <ItemsPresenter MaxWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}" />
                                </ScrollViewer>
                            </Grid>
                        </Decorator>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <StackPanel.Resources>
                                <!-- Shared chrome for the three side buttons -->
                                <Style x:Key="SideButtonStyle" TargetType="{x:Type ButtonBase}">
                                    <Setter Property="Height" Value="17" />
                                    <Setter Property="Focusable" Value="False" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type ButtonBase}">
                                                <Border x:Name="Chrome"
                                                        Background="Transparent"
                                                        CornerRadius="{DynamicResource RibbonKit.Metrics.SmallControlCornerRadius}"
                                                        Margin="1,0,2,0"
                                                        SnapsToDevicePixels="True">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Chrome" Property="Background"
                                                                Value="{DynamicResource RibbonKit.Brushes.Control.HoverBackground}" />
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="Chrome" Property="Background"
                                                                Value="{DynamicResource RibbonKit.Brushes.Control.PressedBackground}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </StackPanel.Resources>
                            <RepeatButton x:Name="PART_LineUp"
                                          Style="{StaticResource SideButtonStyle}">
                                <Path Data="M0,3.5 L3.5,0 L7,3.5"
                                      Stroke="{DynamicResource RibbonKit.Brushes.Text.Secondary}"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" />
                            </RepeatButton>
                            <RepeatButton x:Name="PART_LineDown"
                                          Style="{StaticResource SideButtonStyle}">
                                <Path Data="M0,0 L3.5,3.5 L7,0"
                                      Stroke="{DynamicResource RibbonKit.Brushes.Text.Secondary}"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" />
                            </RepeatButton>
                            <ToggleButton x:Name="PART_ExpandToggle"
                                          Style="{StaticResource SideButtonStyle}"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <StackPanel>
                                    <Rectangle Height="1.5" Width="8"
                                               Fill="{DynamicResource RibbonKit.Brushes.Text.Secondary}"
                                               Margin="0,0,0,2" />
                                    <Path Data="M0,0 L3.5,3.5 L7,0"
                                          Stroke="{DynamicResource RibbonKit.Brushes.Text.Secondary}"
                                          StrokeThickness="1.5"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          HorizontalAlignment="Center" />
                                </StackPanel>
                            </ToggleButton>
                        </StackPanel>
                        <!-- Expanded gallery: overlays the strip, like Office -->
                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               StaysOpen="True"
                               Placement="Relative"
                               HorizontalOffset="-4"
                               VerticalOffset="-4"
                               IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                            <Border x:Name="PART_PopupHost"
                                    Background="{DynamicResource RibbonKit.Brushes.Ribbon.ContentBackground}"
                                    BorderBrush="{DynamicResource RibbonKit.Brushes.ScreenTip.Border}"
                                    BorderThickness="1"
                                    CornerRadius="{DynamicResource RibbonKit.Metrics.PopupCornerRadius}"
                                    Padding="5"
                                    Margin="4,4,8,8"
                                    MaxHeight="340">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.25" />
                                </Border.Effect>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         RibbonWindow — Office-style chrome: custom title bar with
         TitleBarContent slot + themed caption buttons, native
         drag/resize/maximize via WindowChrome
         ============================================================ -->
    <Style TargetType="{x:Type controls:RibbonWindow}">
        <Setter Property="Background" Value="#FFFFFF" />
        <Setter Property="Foreground" Value="{DynamicResource RibbonKit.Brushes.Text.Primary}" />
        <Setter Property="WindowChrome.WindowChrome">
            <Setter.Value>
                <!-- No GlassFrameThickness="-1": extending the DWM glass across the whole
                     window breaks WindowChrome's maximize/work-area handling (the window
                     then overhangs the screen when maximized). Default glass + the
                     WM_GETMINMAXINFO hook in RibbonWindow keep maximize correct. -->
                <WindowChrome CaptionHeight="34"
                              GlassFrameThickness="-1"
                              ResizeBorderThickness="{x:Static SystemParameters.WindowResizeBorderThickness}"
                              CornerRadius="0"
                              UseAeroCaptionButtons="False" />
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:RibbonWindow}">
                    <Border x:Name="PART_WindowRoot" Background="{TemplateBinding Background}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="34" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- Title bar (its own band token, separate from the tab strip:
                                 Office 2019/2013 use a colored title bar over a light strip) -->
                            <Grid Grid.Row="0" Background="{DynamicResource RibbonKit.Brushes.TitleBar.Background}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Quick-access slot: interactive inside the caption area.
                                     Hidden while the ribbon's backstage is open. -->
                                <ContentPresenter x:Name="TitleBarContentHost"
                                                  Grid.Column="0"
                                                  Content="{TemplateBinding TitleBarContent}"
                                                  VerticalAlignment="Center"
                                                  Margin="10,0,6,0"
                                                  WindowChrome.IsHitTestVisibleInChrome="True" />

                                <TextBlock Grid.Column="1"
                                           Text="{TemplateBinding Title}"
                                           FontSize="12"
                                           Foreground="{DynamicResource RibbonKit.Brushes.TitleBar.Foreground}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="8,0" />

                                <!-- Caption buttons -->
                                <StackPanel Grid.Column="2"
                                            Orientation="Horizontal"
                                            WindowChrome.IsHitTestVisibleInChrome="True">
                                    <StackPanel.Resources>
                                        <Style x:Key="CaptionButtonStyle" TargetType="{x:Type Button}">
                                            <Setter Property="Width" Value="46" />
                                            <Setter Property="Height" Value="34" />
                                            <Setter Property="Focusable" Value="False" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="{x:Type Button}">
                                                        <Border x:Name="Chrome" Background="Transparent">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center" />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Chrome" Property="Background"
                                                                        Value="{DynamicResource RibbonKit.Brushes.CaptionButton.HoverBackground}" />
                                                            </Trigger>
                                                            <Trigger Property="IsPressed" Value="True">
                                                                <Setter TargetName="Chrome" Property="Background"
                                                                        Value="{DynamicResource RibbonKit.Brushes.CaptionButton.PressedBackground}" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                        <Style x:Key="CloseCaptionButtonStyle" TargetType="{x:Type Button}">
                                            <Setter Property="Width" Value="46" />
                                            <Setter Property="Height" Value="34" />
                                            <Setter Property="Focusable" Value="False" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="{x:Type Button}">
                                                        <Border x:Name="Chrome" Background="Transparent">
                                                            <Path x:Name="Glyph"
                                                                  Data="M0,0 L9,9 M9,0 L0,9"
                                                                  Stroke="{DynamicResource RibbonKit.Brushes.TitleBar.Foreground}"
                                                                  StrokeThickness="1"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center" />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Chrome" Property="Background"
                                                                        Value="{DynamicResource RibbonKit.Brushes.CaptionButton.CloseHoverBackground}" />
                                                                <Setter TargetName="Glyph" Property="Stroke" Value="#FFFFFF" />
                                                            </Trigger>
                                                            <Trigger Property="IsPressed" Value="True">
                                                                <Setter TargetName="Chrome" Property="Background"
                                                                        Value="{DynamicResource RibbonKit.Brushes.CaptionButton.ClosePressedBackground}" />
                                                                <Setter TargetName="Glyph" Property="Stroke" Value="#FFFFFF" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </StackPanel.Resources>
                                    <Button Style="{StaticResource CaptionButtonStyle}"
                                            Command="{x:Static SystemCommands.MinimizeWindowCommand}"
                                            ToolTip="Minimize">
                                        <Path Data="M0,0 H10"
                                              Stroke="{DynamicResource RibbonKit.Brushes.TitleBar.Foreground}"
                                              StrokeThickness="1" />
                                    </Button>
                                    <Button x:Name="MaximizeButton"
                                            Style="{StaticResource CaptionButtonStyle}"
                                            Command="{x:Static SystemCommands.MaximizeWindowCommand}"
                                            ToolTip="Maximize">
                                        <Path Data="M0,0 H9 V9 H0 Z"
                                              Stroke="{DynamicResource RibbonKit.Brushes.TitleBar.Foreground}"
                                              StrokeThickness="1" />
                                    </Button>
                                    <Button x:Name="RestoreButton"
                                            Style="{StaticResource CaptionButtonStyle}"
                                            Command="{x:Static SystemCommands.RestoreWindowCommand}"
                                            ToolTip="Restore Down"
                                            Visibility="Collapsed">
                                        <Path Data="M0,2 H7 V9 H0 Z M2,2 V0 H9 V7 H7"
                                              Stroke="{DynamicResource RibbonKit.Brushes.TitleBar.Foreground}"
                                              StrokeThickness="1" />
                                    </Button>
                                    <Button Style="{StaticResource CloseCaptionButtonStyle}"
                                            Command="{x:Static SystemCommands.CloseWindowCommand}"
                                            ToolTip="Close" />
                                </StackPanel>
                            </Grid>

                            <!-- Window content. The AdornerDecorator is REQUIRED: without
                                 it adorner-hosted overlays (the backstage) cannot render. -->
                            <AdornerDecorator Grid.Row="1">
                                <ContentPresenter />
                            </AdornerDecorator>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="WindowState" Value="Maximized">
                            <!-- The maximize overhang (a WindowChrome window is placed to
                                 hang past every screen edge) is compensated in code:
                                 RibbonWindow measures how far the window spills past the
                                 monitor work area and insets PART_WindowRoot by exactly
                                 that, so the caption buttons stay on-screen and the ribbon
                                 card keeps its side margin. Here we only swap the caption
                                 glyph from Maximize to Restore. -->
                            <Setter TargetName="MaximizeButton" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="RestoreButton" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsTitleBarContentVisible" Value="False">
                            <Setter TargetName="TitleBarContentHost" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         RibbonOptionsDialog — Word-Options-style dialog: page rail on
         the left, selected page content on the right, OK/Cancel below.
         Rail brushes are LOCAL statics (same precedent as the Modern
         backstage brushes); everything else rides the theme tokens.
         ============================================================ -->
    <SolidColorBrush x:Key="OptionsDialog.RailBackground" Color="#F5F4F3" />

    <Style x:Key="OptionsDialogActionButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="MinWidth" Value="88" />
        <Setter Property="Padding" Value="14,6" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="Foreground" Value="{DynamicResource RibbonKit.Brushes.Text.Primary}" />
        <Setter Property="Background" Value="{DynamicResource RibbonKit.Brushes.Ribbon.ContentBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RibbonKit.Brushes.ScreenTip.Border}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <!-- The Padding is applied to the CONTENT (not the Chrome), so the accent
                         wash + border fill the WHOLE button edge-to-edge — otherwise only the
                         inner (un-padded) area would light up on hover. -->
                    <Border x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{DynamicResource RibbonKit.Metrics.ControlCornerRadius}"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <!-- Accent-follow hover/press: a translucent wash of the CURRENT
                                 accent over the white button gives a light tint of whatever the
                                 accent is (light green for a green accent, etc.) — never a fixed
                                 blue. Opacity, not a baked colour, so it tracks accent changes. -->
                            <Border x:Name="Wash"
                                    Background="{DynamicResource RibbonKit.Brushes.Accent}"
                                    CornerRadius="{DynamicResource RibbonKit.Metrics.ControlCornerRadius}"
                                    Opacity="0" />
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Wash" Property="Opacity" Value="0.16" />
                            <Setter TargetName="Chrome" Property="BorderBrush"
                                    Value="{DynamicResource RibbonKit.Brushes.Accent}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Wash" Property="Opacity" Value="0.30" />
                            <Setter TargetName="Chrome" Property="BorderBrush"
                                    Value="{DynamicResource RibbonKit.Brushes.Accent}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- The accent (OK) button needs its OWN template: the action style washes the button with
         the accent colour, which is invisible on a button already filled with that accent. Here a
         translucent WHITE wash lightens it on hover and a translucent BLACK wash darkens it on
         press — accent-agnostic, always staying in the accent's own colour family. -->
    <Style x:Key="OptionsDialogPrimaryButtonStyle"
           TargetType="{x:Type Button}"
           BasedOn="{StaticResource OptionsDialogActionButtonStyle}">
        <Setter Property="Background" Value="{DynamicResource RibbonKit.Brushes.Accent}" />
        <Setter Property="BorderBrush" Value="{DynamicResource RibbonKit.Brushes.Accent}" />
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <!-- Padding on the CONTENT, not the Chrome, so the wash fills the whole
                         button (a Chrome Padding would leave the padded rim un-washed — the
                         "only the centre lights up" bug). -->
                    <Border x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{DynamicResource RibbonKit.Metrics.ControlCornerRadius}"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <!-- Wash fills the Chrome, over the accent fill, under the label. -->
                            <Border x:Name="Wash"
                                    CornerRadius="{DynamicResource RibbonKit.Metrics.ControlCornerRadius}"
                                    Opacity="0" />
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Wash" Property="Background" Value="#FFFFFF" />
                            <Setter TargetName="Wash" Property="Opacity" Value="0.22" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Wash" Property="Background" Value="#000000" />
                            <Setter TargetName="Wash" Property="Opacity" Value="0.16" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Compact icon-only variant for the Up/Down reorder buttons on the customization pages.
         Inherits the action style's template (so hover/press feedback matches) but is narrow. -->
    <Style x:Key="OptionsDialogReorderButtonStyle"
           TargetType="{x:Type Button}"
           BasedOn="{StaticResource OptionsDialogActionButtonStyle}">
        <Setter Property="MinWidth" Value="40" />
        <Setter Property="Padding" Value="6" />
        <Setter Property="FontSize" Value="11" />
    </Style>

    <!-- The page control IS the nav entry: it renders only its Header (the dialog presents
         the page's Content separately), highlighting from its host ListBoxItem's state. -->
    <Style TargetType="{x:Type controls:RibbonOptionsPage}">
        <Setter Property="Foreground" Value="{DynamicResource RibbonKit.Brushes.Text.Primary}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:RibbonOptionsPage}">
                    <Grid Background="Transparent">
                        <Border x:Name="Chrome"
                                Background="Transparent"
                                CornerRadius="{DynamicResource RibbonKit.Metrics.ControlCornerRadius}"
                                Padding="14,8"
                                Margin="8,1"
                                SnapsToDevicePixels="True">
                            <ContentPresenter ContentSource="Header"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <Rectangle x:Name="SelectedBar"
                                   Width="3"
                                   RadiusX="1.5"
                                   RadiusY="1.5"
                                   Margin="8,9"
                                   HorizontalAlignment="Left"
                                   Fill="{DynamicResource RibbonKit.Brushes.Accent}"
                                   Visibility="Collapsed" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background"
                                    Value="{DynamicResource RibbonKit.Brushes.Control.HoverBackground}" />
                        </Trigger>
                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}"
                                     Value="True">
                            <Setter TargetName="Chrome" Property="Background"
                                    Value="{DynamicResource RibbonKit.Brushes.Control.CheckedBackground}" />
                            <Setter TargetName="SelectedBar" Property="Visibility" Value="Visible" />
                            <Setter Property="Foreground" Value="{DynamicResource RibbonKit.Brushes.Accent}" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Title-bar close button: transparent, X glyph, Windows-red hover. No min/max — a
         modal dialog needs only Close (reuses the RibbonWindow close-glyph pattern). -->
    <Style x:Key="OptionsDialogCloseButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="Width" Value="46" />
        <Setter Property="Height" Value="34" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Chrome" Background="Transparent">
                        <Path x:Name="Glyph"
                              Data="M0,0 L9,9 M9,0 L0,9"
                              Stroke="{DynamicResource RibbonKit.Brushes.Text.Primary}"
                              StrokeThickness="1"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="#E81123" />
                            <Setter TargetName="Glyph" Property="Stroke" Value="#FFFFFF" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="#F1707A" />
                            <Setter TargetName="Glyph" Property="Stroke" Value="#FFFFFF" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:RibbonOptionsDialog}">
        <Setter Property="Background" Value="{DynamicResource RibbonKit.Brushes.Ribbon.ContentBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource RibbonKit.Brushes.Text.Primary}" />
        <!-- Custom chrome: WindowStyle=None (set in code) + WindowChrome, so the dialog draws
             its own white title bar with a single Close button. CaptionHeight matches the
             title bar height so it's draggable; ResizeBorderThickness makes the edges
             resize-grabbable. Corners are rounded by the DWM (MicaHelper.SetRoundedCorners in
             OnSourceInitialized), which also draws the border — hence no WindowChrome corner
             radius and no border on the root here (a square one would fight the rounded DWM
             corners). -->
        <Setter Property="WindowChrome.WindowChrome">
            <Setter.Value>
                <WindowChrome CaptionHeight="34"
                              GlassFrameThickness="0"
                              ResizeBorderThickness="{x:Static SystemParameters.WindowResizeBorderThickness}"
                              CornerRadius="0"
                              UseAeroCaptionButtons="False" />
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:RibbonOptionsDialog}">
                    <!-- AdornerDecorator so tooltips / validation adorners inside pages render. -->
                    <AdornerDecorator>
                        <!-- PART_WindowRoot: MaximizeGuard insets this by the maximize overhang so
                             a maximized dialog's content stays inside the monitor work area. -->
                        <Border x:Name="PART_WindowRoot" Background="{TemplateBinding Background}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="34" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <!-- Custom white title bar: Title on the left (no icon),
                                     Close on the right (no minimize/maximize). -->
                                <Grid Grid.Row="0" Background="Transparent">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{TemplateBinding Title}"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Margin="14,0,0,0"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource RibbonKit.Brushes.Text.Primary}" />
                                    <Button x:Name="PART_CloseButton"
                                            Grid.Column="1"
                                            WindowChrome.IsHitTestVisibleInChrome="True"
                                            Style="{StaticResource OptionsDialogCloseButtonStyle}"
                                            ToolTip="Close" />
                                </Grid>

                                <!-- Body: [rail | page] over a full-width action-button bar.
                                     The rail lives ONLY in the top row, so it ends where the
                                     content does — the button bar spans the full width below. -->
                                <Grid Grid.Row="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="190" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Page rail -->
                                        <Border Grid.Column="0"
                                                Background="{StaticResource OptionsDialog.RailBackground}"
                                                BorderBrush="{DynamicResource RibbonKit.Brushes.Ribbon.Border}"
                                                BorderThickness="0,0,1,0">
                                            <ListBox x:Name="PART_PageList"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     Margin="0,12,0,12"
                                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                     ItemsSource="{TemplateBinding Pages}"
                                                     SelectedItem="{Binding SelectedPage, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                                <ListBox.ItemContainerStyle>
                                                    <!-- The page control draws its own hover/selection;
                                                         the container contributes no chrome. -->
                                                    <Style TargetType="{x:Type ListBoxItem}">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                                                    <ContentPresenter />
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </ListBox.ItemContainerStyle>
                                            </ListBox>
                                        </Border>

                                        <!-- Selected page: heading + content. The content sits
                                             in a ScrollViewer so TALL user pages scroll (a
                                             convenience — the app needn't wrap its own content).
                                             The built-in RibbonQuickAccessPage opts OUT by
                                             capping its height to the viewport (see its style),
                                             so its own ListBoxes scroll and the dialog does not. -->
                                        <Grid Grid.Column="1">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0"
                                                       Text="{Binding SelectedPage.Header, RelativeSource={RelativeSource TemplatedParent}}"
                                                       FontSize="20"
                                                       FontWeight="SemiBold"
                                                       Foreground="{TemplateBinding Foreground}"
                                                       Margin="24,14,24,10" />
                                            <!-- VerticalScrollBarVisibility is set in code per
                                                 page: Disabled for an IRibbonFillPage (constrains
                                                 the content so it FILLS the viewport and scrolls
                                                 its own inner regions), Auto otherwise (tall app
                                                 pages scroll in the dialog). -->
                                            <ScrollViewer x:Name="PART_ContentScroll"
                                                          Grid.Row="1"
                                                          VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Disabled"
                                                          Focusable="False"
                                                          Padding="24,0,24,14">
                                                <ContentPresenter Content="{Binding SelectedPage.Content, RelativeSource={RelativeSource TemplatedParent}}" />
                                            </ScrollViewer>
                                        </Grid>
                                    </Grid>

                                    <!-- Action buttons: full width, below the rail + content. -->
                                    <Border Grid.Row="1"
                                            BorderBrush="{DynamicResource RibbonKit.Brushes.Ribbon.Border}"
                                            BorderThickness="0,1,0,0">
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Right"
                                                    Margin="16,12,16,12">
                                            <Button x:Name="PART_OkButton"
                                                    Content="OK"
                                                    IsDefault="True"
                                                    Style="{StaticResource OptionsDialogPrimaryButtonStyle}" />
                                            <Button x:Name="PART_CancelButton"
                                                    Content="Cancel"
                                                    IsCancel="True"
                                                    Margin="8,0,0,0"
                                                    Style="{StaticResource OptionsDialogActionButtonStyle}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>
                    </AdornerDecorator>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         RibbonQuickAccessPage — the built-in QAT customization page:
         available ribbon commands | Add/Remove/Up/Down | current QAT
         ============================================================ -->
    <Style TargetType="{x:Type controls:RibbonQuickAccessPage}">
        <Setter Property="Foreground" Value="{DynamicResource RibbonKit.Brushes.Text.Primary}" />
        <!-- The page fills the content area because it is an IRibbonFillPage: the dialog hosts
             it in a ScrollViewer with vertical scroll DISABLED, which constrains it to the
             viewport height (a Stretch Control then fills). No explicit Height/MaxHeight needed —
             its own two ListBoxes scroll internally. -->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:RibbonQuickAccessPage}">
                    <ControlTemplate.Resources>
                        <!-- Shared 16px-icon + caption row for both lists -->
                        <DataTemplate x:Key="CommandEntryTemplate">
                            <StackPanel Orientation="Horizontal" Margin="2,1">
                                <Image Source="{Binding Icon}"
                                       Width="16" Height="16"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                                <TextBlock Text="{Binding DisplayName}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </DataTemplate>
                    </ControlTemplate.Resources>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Column="0" Grid.Row="0"
                                   Text="Choose commands from the ribbon:"
                                   Foreground="{DynamicResource RibbonKit.Brushes.Text.Secondary}"
                                   FontSize="12"
                                   Margin="0,0,0,6" />
                        <TextBlock Grid.Column="2" Grid.Row="0"
                                   Text="Current Quick Access Toolbar:"
                                   Foreground="{DynamicResource RibbonKit.Brushes.Text.Secondary}"
                                   FontSize="12"
                                   Margin="0,0,0,6" />

                        <ListBox x:Name="PART_AvailableList"
                                 Grid.Column="0" Grid.Row="1"
                                 Background="{DynamicResource RibbonKit.Brushes.Ribbon.ContentBackground}"
                                 BorderBrush="{DynamicResource RibbonKit.Brushes.ScreenTip.Border}"
                                 BorderThickness="1"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ItemTemplate="{StaticResource CommandEntryTemplate}" />

                        <!-- Add / Remove between the two lists (like the Customize Ribbon page). -->
                        <StackPanel Grid.Column="1" Grid.Row="1"
                                    VerticalAlignment="Center"
                                    Margin="12,0">
                            <Button x:Name="PART_AddButton"
                                    Content="Add »"
                                    Style="{StaticResource OptionsDialogActionButtonStyle}"
                                    Margin="0,0,0,6" />
                            <Button x:Name="PART_RemoveButton"
                                    Content="« Remove"
                                    Style="{StaticResource OptionsDialogActionButtonStyle}" />
                        </StackPanel>

                        <ListBox x:Name="PART_CurrentList"
                                 Grid.Column="2" Grid.Row="1"
                                 Background="{DynamicResource RibbonKit.Brushes.Ribbon.ContentBackground}"
                                 BorderBrush="{DynamicResource RibbonKit.Brushes.ScreenTip.Border}"
                                 BorderThickness="1"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ItemTemplate="{StaticResource CommandEntryTemplate}" />

                        <!-- Up / Down to the RIGHT of the current list, mirroring the ribbon
                             page — icon-only reorder buttons. -->
                        <StackPanel Grid.Column="3" Grid.Row="1"
                                    VerticalAlignment="Center"
                                    Margin="12,0,0,0">
                            <Button x:Name="PART_UpButton"
                                    Content="▲"
                                    Style="{StaticResource OptionsDialogReorderButtonStyle}"
                                    ToolTip="Move Up"
                                    Margin="0,0,0,6" />
                            <Button x:Name="PART_DownButton"
                                    Content="▼"
                                    Style="{StaticResource OptionsDialogReorderButtonStyle}"
                                    ToolTip="Move Down" />
                        </StackPanel>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         RibbonCustomizePage — the built-in "Customize the Ribbon"
         page: available commands | Add/Remove | structure tree (tabs
         → groups → commands, checkbox = tab visibility) | Up/Down,
         with New Tab / New Group / Rename below the tree
         ============================================================ -->
    <Style TargetType="{x:Type controls:RibbonCustomizePage}">
        <Setter Property="Foreground" Value="{DynamicResource RibbonKit.Brushes.Text.Primary}" />
        <Setter Property="MinHeight" Value="240" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:RibbonCustomizePage}">
                    <ControlTemplate.Resources>
                        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

                        <!-- Left list rows: 16px icon + "Tab › Group › Command" caption -->
                        <DataTemplate x:Key="CustomizeCommandEntryTemplate">
                            <StackPanel Orientation="Horizontal" Margin="2,1">
                                <Image Source="{Binding Icon}"
                                       Width="16" Height="16"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                                <TextBlock Text="{Binding DisplayName}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </DataTemplate>

                        <!-- Tree rows: visibility checkbox (tabs only) + optional icon + caption -->
                        <HierarchicalDataTemplate DataType="{x:Type controls:RibbonCustomizeNode}"
                                                  ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal" Margin="0,1">
                                <CheckBox IsChecked="{Binding IsVisibleChecked, Mode=TwoWay}"
                                          Visibility="{Binding ShowCheckBox, Converter={StaticResource BoolToVisibility}}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,6,0"
                                          Focusable="False" />
                                <Image Source="{Binding Icon}"
                                       Width="16" Height="16"
                                       Margin="0,0,6,0"
                                       VerticalAlignment="Center">
                                    <Image.Style>
                                        <Style TargetType="{x:Type Image}">
                                            <Style.Triggers>
                                                <!-- No icon → no reserved gap (tab captions
                                                     would indent for nothing). -->
                                                <DataTrigger Binding="{Binding Icon}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <TextBlock Text="{Binding Header}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </ControlTemplate.Resources>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Column="0" Grid.Row="0"
                                   Text="Choose commands from the ribbon:"
                                   Foreground="{DynamicResource RibbonKit.Brushes.Text.Secondary}"
                                   FontSize="12"
                                   Margin="0,0,0,6" />
                        <TextBlock Grid.Column="2" Grid.Row="0"
                                   Text="Customize the ribbon:"
                                   Foreground="{DynamicResource RibbonKit.Brushes.Text.Secondary}"
                                   FontSize="12"
                                   Margin="0,0,0,6" />

                        <ListBox x:Name="PART_AvailableList"
                                 Grid.Column="0" Grid.Row="1"
                                 Background="{DynamicResource RibbonKit.Brushes.Ribbon.ContentBackground}"
                                 BorderBrush="{DynamicResource RibbonKit.Brushes.ScreenTip.Border}"
                                 BorderThickness="1"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ItemTemplate="{StaticResource CustomizeCommandEntryTemplate}" />

                        <StackPanel Grid.Column="1" Grid.Row="1"
                                    VerticalAlignment="Center"
                                    Margin="12,0">
                            <Button x:Name="PART_AddButton"
                                    Content="Add »"
                                    Style="{StaticResource OptionsDialogActionButtonStyle}"
                                    Margin="0,0,0,6" />
                            <Button x:Name="PART_RemoveButton"
                                    Content="« Remove"
                                    Style="{StaticResource OptionsDialogActionButtonStyle}" />
                        </StackPanel>

                        <TreeView x:Name="PART_Tree"
                                  Grid.Column="2" Grid.Row="1"
                                  Background="{DynamicResource RibbonKit.Brushes.Ribbon.ContentBackground}"
                                  BorderBrush="{DynamicResource RibbonKit.Brushes.ScreenTip.Border}"
                                  BorderThickness="1"
                                  Padding="2"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <TreeView.ItemContainerStyle>
                                <!-- Mirror tree state into the node view-model so the page can
                                     re-select/re-expand programmatically after each rebuild. -->
                                <Style TargetType="{x:Type TreeViewItem}">
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                                </Style>
                            </TreeView.ItemContainerStyle>
                        </TreeView>

                        <StackPanel Grid.Column="3" Grid.Row="1"
                                    VerticalAlignment="Center"
                                    Margin="12,0,0,0">
                            <Button x:Name="PART_UpButton"
                                    Content="▲"
                                    Style="{StaticResource OptionsDialogReorderButtonStyle}"
                                    ToolTip="Move Up"
                                    Margin="0,0,0,6" />
                            <Button x:Name="PART_DownButton"
                                    Content="▼"
                                    Style="{StaticResource OptionsDialogReorderButtonStyle}"
                                    ToolTip="Move Down" />
                        </StackPanel>

                        <!-- Reset restores the host-supplied baseline (factory ribbon),
                             discarding all customizations. Bottom-left, like Office. -->
                        <Button x:Name="PART_ResetButton"
                                Grid.Column="0" Grid.Row="2"
                                HorizontalAlignment="Left"
                                Content="Reset"
                                Style="{StaticResource OptionsDialogActionButtonStyle}"
                                Margin="0,8,0,0" />

                        <!-- Structure tools, under the tree like Office. Edit… opens the
                             per-target dialog (name / icon / layout / size). -->
                        <Grid Grid.Column="2" Grid.ColumnSpan="2" Grid.Row="2" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="PART_NewTabButton"
                                    Grid.Column="0"
                                    Content="New Tab"
                                    Style="{StaticResource OptionsDialogActionButtonStyle}"
                                    Margin="0,0,6,0" />
                            <Button x:Name="PART_NewGroupButton"
                                    Grid.Column="1"
                                    Content="New Group"
                                    Style="{StaticResource OptionsDialogActionButtonStyle}" />
                            <Button x:Name="PART_EditButton"
                                    Grid.Column="3"
                                    Content="Edit…"
                                    Style="{StaticResource OptionsDialogActionButtonStyle}" />
                        </Grid>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         RibbonCustomizeEditDialog — the small per-target edit modal
         opened by the customize page's Edit… button: name (always),
         icon + layout (custom groups), size (custom-group commands).
         Same chrome recipe as the options dialog (custom white title
         bar, close-only, DWM rounded corners from code).
         ============================================================ -->
    <Style TargetType="{x:Type controls:RibbonCustomizeEditDialog}">
        <Setter Property="Background" Value="{DynamicResource RibbonKit.Brushes.Ribbon.ContentBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource RibbonKit.Brushes.Text.Primary}" />
        <Setter Property="WindowChrome.WindowChrome">
            <Setter.Value>
                <WindowChrome CaptionHeight="34"
                              GlassFrameThickness="0"
                              ResizeBorderThickness="0"
                              CornerRadius="0"
                              UseAeroCaptionButtons="False" />
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:RibbonCustomizeEditDialog}">
                    <ControlTemplate.Resources>
                        <Style x:Key="EditDialogLabelStyle" TargetType="{x:Type TextBlock}">
                            <Setter Property="FontSize" Value="12" />
                            <Setter Property="Foreground" Value="{DynamicResource RibbonKit.Brushes.Text.Secondary}" />
                            <Setter Property="Margin" Value="0,0,0,4" />
                        </Style>
                    </ControlTemplate.Resources>
                    <AdornerDecorator>
                        <Border Background="{TemplateBinding Background}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="34" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Title bar: Title left (no icon), Close only -->
                                <Grid Grid.Row="0" Background="Transparent">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{TemplateBinding Title}"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Margin="14,0,0,0"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource RibbonKit.Brushes.Text.Primary}" />
                                    <Button x:Name="PART_CloseButton"
                                            Grid.Column="1"
                                            WindowChrome.IsHitTestVisibleInChrome="True"
                                            Style="{StaticResource OptionsDialogCloseButtonStyle}"
                                            ToolTip="Close" />
                                </Grid>

                                <!-- Sections; the control collapses the ones that don't
                                     apply to the current target. -->
                                <StackPanel Grid.Row="1" Margin="16,8,16,4">
                                    <TextBlock Text="Name:" Style="{StaticResource EditDialogLabelStyle}" />
                                    <TextBox x:Name="PART_NameBox"
                                             VerticalContentAlignment="Center"
                                             Padding="6,5"
                                             Background="{DynamicResource RibbonKit.Brushes.Ribbon.ContentBackground}"
                                             BorderBrush="{DynamicResource RibbonKit.Brushes.ScreenTip.Border}"
                                             Foreground="{DynamicResource RibbonKit.Brushes.Text.Primary}"
                                             Margin="0,0,0,12" />

                                    <StackPanel x:Name="PART_IconSection" Margin="0,0,0,12">
                                        <TextBlock Text="Icon (from this ribbon's commands):"
                                                   Style="{StaticResource EditDialogLabelStyle}" />
                                        <ListBox x:Name="PART_IconList"
                                                 MaxHeight="150"
                                                 Background="{DynamicResource RibbonKit.Brushes.Ribbon.ContentBackground}"
                                                 BorderBrush="{DynamicResource RibbonKit.Brushes.ScreenTip.Border}"
                                                 BorderThickness="1"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                            <ListBox.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ListBox.ItemsPanel>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Width="36" Height="36">
                                                        <Image Source="{Binding Icon}"
                                                               Width="20" Height="20"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                        <TextBlock Text="None"
                                                                   FontSize="10"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource RibbonKit.Brushes.Text.Secondary}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="{x:Type TextBlock}">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsNone}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>

                                    <StackPanel x:Name="PART_LayoutSection" Margin="0,0,0,12">
                                        <TextBlock Text="Group layout:" Style="{StaticResource EditDialogLabelStyle}" />
                                        <ComboBox x:Name="PART_LayoutBox" />
                                    </StackPanel>

                                    <StackPanel x:Name="PART_SizeSection" Margin="0,0,0,12">
                                        <TextBlock Text="Button size:" Style="{StaticResource EditDialogLabelStyle}" />
                                        <ComboBox x:Name="PART_SizeBox" />
                                    </StackPanel>
                                </StackPanel>

                                <!-- Action buttons -->
                                <Border Grid.Row="2"
                                        BorderBrush="{DynamicResource RibbonKit.Brushes.Ribbon.Border}"
                                        BorderThickness="0,1,0,0">
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                Margin="16,10,16,10">
                                        <Button x:Name="PART_OkButton"
                                                Content="OK"
                                                IsDefault="True"
                                                Style="{StaticResource OptionsDialogPrimaryButtonStyle}" />
                                        <Button x:Name="PART_CancelButton"
                                                Content="Cancel"
                                                IsCancel="True"
                                                Margin="8,0,0,0"
                                                Style="{StaticResource OptionsDialogActionButtonStyle}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </AdornerDecorator>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
