<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:RibbonKit.Controls"
    xmlns:layout="clr-namespace:RibbonKit.Layout">

    <!-- ============================================================
         Shared control templates. Colors and metrics come from the
         token layer via {DynamicResource}: a theme (Themes/Tokens.*.xaml)
         supplies those tokens in Application.Resources, so switching the
         token dictionary re-colors every control at runtime WITHOUT
         duplicating a single template. Merge a token dictionary in
         App.xaml (default: Themes/Tokens.Office2024.xaml).
         ============================================================ -->

    <!-- ============================================================
         Ribbon
         ============================================================ -->
    <Style TargetType="{x:Type controls:Ribbon}">
        <Setter Property="Background" Value="{DynamicResource RibbonKit.Brushes.Ribbon.Background}" />
        <Setter Property="Foreground" Value="{DynamicResource RibbonKit.Brushes.Text.Primary}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:Ribbon}">
                    <!-- The backstage overlay is hosted in the window's adorner layer
                         by the Ribbon class itself (see BackstageAdorner), not here. -->
                    <Border Background="{TemplateBinding Background}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <controls:RibbonTabControl
                                Grid.Row="0"
                                ItemsSource="{TemplateBinding Tabs}"
                                SelectedItem="{Binding SelectedTab, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}" />
                            <!-- Quick access row shown when QuickAccessPosition=BelowRibbon.
                                 Styled as an extender chip that tucks under the ribbon
                                 card (Office 2024); flat themes render a plain strip. -->
                            <Border x:Name="QatBelowHost"
                                    Grid.Row="1"
                                    HorizontalAlignment="Stretch"
                                    Margin="{DynamicResource RibbonKit.Metrics.QatExtenderMargin}"
                                    Padding="8,2"
                                    Background="{DynamicResource RibbonKit.Brushes.Ribbon.ContentBackground}"
                                    BorderBrush="{DynamicResource RibbonKit.Brushes.Ribbon.Border}"
                                    BorderThickness="{DynamicResource RibbonKit.Metrics.QatExtenderBorderThickness}"
                                    CornerRadius="{DynamicResource RibbonKit.Metrics.QatExtenderCornerRadius}"
                                    Effect="{DynamicResource RibbonKit.Effects.ContentShadow}"
                                    Visibility="Collapsed">
                                <!-- ItemsSource bound only by the BelowRibbon trigger. -->
                                <ItemsControl x:Name="QatBelowItems"
                                              Focusable="False"
                                              Margin="4,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </Border>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="QuickAccessPosition" Value="BelowRibbon">
                            <Setter TargetName="QatBelowHost" Property="Visibility" Value="Visible" />
                            <Setter TargetName="QatBelowItems" Property="ItemsSource">
                                <Setter.Value>
                                    <Binding Path="QuickAccessItems"
                                             RelativeSource="{RelativeSource AncestorType={x:Type controls:Ribbon}}" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <!-- Minimized + QAT below: the ribbon body card is collapsed, so the
                             QAT bar is left standing alone under the tab strip. Make it a
                             self-contained floating card — round ALL corners (not just the
                             bottom), border it all the way around, and give it the small top
                             gap the card used to occupy — matching Office. It reverts to the
                             flush-connected strip automatically when the ribbon is restored.
                             Flat themes (2019/2013) point these tokens at their strip values,
                             so nothing changes shape for them. -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="QuickAccessPosition" Value="BelowRibbon" />
                                <Condition Property="IsMinimized" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="QatBelowHost" Property="CornerRadius"
                                    Value="{DynamicResource RibbonKit.Metrics.QatExtenderCornerRadiusMinimized}" />
                            <Setter TargetName="QatBelowHost" Property="BorderThickness"
                                    Value="{DynamicResource RibbonKit.Metrics.QatExtenderBorderThicknessMinimized}" />
                            <Setter TargetName="QatBelowHost" Property="Margin"
                                    Value="{DynamicResource RibbonKit.Metrics.QatExtenderMarginMinimized}" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         RibbonTabControl — tab strip on top, groups row below
         ============================================================ -->
    <Style TargetType="{x:Type controls:RibbonTabControl}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:RibbonTabControl}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <!-- Application (File) button: opens the backstage; hidden
                                 when the hosting Ribbon has no Backstage assigned -->
                            <ToggleButton x:Name="ApplicationButton"
                                          Grid.Column="0"
                                          Margin="{DynamicResource RibbonKit.Metrics.ApplicationButtonMargin}"
                                          Content="{Binding ApplicationButtonHeader, RelativeSource={RelativeSource AncestorType={x:Type controls:Ribbon}}}"
                                          IsChecked="{Binding IsBackstageOpen, RelativeSource={RelativeSource AncestorType={x:Type controls:Ribbon}}, Mode=TwoWay}">
                                <ToggleButton.Style>
                                    <Style TargetType="{x:Type ToggleButton}">
                                        <Setter Property="Foreground" Value="{DynamicResource RibbonKit.Brushes.ApplicationButton.Foreground}" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type ToggleButton}">
                                                    <!-- The File tab hovers exactly like the other tabs:
                                                         same Tab.HoverBackground + Tab.HoverUnderline tokens,
                                                         so its hover style tracks the theme automatically. -->
                                                    <Grid>
                                                        <Border x:Name="Chrome"
                                                                Background="{DynamicResource RibbonKit.Brushes.ApplicationButton.Background}"
                                                                CornerRadius="{DynamicResource RibbonKit.Metrics.TabCornerRadius}"
                                                                Padding="14,7,14,9"
                                                                SnapsToDevicePixels="True">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center" />
                                                        </Border>
                                                        <Rectangle x:Name="HoverUnderline"
                                                                   Height="2.5"
                                                                   RadiusX="1.25"
                                                                   RadiusY="1.25"
                                                                   Margin="10,0"
                                                                   VerticalAlignment="Bottom"
                                                                   Fill="{DynamicResource RibbonKit.Brushes.ApplicationButton.HoverUnderline}"
                                                                   Visibility="Collapsed" />
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Chrome" Property="Background"
                                                                    Value="{DynamicResource RibbonKit.Brushes.ApplicationButton.HoverBackground}" />
                                                            <Setter TargetName="HoverUnderline" Property="Visibility" Value="Visible" />
                                                        </Trigger>
                                                        <!-- Backstage open: File highlights in accent, like Office -->
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="Chrome" Property="Background"
                                                                    Value="{DynamicResource RibbonKit.Brushes.Accent}" />
                                                            <Setter TargetName="HoverUnderline" Property="Visibility" Value="Collapsed" />
                                                            <Setter Property="Foreground" Value="#FFFFFF" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Backstage, RelativeSource={RelativeSource AncestorType={x:Type controls:Ribbon}}}"
                                                         Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ToggleButton.Style>
                            </ToggleButton>
                            <!-- Quick access strip in the tab row (QuickAccessPosition=TabRow).
                                 ItemsSource is bound ONLY by the TabRow trigger below, never
                                 by default — the same live QAT UIElements can have only one
                                 parent, so exactly one host (tab-row or below-ribbon) may
                                 bind at a time. -->
                            <ItemsControl x:Name="QatTabRowHost"
                                          Grid.Column="1"
                                          Focusable="False"
                                          VerticalAlignment="Center"
                                          Visibility="Collapsed"
                                          Margin="2,4,4,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                            <TabPanel Grid.Column="2"
                                      IsItemsHost="True"
                                      Margin="{DynamicResource RibbonKit.Metrics.TabStripMargin}"
                                      Background="Transparent" />
                            <!-- Minimize chevron: toggles Ribbon.IsMinimized -->
                            <ToggleButton x:Name="MinimizeToggle"
                                          Grid.Column="3"
                                          Width="24" Height="22"
                                          Margin="0,6,8,0"
                                          VerticalAlignment="Center"
                                          ToolTip="Minimize the Ribbon"
                                          IsChecked="{Binding IsMinimized, RelativeSource={RelativeSource AncestorType={x:Type controls:Ribbon}}, Mode=TwoWay}">
                                <ToggleButton.Style>
                                    <Style TargetType="{x:Type ToggleButton}">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type ToggleButton}">
                                                    <Border x:Name="Chrome"
                                                            Background="Transparent"
                                                            CornerRadius="{DynamicResource RibbonKit.Metrics.ControlCornerRadius}"
                                                            SnapsToDevicePixels="True">
                                                        <Grid>
                                                            <Path x:Name="ChevronUp"
                                                                  Data="M0,3.5 L3.5,0 L7,3.5"
                                                                  Stroke="{DynamicResource RibbonKit.Brushes.TabStrip.Foreground}"
                                                                  StrokeThickness="1.5"
                                                                  StrokeStartLineCap="Round"
                                                                  StrokeEndLineCap="Round"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center" />
                                                            <Path x:Name="ChevronDown"
                                                                  Data="M0,0 L3.5,3.5 L7,0"
                                                                  Stroke="{DynamicResource RibbonKit.Brushes.TabStrip.Foreground}"
                                                                  StrokeThickness="1.5"
                                                                  StrokeStartLineCap="Round"
                                                                  StrokeEndLineCap="Round"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"
                                                                  Visibility="Collapsed" />
                                                        </Grid>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Chrome" Property="Background"
                                                                    Value="{DynamicResource RibbonKit.Brushes.TabStrip.ControlHoverBackground}" />
                                                        </Trigger>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="ChevronUp" Property="Visibility" Value="Collapsed" />
                                                            <Setter TargetName="ChevronDown" Property="Visibility" Value="Visible" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ToggleButton.Style>
                            </ToggleButton>
                        </Grid>
                        <!-- Ribbon body. Office 2024/365 renders it as a floating rounded
                             "card" (inset margin, rounded on all corners, bordered all
                             around) over the light ribbon band. Flat themes (2019/2013)
                             zero the margin and radius and use a top/bottom-only border,
                             collapsing it back to a full-width strip — all via tokens. -->
                        <Border x:Name="ContentHost"
                                Grid.Row="1"
                                Background="{DynamicResource RibbonKit.Brushes.Ribbon.ContentBackground}"
                                BorderBrush="{DynamicResource RibbonKit.Brushes.Ribbon.Border}"
                                BorderThickness="{DynamicResource RibbonKit.Metrics.ContentBorderThickness}"
                                CornerRadius="{DynamicResource RibbonKit.Metrics.ContentCornerRadius}"
                                Margin="{DynamicResource RibbonKit.Metrics.ContentMargin}"
                                Effect="{DynamicResource RibbonKit.Effects.ContentShadow}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter ContentSource="SelectedContent" Margin="6,2" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- The ribbon body's Visibility while minimized is managed in code
                             (Ribbon.OnIsMinimizedChanged) so it can slide up + fade out before
                             collapsing, and slide back in on restore. -->
                        <DataTrigger Binding="{Binding QuickAccessPosition, RelativeSource={RelativeSource AncestorType={x:Type controls:Ribbon}}}"
                                     Value="TabRow">
                            <Setter TargetName="QatTabRowHost" Property="Visibility" Value="Visible" />
                            <Setter TargetName="QatTabRowHost" Property="ItemsSource">
                                <Setter.Value>
                                    <Binding Path="QuickAccessItems"
                                             RelativeSource="{RelativeSource AncestorType={x:Type controls:Ribbon}}" />
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                        <!-- When the QAT sits below the ribbon, the card squares its bottom
                             corners and drops its bottom margin so the full-width QAT bar
                             connects flush underneath. -->
                        <DataTrigger Binding="{Binding QuickAccessPosition, RelativeSource={RelativeSource AncestorType={x:Type controls:Ribbon}}}"
                                     Value="BelowRibbon">
                            <Setter TargetName="ContentHost" Property="CornerRadius"
                                    Value="{DynamicResource RibbonKit.Metrics.ContentCornerRadiusTop}" />
                            <Setter TargetName="ContentHost" Property="Margin"
                                    Value="{DynamicResource RibbonKit.Metrics.ContentMarginQatBelow}" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         RibbonTab — header in the strip; selected tab gets the
         Office 2024 accent underline
         ============================================================ -->
    <Style TargetType="{x:Type controls:RibbonTab}">
        <Setter Property="Foreground" Value="{DynamicResource RibbonKit.Brushes.TabStrip.Foreground}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:RibbonTab}">
                    <Grid>
                        <Border x:Name="HeaderChrome"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                CornerRadius="{DynamicResource RibbonKit.Metrics.TabCornerRadius}"
                                Padding="12,7,12,9">
                            <Grid>
                                <!-- Normal header text: theme foreground (and selected
                                     foreground while selected). -->
                                <ContentPresenter x:Name="HeaderText"
                                                  ContentSource="Header"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                                <!-- Contextual header text: tinted by the tab's ContextualBrush,
                                     muted until selected. Only shown for contextual tabs. -->
                                <ContentPresenter x:Name="ContextualHeaderText"
                                                  ContentSource="Header"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"
                                                  TextElement.Foreground="{TemplateBinding ContextualBrush}"
                                                  Opacity="{DynamicResource RibbonKit.Metrics.ContextualUnselectedOpacity}"
                                                  Visibility="Collapsed" />
                            </Grid>
                        </Border>
                        <!-- The template carries BOTH an underline and a fill for hover and
                             for selection; a theme picks its style by making the unwanted
                             token Transparent (2024 = underlines; 2019 = fills/pills). -->
                        <Rectangle x:Name="HoverIndicator"
                                   Height="2.5"
                                   RadiusX="1.25"
                                   RadiusY="1.25"
                                   Margin="10,0"
                                   VerticalAlignment="Bottom"
                                   Fill="{DynamicResource RibbonKit.Brushes.Tab.HoverUnderline}"
                                   Visibility="Collapsed" />
                        <Rectangle x:Name="SelectionIndicator"
                                   Height="3"
                                   RadiusX="1.5"
                                   RadiusY="1.5"
                                   Margin="10,0"
                                   VerticalAlignment="Bottom"
                                   Fill="{DynamicResource RibbonKit.Brushes.Tab.SelectedUnderline}"
                                   Visibility="Collapsed" />
                        <!-- Selected contextual tab's underline, tinted the same as its
                             header text. Height is a theme token (2024 = 3, flat themes = 0)
                             so only underline themes show it. -->
                        <Rectangle x:Name="ContextualSelectionIndicator"
                                   Height="{DynamicResource RibbonKit.Metrics.ContextualUnderlineHeight}"
                                   RadiusX="1.5"
                                   RadiusY="1.5"
                                   Margin="10,0"
                                   VerticalAlignment="Bottom"
                                   Fill="{TemplateBinding ContextualBrush}"
                                   Visibility="Collapsed" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- Contextual tabs render their header via the tinted presenter. -->
                        <Trigger Property="IsContextual" Value="True">
                            <Setter TargetName="HeaderText" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="ContextualHeaderText" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <!-- Hover shows the fill AND the underline; each theme zeroes the
                             one it doesn't use. SourceName scoping matters — TabItem.IsMouseOver
                             is also true over the tab CONTENT, which would flicker the header. -->
                        <Trigger SourceName="HeaderChrome" Property="IsMouseOver" Value="True">
                            <Setter TargetName="HeaderChrome" Property="Background"
                                    Value="{DynamicResource RibbonKit.Brushes.Tab.HoverBackground}" />
                            <Setter TargetName="HoverIndicator" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="HeaderChrome" Property="Background"
                                    Value="{DynamicResource RibbonKit.Brushes.Tab.SelectedBackground}" />
                            <!-- Office 2013/Metro: the active tab is outlined on top and
                                 sides (no bottom) so it connects into the ribbon body.
                                 Other themes keep this Transparent / zero-thickness. -->
                            <Setter TargetName="HeaderChrome" Property="BorderBrush"
                                    Value="{DynamicResource RibbonKit.Brushes.Tab.SelectedBorderBrush}" />
                            <Setter TargetName="HeaderChrome" Property="BorderThickness"
                                    Value="{DynamicResource RibbonKit.Metrics.TabSelectedBorderThickness}" />
                            <Setter TargetName="SelectionIndicator" Property="Visibility" Value="Visible" />
                            <Setter TargetName="HoverIndicator" Property="Visibility" Value="Collapsed" />
                            <Setter Property="Foreground"
                                    Value="{DynamicResource RibbonKit.Brushes.Tab.SelectedForeground}" />
                        </Trigger>
                        <!-- Selected contextual tab: full-strength tint, tinted underline,
                             and the normal accent underline hidden in its favor. -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsContextual" Value="True" />
                                <Condition Property="IsSelected" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="ContextualHeaderText" Property="Opacity" Value="1" />
                            <Setter TargetName="SelectionIndicator" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="ContextualSelectionIndicator" Property="Visibility" Value="Visible" />
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         RibbonGroupsHost — hosts groups on the adaptive panel
         ============================================================ -->
    <Style TargetType="{x:Type controls:RibbonGroupsHost}">
        <Setter Property="Focusable" Value="False" />
        <!-- StaticResource: resolved at parse time from this dictionary, so the fixed
             row height can never fail to apply. ClipToBounds stops any over-tall group
             content from painting over the document area. -->
        <Setter Property="Height" Value="{DynamicResource RibbonKit.Metrics.GroupsRowHeight}" />
        <Setter Property="ClipToBounds" Value="True" />
        <Setter Property="KeyboardNavigation.DirectionalNavigation" Value="Continue" />
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <layout:RibbonGroupsPanel />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:RibbonGroupsHost}">
                    <ItemsPresenter />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         RibbonGroup — items row + group name; collapses to a single
         flyout button (Office 2024 behavior) when width runs out
         ============================================================ -->
    <Style TargetType="{x:Type controls:RibbonGroup}">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="KeyboardNavigation.DirectionalNavigation" Value="Continue" />
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:RibbonGroup}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Normal (expanded) content. The inner grid is re-homed into
                             the flyout by RibbonGroup while the popup is open. -->
                        <Decorator x:Name="PART_NormalHost" Grid.Column="0">
                            <Grid Margin="4,2,4,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ItemsPresenter Grid.Row="0" VerticalAlignment="Center" />
                                <Grid Grid.Row="1" Margin="2,3,2,4">
                                    <ContentPresenter ContentSource="Header"
                                                      HorizontalAlignment="Center"
                                                      TextElement.FontSize="11"
                                                      TextElement.Foreground="{DynamicResource RibbonKit.Brushes.Text.Secondary}" />
                                    <!-- ↘ dialog launcher, shown via ShowDialogLauncher -->
                                    <Button x:Name="PART_DialogLauncher"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Width="18" Height="14"
                                            Visibility="Collapsed"
                                            ToolTip="More options"
                                            Command="{TemplateBinding DialogLauncherCommand}">
                                        <Button.Style>
                                            <Style TargetType="{x:Type Button}">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="{x:Type Button}">
                                                            <Border x:Name="Chrome"
                                                                    Background="Transparent"
                                                                    CornerRadius="{DynamicResource RibbonKit.Metrics.SmallControlCornerRadius}"
                                                                    SnapsToDevicePixels="True">
                                                                <Path Data="M1,1 H3.5 M1,1 V3.5 M2.5,2.5 L7,7 M7,7 V4.5 M7,7 H4.5"
                                                                      Stroke="{DynamicResource RibbonKit.Brushes.Text.Secondary}"
                                                                      StrokeThickness="1.2"
                                                                      StrokeStartLineCap="Round"
                                                                      StrokeEndLineCap="Round"
                                                                      HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center" />
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Chrome" Property="Background"
                                                                            Value="{DynamicResource RibbonKit.Brushes.Control.HoverBackground}" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </Grid>
                        </Decorator>

                        <!-- Collapsed representation: one button with icon, name, chevron.
                             The style is inlined so it can never miss a resource lookup. -->
                        <ToggleButton x:Name="PART_CollapsedButton"
                                      Grid.Column="0"
                                      Margin="1"
                                      Visibility="Collapsed">
                            <ToggleButton.Style>
                                <Style TargetType="{x:Type ToggleButton}">
                                    <Setter Property="Focusable" Value="True" />
                                    <Setter Property="Foreground"
                                            Value="{DynamicResource RibbonKit.Brushes.Text.Primary}" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type ToggleButton}">
                                                <Border x:Name="Chrome"
                                                        Background="Transparent"
                                                        CornerRadius="{DynamicResource RibbonKit.Metrics.ControlCornerRadius}"
                                                        SnapsToDevicePixels="True">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Chrome" Property="Background"
                                                                Value="{DynamicResource RibbonKit.Brushes.Control.HoverBackground}" />
                                                    </Trigger>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Chrome" Property="Background"
                                                                Value="{DynamicResource RibbonKit.Brushes.Control.PressedBackground}" />
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="Chrome" Property="Background"
                                                                Value="{DynamicResource RibbonKit.Brushes.Control.PressedBackground}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ToggleButton.Style>
                            <StackPanel Orientation="Vertical" Margin="8,4">
                                <Image Source="{TemplateBinding Icon}"
                                       Width="32" Height="32"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding Header, RelativeSource={RelativeSource TemplatedParent}}"
                                           TextAlignment="Center"
                                           Margin="0,4,0,0" />
                                <Path Data="M0,0 L3.5,3.5 L7,0"
                                      Stroke="{DynamicResource RibbonKit.Brushes.Text.Secondary}"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      HorizontalAlignment="Center"
                                      Margin="0,3,0,1" />
                            </StackPanel>
                        </ToggleButton>

                        <!-- Flyout that hosts the group's full content while collapsed -->
                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               StaysOpen="True"
                               Placement="Bottom"
                               PlacementTarget="{Binding ElementName=PART_CollapsedButton}"
                               IsOpen="{Binding IsChecked, ElementName=PART_CollapsedButton, Mode=TwoWay}">
                            <!-- AdornerDecorator wraps the host so the re-homed flyout content
                                 (set as PART_PopupHost.Child at runtime) has an adorner layer
                                 for KeyTip badges. -->
                            <AdornerDecorator>
                                <Border x:Name="PART_PopupHost"
                                        Background="{DynamicResource RibbonKit.Brushes.Ribbon.ContentBackground}"
                                        BorderBrush="{DynamicResource RibbonKit.Brushes.ScreenTip.Border}"
                                        BorderThickness="1"
                                        CornerRadius="{DynamicResource RibbonKit.Metrics.PopupCornerRadius}"
                                        Padding="6,4"
                                        Margin="4,2,8,8">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.25" />
                                    </Border.Effect>
                                </Border>
                            </AdornerDecorator>
                        </Popup>

                        <Rectangle Grid.Column="1"
                                   Width="1"
                                   Margin="1,10"
                                   Fill="{DynamicResource RibbonKit.Brushes.Group.Separator}" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="SizeState" Value="Collapsed">
                            <Setter TargetName="PART_NormalHost" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="PART_CollapsedButton" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="ShowDialogLauncher" Value="True">
                            <Setter TargetName="PART_DialogLauncher" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         RibbonButton — Large / Medium / Small layouts via triggers
         ============================================================ -->
    <Style TargetType="{x:Type controls:RibbonButton}">
        <Setter Property="Foreground" Value="{DynamicResource RibbonKit.Brushes.Text.Primary}" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:RibbonButton}">
                    <Border x:Name="Chrome"
                            Background="Transparent"
                            CornerRadius="{DynamicResource RibbonKit.Metrics.ControlCornerRadius}"
                            Margin="1"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <!-- Large: 32px icon over wrapped label -->
                            <StackPanel x:Name="LargeLayout"
                                        Orientation="Vertical"
                                        Margin="6,8,6,0"
                                        VerticalAlignment="Center">
                                <Image x:Name="LargeImage"
                                       Source="{TemplateBinding LargeIcon}"
                                       Width="32" Height="32"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center" />
                                <TextBlock Text="{TemplateBinding Header}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           MaxWidth="76"
                                           MinHeight="32"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                            <!-- Medium: 16px icon + label in a row -->
                            <StackPanel x:Name="MediumLayout"
                                        Orientation="Horizontal"
                                        Margin="4,2"
                                        VerticalAlignment="Center"
                                        Visibility="Collapsed">
                                <Image Source="{TemplateBinding Icon}"
                                       Width="16" Height="16"
                                       Stretch="Uniform"
                                       VerticalAlignment="Center" />
                                <TextBlock Text="{TemplateBinding Header}"
                                           Margin="5,0,2,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <!-- Small: 16px icon only. Tight vertical margin so a stack of
                                 three small buttons plus the group caption fits the fixed
                                 groups row. Two renderings: the normal colour icon, and a
                                 flat white silhouette shown when Ribbon.QatOnColoredSurface
                                 is set (QAT on a colored title bar / strip). -->
                            <Grid x:Name="SmallLayout"
                                  Margin="5,3"
                                  VerticalAlignment="Center"
                                  Visibility="Collapsed">
                                <Image x:Name="SmallImage"
                                       Source="{TemplateBinding Icon}"
                                       Width="16" Height="16"
                                       Stretch="Uniform" />
                                <Rectangle x:Name="SmallImageTint" Width="16" Height="16"
                                           Fill="#FFFFFF"
                                           Visibility="Collapsed">
                                    <Rectangle.OpacityMask>
                                        <ImageBrush ImageSource="{Binding Icon, RelativeSource={RelativeSource TemplatedParent}}" />
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                            </Grid>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- QAT on a colored surface (accent title bar / colored strip): draw
                             the icon as a white silhouette instead of its full colour. -->
                        <Trigger Property="controls:Ribbon.QatOnColoredSurface" Value="True">
                            <Setter TargetName="SmallImage" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="SmallImageTint" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="LargeIcon" Value="{x:Null}">
                            <Setter TargetName="LargeImage" Property="Source"
                                    Value="{Binding Icon, RelativeSource={RelativeSource TemplatedParent}}" />
                        </Trigger>
                        <Trigger Property="Size" Value="Medium">
                            <Setter TargetName="LargeLayout" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="MediumLayout" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="Size" Value="Small">
                            <Setter TargetName="LargeLayout" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="SmallLayout" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background"
                                    Value="{DynamicResource RibbonKit.Brushes.Control.HoverBackground}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Chrome" Property="Background"
                                    Value="{DynamicResource RibbonKit.Brushes.Control.PressedBackground}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                        <!-- On a colored surface, hover with the surrounding band's brush
                             (caption/tab hover) instead of the neutral control hover. -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="controls:Ribbon.QatOnColoredSurface" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Chrome" Property="Background"
                                    Value="{Binding Path=(controls:Ribbon.QatHoverBackground), RelativeSource={RelativeSource TemplatedParent}}" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         RibbonScreenTip — rich tooltip
         ============================================================ -->
    <Style TargetType="{x:Type controls:RibbonScreenTip}">
        <Setter Property="Background" Value="{DynamicResource RibbonKit.Brushes.ScreenTip.Background}" />
        <Setter Property="Foreground" Value="{DynamicResource RibbonKit.Brushes.Text.Primary}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="12" />
