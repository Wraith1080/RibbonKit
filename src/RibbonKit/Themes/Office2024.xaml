<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:RibbonKit.Controls"
    xmlns:layout="clr-namespace:RibbonKit.Layout">

    <!-- ============================================================
         Token layer — Office 2024 (light).
         Templates below reference ONLY these tokens, so future themes
         (2019/2013/2010/2007) override values, not templates.
         ============================================================ -->
    <SolidColorBrush x:Key="RibbonKit.Brushes.Ribbon.Background" Color="#F3F3F3" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Ribbon.ContentBackground" Color="#F9F9F9" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Ribbon.Border" Color="#E0E0E0" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Text.Primary" Color="#1A1A1A" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Text.Secondary" Color="#616161" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Accent" Color="#0F6CBD" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Control.HoverBackground" Color="#E6E6E6" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Control.PressedBackground" Color="#DADADA" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Control.CheckedBackground" Color="#CDE0F3" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Control.CheckedHoverBackground" Color="#BDD5EC" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Tab.HoverBackground" Color="#EAEAEA" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Group.Separator" Color="#E0E0E0" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.ScreenTip.Background" Color="#FFFFFF" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.ScreenTip.Border" Color="#D1D1D1" />

    <system:Double xmlns:system="clr-namespace:System;assembly=System.Runtime"
                   x:Key="RibbonKit.Metrics.GroupsRowHeight">96</system:Double>

    <!-- ============================================================
         Ribbon
         ============================================================ -->
    <Style TargetType="{x:Type controls:Ribbon}">
        <Setter Property="Background" Value="{StaticResource RibbonKit.Brushes.Ribbon.Background}" />
        <Setter Property="Foreground" Value="{StaticResource RibbonKit.Brushes.Text.Primary}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:Ribbon}">
                    <Border Background="{TemplateBinding Background}">
                        <controls:RibbonTabControl
                            ItemsSource="{TemplateBinding Tabs}"
                            SelectedItem="{Binding SelectedTab, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         RibbonTabControl — tab strip on top, groups row below
         ============================================================ -->
    <Style TargetType="{x:Type controls:RibbonTabControl}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:RibbonTabControl}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TabPanel Grid.Column="0"
                                      IsItemsHost="True"
                                      Margin="8,4,4,0"
                                      Background="Transparent" />
                            <!-- Minimize chevron: toggles Ribbon.IsMinimized -->
                            <ToggleButton x:Name="MinimizeToggle"
                                          Grid.Column="1"
                                          Width="24" Height="22"
                                          Margin="0,6,8,0"
                                          VerticalAlignment="Center"
                                          ToolTip="Minimize the Ribbon"
                                          IsChecked="{Binding IsMinimized, RelativeSource={RelativeSource AncestorType={x:Type controls:Ribbon}}, Mode=TwoWay}">
                                <ToggleButton.Style>
                                    <Style TargetType="{x:Type ToggleButton}">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type ToggleButton}">
                                                    <Border x:Name="Chrome"
                                                            Background="Transparent"
                                                            CornerRadius="4"
                                                            SnapsToDevicePixels="True">
                                                        <Grid>
                                                            <Path x:Name="ChevronUp"
                                                                  Data="M0,3.5 L3.5,0 L7,3.5"
                                                                  Stroke="{StaticResource RibbonKit.Brushes.Text.Secondary}"
                                                                  StrokeThickness="1.5"
                                                                  StrokeStartLineCap="Round"
                                                                  StrokeEndLineCap="Round"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center" />
                                                            <Path x:Name="ChevronDown"
                                                                  Data="M0,0 L3.5,3.5 L7,0"
                                                                  Stroke="{StaticResource RibbonKit.Brushes.Text.Secondary}"
                                                                  StrokeThickness="1.5"
                                                                  StrokeStartLineCap="Round"
                                                                  StrokeEndLineCap="Round"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"
                                                                  Visibility="Collapsed" />
                                                        </Grid>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Chrome" Property="Background"
                                                                    Value="{StaticResource RibbonKit.Brushes.Control.HoverBackground}" />
                                                        </Trigger>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="ChevronUp" Property="Visibility" Value="Collapsed" />
                                                            <Setter TargetName="ChevronDown" Property="Visibility" Value="Visible" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ToggleButton.Style>
                            </ToggleButton>
                        </Grid>
                        <Border x:Name="ContentHost"
                                Grid.Row="1"
                                Background="{StaticResource RibbonKit.Brushes.Ribbon.ContentBackground}"
                                BorderBrush="{StaticResource RibbonKit.Brushes.Ribbon.Border}"
                                BorderThickness="0,1,0,1">
                            <ContentPresenter ContentSource="SelectedContent" Margin="6,2" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsMinimized, RelativeSource={RelativeSource AncestorType={x:Type controls:Ribbon}}}"
                                     Value="True">
                            <Setter TargetName="ContentHost" Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         RibbonTab — header in the strip; selected tab gets the
         Office 2024 accent underline
         ============================================================ -->
    <Style TargetType="{x:Type controls:RibbonTab}">
        <Setter Property="Foreground" Value="{StaticResource RibbonKit.Brushes.Text.Primary}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:RibbonTab}">
                    <Grid>
                        <Border x:Name="HeaderChrome"
                                Background="Transparent"
                                CornerRadius="4,4,0,0"
                                Padding="12,7,12,9">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <Rectangle x:Name="SelectionIndicator"
                                   Height="3"
                                   RadiusX="1.5"
                                   RadiusY="1.5"
                                   Margin="10,0"
                                   VerticalAlignment="Bottom"
                                   Fill="{StaticResource RibbonKit.Brushes.Accent}"
                                   Visibility="Collapsed" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- SourceName scoping matters: TabItem.IsMouseOver is also true while
                             the mouse is over the tab's CONTENT (IsMouseOver propagates up the
                             logical tree), which made the header flicker while hovering ribbon
                             buttons. Only the header chrome itself should trigger hover. -->
                        <Trigger SourceName="HeaderChrome" Property="IsMouseOver" Value="True">
                            <Setter TargetName="HeaderChrome" Property="Background"
                                    Value="{StaticResource RibbonKit.Brushes.Tab.HoverBackground}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="SelectionIndicator" Property="Visibility" Value="Visible" />
                            <Setter Property="Foreground"
                                    Value="{StaticResource RibbonKit.Brushes.Accent}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         RibbonGroupsHost — hosts groups on the adaptive panel
         ============================================================ -->
    <Style TargetType="{x:Type controls:RibbonGroupsHost}">
        <Setter Property="Focusable" Value="False" />
        <!-- StaticResource: resolved at parse time from this dictionary, so the fixed
             row height can never fail to apply. ClipToBounds stops any over-tall group
             content from painting over the document area. -->
        <Setter Property="Height" Value="{StaticResource RibbonKit.Metrics.GroupsRowHeight}" />
        <Setter Property="ClipToBounds" Value="True" />
        <Setter Property="KeyboardNavigation.DirectionalNavigation" Value="Continue" />
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <layout:RibbonGroupsPanel />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:RibbonGroupsHost}">
                    <ItemsPresenter />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         RibbonGroup — items row + group name; collapses to a single
         flyout button (Office 2024 behavior) when width runs out
         ============================================================ -->
    <Style TargetType="{x:Type controls:RibbonGroup}">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="KeyboardNavigation.DirectionalNavigation" Value="Continue" />
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:RibbonGroup}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Normal (expanded) content. The inner grid is re-homed into
                             the flyout by RibbonGroup while the popup is open. -->
                        <Decorator x:Name="PART_NormalHost" Grid.Column="0">
                            <Grid Margin="4,2,4,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ItemsPresenter Grid.Row="0" VerticalAlignment="Center" />
                                <Grid Grid.Row="1" Margin="2,3,2,4">
                                    <ContentPresenter ContentSource="Header"
                                                      HorizontalAlignment="Center"
                                                      TextElement.FontSize="11"
                                                      TextElement.Foreground="{StaticResource RibbonKit.Brushes.Text.Secondary}" />
                                    <!-- ↘ dialog launcher, shown via ShowDialogLauncher -->
                                    <Button x:Name="PART_DialogLauncher"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Width="18" Height="14"
                                            Visibility="Collapsed"
                                            ToolTip="More options"
                                            Command="{TemplateBinding DialogLauncherCommand}">
                                        <Button.Style>
                                            <Style TargetType="{x:Type Button}">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="{x:Type Button}">
                                                            <Border x:Name="Chrome"
                                                                    Background="Transparent"
                                                                    CornerRadius="2"
                                                                    SnapsToDevicePixels="True">
                                                                <Path Data="M1,1 H3.5 M1,1 V3.5 M2.5,2.5 L7,7 M7,7 V4.5 M7,7 H4.5"
                                                                      Stroke="{StaticResource RibbonKit.Brushes.Text.Secondary}"
                                                                      StrokeThickness="1.2"
                                                                      StrokeStartLineCap="Round"
                                                                      StrokeEndLineCap="Round"
                                                                      HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center" />
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Chrome" Property="Background"
                                                                            Value="{StaticResource RibbonKit.Brushes.Control.HoverBackground}" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </Grid>
                        </Decorator>

                        <!-- Collapsed representation: one button with icon, name, chevron.
                             The style is inlined so it can never miss a resource lookup. -->
                        <ToggleButton x:Name="PART_CollapsedButton"
                                      Grid.Column="0"
                                      Margin="1"
                                      Visibility="Collapsed">
                            <ToggleButton.Style>
                                <Style TargetType="{x:Type ToggleButton}">
                                    <Setter Property="Focusable" Value="True" />
                                    <Setter Property="Foreground"
                                            Value="{StaticResource RibbonKit.Brushes.Text.Primary}" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type ToggleButton}">
                                                <Border x:Name="Chrome"
                                                        Background="Transparent"
                                                        CornerRadius="4"
                                                        SnapsToDevicePixels="True">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Chrome" Property="Background"
                                                                Value="{StaticResource RibbonKit.Brushes.Control.HoverBackground}" />
                                                    </Trigger>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Chrome" Property="Background"
                                                                Value="{StaticResource RibbonKit.Brushes.Control.PressedBackground}" />
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="Chrome" Property="Background"
                                                                Value="{StaticResource RibbonKit.Brushes.Control.PressedBackground}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ToggleButton.Style>
                            <StackPanel Orientation="Vertical" Margin="8,4">
                                <Image Source="{TemplateBinding Icon}"
                                       Width="32" Height="32"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding Header, RelativeSource={RelativeSource TemplatedParent}}"
                                           TextAlignment="Center"
                                           Margin="0,4,0,0" />
                                <Path Data="M0,0 L3.5,3.5 L7,0"
                                      Stroke="{StaticResource RibbonKit.Brushes.Text.Secondary}"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      HorizontalAlignment="Center"
                                      Margin="0,3,0,1" />
                            </StackPanel>
                        </ToggleButton>

                        <!-- Flyout that hosts the group's full content while collapsed -->
                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               StaysOpen="True"
                               Placement="Bottom"
                               PlacementTarget="{Binding ElementName=PART_CollapsedButton}"
                               IsOpen="{Binding IsChecked, ElementName=PART_CollapsedButton, Mode=TwoWay}">
                            <Border x:Name="PART_PopupHost"
                                    Background="{StaticResource RibbonKit.Brushes.Ribbon.ContentBackground}"
                                    BorderBrush="{StaticResource RibbonKit.Brushes.ScreenTip.Border}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="6,4"
                                    Margin="4,2,8,8">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.25" />
                                </Border.Effect>
                            </Border>
                        </Popup>

                        <Rectangle Grid.Column="1"
                                   Width="1"
                                   Margin="1,10"
                                   Fill="{StaticResource RibbonKit.Brushes.Group.Separator}" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="SizeState" Value="Collapsed">
                            <Setter TargetName="PART_NormalHost" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="PART_CollapsedButton" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="ShowDialogLauncher" Value="True">
                            <Setter TargetName="PART_DialogLauncher" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         RibbonButton — Large / Medium / Small layouts via triggers
         ============================================================ -->
    <Style TargetType="{x:Type controls:RibbonButton}">
        <Setter Property="Foreground" Value="{StaticResource RibbonKit.Brushes.Text.Primary}" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:RibbonButton}">
                    <Border x:Name="Chrome"
                            Background="Transparent"
                            CornerRadius="4"
                            Margin="1"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <!-- Large: 32px icon over wrapped label -->
                            <StackPanel x:Name="LargeLayout"
                                        Orientation="Vertical"
                                        Margin="6,4"
                                        VerticalAlignment="Center">
                                <Image x:Name="LargeImage"
                                       Source="{TemplateBinding LargeIcon}"
                                       Width="32" Height="32"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center" />
                                <TextBlock Text="{TemplateBinding Header}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           MaxWidth="76"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                            <!-- Medium: 16px icon + label in a row -->
                            <StackPanel x:Name="MediumLayout"
                                        Orientation="Horizontal"
                                        Margin="4,2"
                                        VerticalAlignment="Center"
                                        Visibility="Collapsed">
                                <Image Source="{TemplateBinding Icon}"
                                       Width="16" Height="16"
                                       Stretch="Uniform"
                                       VerticalAlignment="Center" />
                                <TextBlock Text="{TemplateBinding Header}"
                                           Margin="5,0,2,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <!-- Small: 16px icon only. Tight vertical margin so a stack of
                                 three small buttons plus the group caption fits the fixed
                                 96px groups row. -->
                            <Image x:Name="SmallLayout"
                                   Source="{TemplateBinding Icon}"
                                   Width="16" Height="16"
                                   Stretch="Uniform"
                                   Margin="5,3"
                                   VerticalAlignment="Center"
                                   Visibility="Collapsed" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="LargeIcon" Value="{x:Null}">
                            <Setter TargetName="LargeImage" Property="Source"
                                    Value="{Binding Icon, RelativeSource={RelativeSource TemplatedParent}}" />
                        </Trigger>
                        <Trigger Property="Size" Value="Medium">
                            <Setter TargetName="LargeLayout" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="MediumLayout" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="Size" Value="Small">
                            <Setter TargetName="LargeLayout" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="SmallLayout" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background"
                                    Value="{StaticResource RibbonKit.Brushes.Control.HoverBackground}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Chrome" Property="Background"
                                    Value="{StaticResource RibbonKit.Brushes.Control.PressedBackground}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         RibbonScreenTip — rich tooltip
         ============================================================ -->
    <Style TargetType="{x:Type controls:RibbonScreenTip}">
        <Setter Property="Background" Value="{StaticResource RibbonKit.Brushes.ScreenTip.Background}" />
        <Setter Property="Foreground" Value="{StaticResource RibbonKit.Brushes.Text.Primary}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:RibbonScreenTip}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{StaticResource RibbonKit.Brushes.ScreenTip.Border}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="10,8"
                            MaxWidth="300">
                        <StackPanel>
                            <TextBlock x:Name="TitleText"
                                       Text="{TemplateBinding Title}"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                            <TextBlock x:Name="DescriptionText"
                                       Text="{TemplateBinding Description}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0"
                                       Foreground="{StaticResource RibbonKit.Brushes.Text.Secondary}" />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Title" Value="{x:Null}">
                            <Setter TargetName="TitleText" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Description" Value="{x:Null}">
                            <Setter TargetName="DescriptionText" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="DescriptionText" Property="Margin" Value="0" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         RibbonToggleButton — like RibbonButton + checked accent tint
         ============================================================ -->
    <Style TargetType="{x:Type controls:RibbonToggleButton}">
        <Setter Property="Foreground" Value="{StaticResource RibbonKit.Brushes.Text.Primary}" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:RibbonToggleButton}">
                    <Border x:Name="Chrome"
                            Background="Transparent"
                            CornerRadius="4"
                            Margin="1"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <StackPanel x:Name="LargeLayout"
                                        Orientation="Vertical"
                                        Margin="6,4"
                                        VerticalAlignment="Center">
                                <Image x:Name="LargeImage"
                                       Source="{TemplateBinding LargeIcon}"
                                       Width="32" Height="32"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center" />
                                <TextBlock Text="{TemplateBinding Header}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           MaxWidth="76"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                            <StackPanel x:Name="MediumLayout"
                                        Orientation="Horizontal"
                                        Margin="4,2"
                                        VerticalAlignment="Center"
                                        Visibility="Collapsed">
                                <Image Source="{TemplateBinding Icon}"
                                       Width="16" Height="16"
                                       Stretch="Uniform"
                                       VerticalAlignment="Center" />
                                <TextBlock Text="{TemplateBinding Header}"
                                           Margin="5,0,2,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <Image x:Name="SmallLayout"
                                   Source="{TemplateBinding Icon}"
                                   Width="16" Height="16"
                                   Stretch="Uniform"
                                   Margin="5,3"
                                   VerticalAlignment="Center"
                                   Visibility="Collapsed" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="LargeIcon" Value="{x:Null}">
                            <Setter TargetName="LargeImage" Property="Source"
                                    Value="{Binding Icon, RelativeSource={RelativeSource TemplatedParent}}" />
                        </Trigger>
                        <Trigger Property="Size" Value="Medium">
                            <Setter TargetName="LargeLayout" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="MediumLayout" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="Size" Value="Small">
                            <Setter TargetName="LargeLayout" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="SmallLayout" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background"
                                    Value="{StaticResource RibbonKit.Brushes.Control.HoverBackground}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Chrome" Property="Background"
                                    Value="{StaticResource RibbonKit.Brushes.Control.PressedBackground}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Chrome" Property="Background"
                                    Value="{StaticResource RibbonKit.Brushes.Control.CheckedBackground}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Chrome" Property="Background"
                                    Value="{StaticResource RibbonKit.Brushes.Control.CheckedHoverBackground}" />
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         RibbonDropDownButton — button that opens a menu flyout
         ============================================================ -->
    <Style TargetType="{x:Type controls:RibbonDropDownButton}">
        <Setter Property="Foreground" Value="{StaticResource RibbonKit.Brushes.Text.Primary}" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:RibbonDropDownButton}">
                    <Grid>
                        <ToggleButton x:Name="PART_Toggle"
                                      IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                            <ToggleButton.Style>
                                <Style TargetType="{x:Type ToggleButton}">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type ToggleButton}">
                                                <Border x:Name="Chrome"
                                                        Background="Transparent"
                                                        CornerRadius="4"
                                                        Margin="1"
                                                        SnapsToDevicePixels="True">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Chrome" Property="Background"
                                                                Value="{StaticResource RibbonKit.Brushes.Control.HoverBackground}" />
                                                    </Trigger>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Chrome" Property="Background"
                                                                Value="{StaticResource RibbonKit.Brushes.Control.PressedBackground}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ToggleButton.Style>
                            <Grid>
                                <StackPanel x:Name="LargeLayout"
                                            Orientation="Vertical"
                                            Margin="6,4"
                                            VerticalAlignment="Center">
                                    <Image x:Name="LargeImage"
                                           Source="{TemplateBinding LargeIcon}"
                                           Width="32" Height="32"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Center" />
                                    <TextBlock Text="{TemplateBinding Header}"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               MaxWidth="76"
                                               Margin="0,4,0,0" />
                                    <Path Data="M0,0 L3.5,3.5 L7,0"
                                          Stroke="{StaticResource RibbonKit.Brushes.Text.Secondary}"
                                          StrokeThickness="1.5"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          HorizontalAlignment="Center"
                                          Margin="0,3,0,0" />
                                </StackPanel>
                                <StackPanel x:Name="MediumLayout"
                                            Orientation="Horizontal"
                                            Margin="4,2"
                                            VerticalAlignment="Center"
                                            Visibility="Collapsed">
                                    <Image Source="{TemplateBinding Icon}"
                                           Width="16" Height="16"
                                           Stretch="Uniform"
                                           VerticalAlignment="Center" />
                                    <TextBlock Text="{TemplateBinding Header}"
                                               Margin="5,0,2,0"
                                               VerticalAlignment="Center" />
                                    <Path Data="M0,0 L3.5,3.5 L7,0"
                                          Stroke="{StaticResource RibbonKit.Brushes.Text.Secondary}"
                                          StrokeThickness="1.5"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          VerticalAlignment="Center"
                                          Margin="2,2,1,0" />
                                </StackPanel>
                                <StackPanel x:Name="SmallLayout"
                                            Orientation="Horizontal"
                                            Margin="3,0"
                                            VerticalAlignment="Center"
                                            Visibility="Collapsed">
                                    <Image Source="{TemplateBinding Icon}"
                                           Width="16" Height="16"
                                           Stretch="Uniform"
                                           Margin="2,3"
                                           VerticalAlignment="Center" />
                                    <Path Data="M0,0 L3.5,3.5 L7,0"
                                          Stroke="{StaticResource RibbonKit.Brushes.Text.Secondary}"
                                          StrokeThickness="1.5"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          VerticalAlignment="Center"
                                          Margin="1,2,1,0" />
                                </StackPanel>
                            </Grid>
                        </ToggleButton>
                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               StaysOpen="True"
                               Placement="Bottom"
                               IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                            <Border x:Name="PART_MenuHost"
                                    Background="{StaticResource RibbonKit.Brushes.Ribbon.ContentBackground}"
                                    BorderBrush="{StaticResource RibbonKit.Brushes.ScreenTip.Border}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="4"
                                    Margin="4,2,8,8">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.25" />
                                </Border.Effect>
                                <ItemsPresenter />
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="LargeIcon" Value="{x:Null}">
                            <Setter TargetName="LargeImage" Property="Source"
                                    Value="{Binding Icon, RelativeSource={RelativeSource TemplatedParent}}" />
                        </Trigger>
                        <Trigger Property="Size" Value="Medium">
                            <Setter TargetName="LargeLayout" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="MediumLayout" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="Size" Value="Small">
                            <Setter TargetName="LargeLayout" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="SmallLayout" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         RibbonSplitButton — command part + chevron dropdown part
         ============================================================ -->
    <Style TargetType="{x:Type controls:RibbonSplitButton}">
        <Setter Property="Foreground" Value="{StaticResource RibbonKit.Brushes.Text.Primary}" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:RibbonSplitButton}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="PART_Primary"
                                Grid.Column="0"
                                Command="{TemplateBinding Command}"
                                CommandParameter="{TemplateBinding CommandParameter}">
                            <Button.Style>
                                <Style TargetType="{x:Type Button}">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type Button}">
                                                <Border x:Name="Chrome"
                                                        Background="Transparent"
                                                        CornerRadius="4,0,0,4"
                                                        Margin="1,1,0,1"
                                                        SnapsToDevicePixels="True">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Chrome" Property="Background"
                                                                Value="{StaticResource RibbonKit.Brushes.Control.HoverBackground}" />
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="Chrome" Property="Background"
                                                                Value="{StaticResource RibbonKit.Brushes.Control.PressedBackground}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <Grid>
                                <StackPanel x:Name="LargeLayout"
                                            Orientation="Vertical"
                                            Margin="6,4"
                                            VerticalAlignment="Center">
                                    <Image x:Name="LargeImage"
                                           Source="{TemplateBinding LargeIcon}"
                                           Width="32" Height="32"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Center" />
                                    <TextBlock Text="{TemplateBinding Header}"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               MaxWidth="76"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                                <StackPanel x:Name="MediumLayout"
                                            Orientation="Horizontal"
                                            Margin="4,2"
                                            VerticalAlignment="Center"
                                            Visibility="Collapsed">
                                    <Image Source="{TemplateBinding Icon}"
                                           Width="16" Height="16"
                                           Stretch="Uniform"
                                           VerticalAlignment="Center" />
                                    <TextBlock Text="{TemplateBinding Header}"
                                               Margin="5,0,2,0"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <Image x:Name="SmallLayout"
                                       Source="{TemplateBinding Icon}"
                                       Width="16" Height="16"
                                       Stretch="Uniform"
                                       Margin="5,3"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed" />
                            </Grid>
                        </Button>
                        <ToggleButton x:Name="PART_Toggle"
                                      Grid.Column="1"
                                      Width="15"
                                      IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                            <ToggleButton.Style>
                                <Style TargetType="{x:Type ToggleButton}">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type ToggleButton}">
                                                <Border x:Name="Chrome"
                                                        Background="Transparent"
                                                        CornerRadius="0,4,4,0"
                                                        Margin="0,1,1,1"
                                                        SnapsToDevicePixels="True">
                                                    <Path Data="M0,0 L3.5,3.5 L7,0"
                                                          Stroke="{StaticResource RibbonKit.Brushes.Text.Secondary}"
                                                          StrokeThickness="1.5"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Chrome" Property="Background"
                                                                Value="{StaticResource RibbonKit.Brushes.Control.HoverBackground}" />
                                                    </Trigger>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Chrome" Property="Background"
                                                                Value="{StaticResource RibbonKit.Brushes.Control.PressedBackground}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ToggleButton.Style>
                        </ToggleButton>
                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               StaysOpen="True"
                               Placement="Bottom"
                               IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                            <Border x:Name="PART_MenuHost"
                                    Background="{StaticResource RibbonKit.Brushes.Ribbon.ContentBackground}"
                                    BorderBrush="{StaticResource RibbonKit.Brushes.ScreenTip.Border}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="4"
                                    Margin="4,2,8,8">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.25" />
                                </Border.Effect>
                                <ItemsPresenter />
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="LargeIcon" Value="{x:Null}">
                            <Setter TargetName="LargeImage" Property="Source"
                                    Value="{Binding Icon, RelativeSource={RelativeSource TemplatedParent}}" />
                        </Trigger>
                        <Trigger Property="Size" Value="Medium">
                            <Setter TargetName="LargeLayout" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="MediumLayout" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="Size" Value="Small">
                            <Setter TargetName="LargeLayout" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="SmallLayout" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         RibbonMenuItem — row inside dropdown flyouts
         ============================================================ -->
    <Style TargetType="{x:Type controls:RibbonMenuItem}">
        <Setter Property="Foreground" Value="{StaticResource RibbonKit.Brushes.Text.Primary}" />
        <Setter Property="MinWidth" Value="160" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:RibbonMenuItem}">
                    <Border x:Name="Chrome"
                            Background="Transparent"
                            CornerRadius="4"
                            Padding="6,5"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Image Grid.Column="0"
                                   Source="{TemplateBinding Icon}"
                                   Width="16" Height="16"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Text="{TemplateBinding Header}"
                                       VerticalAlignment="Center"
                                       Margin="2,0,8,0" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background"
                                    Value="{StaticResource RibbonKit.Brushes.Control.HoverBackground}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Chrome" Property="Background"
                                    Value="{StaticResource RibbonKit.Brushes.Control.PressedBackground}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         RibbonComboBox — optional label + compact selection box
         (the Office font-family / font-size pattern)
         ============================================================ -->
    <Style TargetType="{x:Type controls:RibbonComboBox}">
        <Setter Property="Foreground" Value="{StaticResource RibbonKit.Brushes.Text.Primary}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="{x:Type ComboBoxItem}">
                    <Setter Property="Foreground" Value="{StaticResource RibbonKit.Brushes.Text.Primary}" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                                <Border x:Name="Chrome"
                                        Background="Transparent"
                                        CornerRadius="3"
                                        Padding="7,4"
                                        SnapsToDevicePixels="True">
                                    <ContentPresenter VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter TargetName="Chrome" Property="Background"
                                                Value="{StaticResource RibbonKit.Brushes.Control.HoverBackground}" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Chrome" Property="Background"
                                                Value="{StaticResource RibbonKit.Brushes.Control.CheckedBackground}" />
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.4" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:RibbonComboBox}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="HeaderText"
                                   Text="{TemplateBinding Header}"
                                   VerticalAlignment="Center"
                                   Margin="2,0,6,0" />
                        <Grid Width="{TemplateBinding InputWidth}">
                            <Border x:Name="Chrome"
                                    Background="#FFFFFF"
                                    BorderBrush="{StaticResource RibbonKit.Brushes.ScreenTip.Border}"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    SnapsToDevicePixels="True" />
                            <ToggleButton x:Name="DropToggle"
                                          ClickMode="Press"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <ToggleButton.Style>
                                    <Style TargetType="{x:Type ToggleButton}">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type ToggleButton}">
                                                    <Border Background="Transparent">
                                                        <Path Data="M0,0 L3.5,3.5 L7,0"
                                                              Stroke="{StaticResource RibbonKit.Brushes.Text.Secondary}"
                                                              StrokeThickness="1.5"
                                                              StrokeStartLineCap="Round"
                                                              StrokeEndLineCap="Round"
                                                              HorizontalAlignment="Right"
                                                              VerticalAlignment="Center"
                                                              Margin="0,0,7,0" />
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ToggleButton.Style>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Margin="8,0,22,0"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" />
                            <TextBox x:Name="PART_EditableTextBox"
                                     Visibility="Hidden"
                                     Margin="5,1,21,1"
                                     Padding="0"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     VerticalContentAlignment="Center"
                                     Focusable="True" />
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Border Background="{StaticResource RibbonKit.Brushes.Ribbon.ContentBackground}"
                                        BorderBrush="{StaticResource RibbonKit.Brushes.ScreenTip.Border}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="3"
                                        Margin="4,2,8,8"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.25" />
                                    </Border.Effect>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Header" Value="{x:Null}">
                            <Setter TargetName="HeaderText" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="IsEditable" Value="True">
                            <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible" />
                            <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush"
                                    Value="{StaticResource RibbonKit.Brushes.Text.Secondary}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush"
                                    Value="{StaticResource RibbonKit.Brushes.Accent}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
