<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:system="clr-namespace:System;assembly=System.Runtime">

    <!-- ============================================================
         Office 2019 (colorful) token palette. Same keys as Office 2024,
         different values: a blue tab strip flowing out of the blue title
         bar, white tab text, an active tab that connects to the light
         ribbon body, and fully flat (zero-radius) chrome.
         ============================================================ -->
    <!-- Modern "colorful" look: the band behind the tabs (and the title bar) is a light
         grey, and the color moves to the title bar only (via the Colored Title Bar
         option). A light grey — not white — so the near-white selected tab stands out. -->
    <SolidColorBrush x:Key="RibbonKit.Brushes.Ribbon.Background" Color="#E6E6E6" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Ribbon.ContentBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Ribbon.Border" Color="#C8C6C4" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Text.Primary" Color="#201F1E" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Text.Secondary" Color="#605E5C" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Accent" Color="#2B579A" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Control.HoverBackground" Color="#DEDCDA" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Control.PressedBackground" Color="#CFCDCB" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Control.CheckedBackground" Color="#CEDCF0" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Control.CheckedHoverBackground" Color="#BBCFEA" />
    <!-- No highlight border (Office 2010 uses a gold one; other themes don't). -->
    <SolidColorBrush x:Key="RibbonKit.Brushes.Control.HoverBorder" Color="Transparent" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Control.PressedBorder" Color="Transparent" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Control.CheckedBorder" Color="Transparent" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Control.InnerGlow" Color="Transparent" />
    <Thickness x:Key="RibbonKit.Metrics.ControlHighlightBorderThickness">0</Thickness>
    <SolidColorBrush x:Key="RibbonKit.Brushes.Tab.ContextualBackground" Color="#3D66A8" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Tab.ContextualHoverBackground" Color="#4E74B4" />
    <!-- Tabs sit on the blue band. Office 2019 uses FILLS, not underlines: the hover FILL
         is a lighter blue box, the selected FILL is the light body color (connected tab),
         and BOTH underline tokens are Transparent so no underline ever shows. -->
    <SolidColorBrush x:Key="RibbonKit.Brushes.TabStrip.Foreground" Color="#201F1E" />
    <!-- Hover fill for chrome buttons on the tab strip (File button, minimize toggle),
         matching the tab hover. Becomes accent-tinted when the title bar is colored. -->
    <SolidColorBrush x:Key="RibbonKit.Brushes.TabStrip.ControlHoverBackground" Color="#EDEDED" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Tab.HoverBackground" Color="#EDEDED" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Tab.HoverUnderline" Color="Transparent" />
    <!-- Selected tab is true white (matches the white ribbon body), standing out from the
         grey strip when the title bar isn't colored, and from the accent strip when it is. -->
    <SolidColorBrush x:Key="RibbonKit.Brushes.Tab.SelectedBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Tab.SelectedUnderline" Color="Transparent" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Tab.SelectedForeground" Color="#201F1E" />
    <!-- Active tab connects to the body via its fill; no outline needed. -->
    <SolidColorBrush x:Key="RibbonKit.Brushes.Tab.SelectedBorderBrush" Color="Transparent" />
    <Thickness x:Key="RibbonKit.Metrics.TabSelectedBorderThickness">0</Thickness>
    <Thickness x:Key="RibbonKit.Metrics.TabSelectedMargin">0</Thickness>
    <!-- Contextual tabs: this flat theme only tints the header text (no underline, no
         mute) — selection stays the fill-based active tab. -->
    <system:Double x:Key="RibbonKit.Metrics.ContextualUnderlineHeight">0</system:Double>
    <system:Double x:Key="RibbonKit.Metrics.ContextualUnselectedOpacity">1</system:Double>
    <Thickness x:Key="RibbonKit.Metrics.ApplicationButtonMargin">8,4,2,0</Thickness>
    <!-- Wider File tab than the 2024 default (a broader tab-like block). -->
    <Thickness x:Key="RibbonKit.Metrics.ApplicationButtonPadding">20,7,20,9</Thickness>
    <!-- Top inset of the tab headers (matches the File button's top). -->
    <Thickness x:Key="RibbonKit.Metrics.TabStripMargin">2,4,4,0</Thickness>
    <SolidColorBrush x:Key="RibbonKit.Brushes.Group.Separator" Color="#C8C6C4" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.ScreenTip.Background" Color="#FFFFFF" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.ScreenTip.Border" Color="#C8C6C4" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Backstage.ItemHoverBackground" Color="#3D66A8" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Backstage.ItemSelectedBackground" Color="#1F3F72" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Backstage.ContentBackground" Color="#FFFFFF" />
    <!-- Classic2010 selected-item glass marker + dialog primary (OK) button fill (flat accent). -->
    <LinearGradientBrush x:Key="RibbonKit.Brushes.Backstage.ItemSelectedGlass" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#4E7CC0" />
        <GradientStop Offset="0.5" Color="#33619E" />
        <GradientStop Offset="1" Color="#234C86" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="RibbonKit.Brushes.Dialog.PrimaryBackground" Color="#2B579A" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Dialog.PrimaryBorder" Color="#2B579A" />
    <!-- Caption buttons sit on the light grey title band: subtle grey hover/pressed. -->
    <SolidColorBrush x:Key="RibbonKit.Brushes.CaptionButton.HoverBackground" Color="#D8D8D8" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.CaptionButton.PressedBackground" Color="#C8C8C8" />
    <!-- Safety-net defaults for the QAT-on-colored-band hover/pressed wash. The Ribbon
         overrides both keys per-button with the live caption/tab band brushes
         (Ribbon.UpdateQatButtonContext); these only surface if a trigger fires first. -->
    <SolidColorBrush x:Key="RibbonKit.Brushes.Qat.ColoredHoverBackground" Color="#2EFFFFFF" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Qat.ColoredPressedBackground" Color="#4DFFFFFF" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.CaptionButton.CloseHoverBackground" Color="#E81123" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.CaptionButton.ClosePressedBackground" Color="#F1707A" />

    <!-- KeyTip badges: a white chip reads clearly over both the blue tab strip and the
         light ribbon body. -->
    <SolidColorBrush x:Key="RibbonKit.Brushes.KeyTip.Background" Color="#FFFFFF" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.KeyTip.Border" Color="#7A7A7A" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.KeyTip.Foreground" Color="#201F1E" />

    <!-- Light grey title bar matching the band behind the tabs. Enabling the Colored
         Title Bar option (ThemeManager.SetAccentedTitleBar) swaps this to the accent. -->
    <SolidColorBrush x:Key="RibbonKit.Brushes.TitleBar.Background" Color="#E6E6E6" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.TitleBar.Foreground" Color="#201F1E" />

    <!-- Office 2019 File button is flat/tab-like too (the solid accent block is a
         2010/2013 trait). Accent only while the backstage is open. -->
    <SolidColorBrush x:Key="RibbonKit.Brushes.ApplicationButton.Background" Color="Transparent" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.ApplicationButton.Foreground" Color="#201F1E" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.ApplicationButton.HoverBackground" Color="#EDEDED" />
    <!-- Mouse-down (pressed) fill for the File button. -->
    <SolidColorBrush x:Key="RibbonKit.Brushes.ApplicationButton.PressedBackground" Color="#CFCDCB" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.ApplicationButton.HoverUnderline" Color="Transparent" />
    <!-- No File-button border (Office 2010 uses one). -->
    <SolidColorBrush x:Key="RibbonKit.Brushes.ApplicationButton.Border" Color="Transparent" />
    <Thickness x:Key="RibbonKit.Metrics.ApplicationButtonBorderThickness">0</Thickness>

    <system:Double x:Key="RibbonKit.Metrics.GroupsRowHeight">104</system:Double>

    <!-- Office 2019 is fully flat: every corner radius is zero. -->
    <CornerRadius x:Key="RibbonKit.Metrics.ControlCornerRadius">0</CornerRadius>
    <CornerRadius x:Key="RibbonKit.Metrics.SmallControlCornerRadius">0</CornerRadius>
    <CornerRadius x:Key="RibbonKit.Metrics.PopupCornerRadius">0</CornerRadius>
    <CornerRadius x:Key="RibbonKit.Metrics.TabCornerRadius">0</CornerRadius>
    <CornerRadius x:Key="RibbonKit.Metrics.SplitLeftCornerRadius">0</CornerRadius>
    <CornerRadius x:Key="RibbonKit.Metrics.SplitRightCornerRadius">0</CornerRadius>

    <!-- Office 2019: no floating card. Bottom border only, so the light body connects
         seamlessly under the blue tab strip and the active (light) tab merges into it. -->
    <Thickness x:Key="RibbonKit.Metrics.ContentBorderThickness">0,0,0,1</Thickness>
    <Thickness x:Key="RibbonKit.Metrics.ContentMargin">0</Thickness>
    <CornerRadius x:Key="RibbonKit.Metrics.ContentCornerRadius">0</CornerRadius>
    <CornerRadius x:Key="RibbonKit.Metrics.ContentCornerRadiusTop">0</CornerRadius>
    <Thickness x:Key="RibbonKit.Metrics.ContentMarginQatBelow">0</Thickness>

    <!-- Flat theme: no ribbon shadow. -->
    <DropShadowEffect x:Key="RibbonKit.Effects.ContentShadow"
                      Opacity="0" BlurRadius="0" ShadowDepth="0" />

    <!-- Flat below-ribbon QAT: a plain full-width strip with a bottom border. -->
    <Thickness x:Key="RibbonKit.Metrics.QatExtenderMargin">0</Thickness>
    <Thickness x:Key="RibbonKit.Metrics.QatExtenderBorderThickness">0,0,0,1</Thickness>
    <CornerRadius x:Key="RibbonKit.Metrics.QatExtenderCornerRadius">0</CornerRadius>

    <!-- Flat theme: the minimized QAT keeps the same full-width, bottom-bordered strip
         (no floating card), so these match the normal values above. -->
    <Thickness x:Key="RibbonKit.Metrics.QatExtenderMarginMinimized">0</Thickness>
    <Thickness x:Key="RibbonKit.Metrics.QatExtenderBorderThicknessMinimized">0,0,0,1</Thickness>
    <CornerRadius x:Key="RibbonKit.Metrics.QatExtenderCornerRadiusMinimized">0</CornerRadius>

</ResourceDictionary>
