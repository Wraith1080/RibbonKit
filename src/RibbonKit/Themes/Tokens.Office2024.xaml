<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:system="clr-namespace:System;assembly=System.Runtime">

    <!-- ============================================================
         Office 2024 (light) token palette. Merge this in App.xaml, or
         swap it at runtime via RibbonKit.Theming.ThemeManager. The
         shared templates in Office2024.xaml reference these by key.
         ============================================================ -->
    <!-- Transparent so the ribbon area shows the window background (no grey box):
         the ribbon body floats as a white card over it. -->
    <SolidColorBrush x:Key="RibbonKit.Brushes.Ribbon.Background" Color="Transparent" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Ribbon.ContentBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Ribbon.Border" Color="#E0E0E0" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Text.Primary" Color="#1A1A1A" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Text.Secondary" Color="#616161" />
    <!-- Default (Auto) accent: Office blue #2B579A, the SAME default as 2019/2013, so switching
         theme generations doesn't jump the accent (was Fluent #0F6CBD, which only 2024 used).
         Every #2B579A below tracks this; a runtime accent via ThemeManager overrides them all. -->
    <SolidColorBrush x:Key="RibbonKit.Brushes.Accent" Color="#2B579A" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Control.HoverBackground" Color="#E6E6E6" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Control.PressedBackground" Color="#DADADA" />
    <!-- Toggled washes = the SAME tint formula ThemeManager applies for a custom accent
         (Mix(accent, White, 0.82 / 0.72)) evaluated at the #2B579A default, so the default and
         an explicitly-set #2B579A accent look identical. -->
    <SolidColorBrush x:Key="RibbonKit.Brushes.Control.CheckedBackground" Color="#D9E1ED" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Control.CheckedHoverBackground" Color="#C4D0E3" />
    <!-- No highlight border (Office 2010 uses a gold one; other themes don't). -->
    <SolidColorBrush x:Key="RibbonKit.Brushes.Control.HoverBorder" Color="Transparent" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Control.PressedBorder" Color="Transparent" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Control.CheckedBorder" Color="Transparent" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Control.InnerGlow" Color="Transparent" />
    <Thickness x:Key="RibbonKit.Metrics.ControlHighlightBorderThickness">0</Thickness>
    <SolidColorBrush x:Key="RibbonKit.Brushes.Tab.ContextualBackground" Color="#E4F0FB" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Tab.ContextualHoverBackground" Color="#D5E7F7" />
    <!-- Tab strip. Office 2024 uses UNDERLINES: the hover/selected FILLS are Transparent,
         the hover/selected UNDERLINES carry the color. (A theme flips this by making the
         underlines Transparent and the fills colored — see Office 2019.) -->
    <SolidColorBrush x:Key="RibbonKit.Brushes.TabStrip.Foreground" Color="#1A1A1A" />
    <!-- Hover fill for chrome buttons sitting on the tab strip (File button, minimize
         toggle), so they highlight like the tabs. Tracks the accent when the title bar
         is colored. -->
    <SolidColorBrush x:Key="RibbonKit.Brushes.TabStrip.ControlHoverBackground" Color="#E6E6E6" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Tab.HoverBackground" Color="Transparent" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Tab.HoverUnderline" Color="#B8B8B8" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Tab.SelectedBackground" Color="Transparent" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Tab.SelectedUnderline" Color="#2B579A" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Tab.SelectedForeground" Color="#2B579A" />
    <!-- Active-tab outline is off in 2024 (the accent underline marks selection). -->
    <SolidColorBrush x:Key="RibbonKit.Brushes.Tab.SelectedBorderBrush" Color="Transparent" />
    <Thickness x:Key="RibbonKit.Metrics.TabSelectedBorderThickness">0</Thickness>
    <Thickness x:Key="RibbonKit.Metrics.TabSelectedMargin">0</Thickness>
    <!-- Underline theme: the active tab floats above the body, so the connect transform is identity
         and the connector foot stays invisible. -->
    <TranslateTransform x:Key="RibbonKit.Transforms.TabConnect" Y="0" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Tab.ConnectFootHover" Color="Transparent" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Tab.ConnectFootSelected" Color="Transparent" />
    <!-- No connected tab: the body-border notch (PART_ConnectNotch) stays disabled — the code
         gates on this brush being a visible colour. -->
    <SolidColorBrush x:Key="RibbonKit.Brushes.Tab.ConnectNotch" Color="Transparent" />
    <!-- Contextual tabs: 2024 tints the header text and shows a tinted selection
         underline (height 3), and mutes the text until the tab is selected. -->
    <system:Double x:Key="RibbonKit.Metrics.ContextualUnderlineHeight">3</system:Double>
    <system:Double x:Key="RibbonKit.Metrics.ContextualUnselectedOpacity">0.6</system:Double>
    <!-- Small gap before the File button. -->
    <Thickness x:Key="RibbonKit.Metrics.ApplicationButtonMargin">8,4,2,0</Thickness>
    <!-- Inner padding of the File button (drives its width). 2024 keeps the compact default;
         the pre-2024 themes widen it (their File tab reads as a broader block). -->
    <Thickness x:Key="RibbonKit.Metrics.ApplicationButtonPadding">14,7,14,9</Thickness>
    <!-- Top inset of the tab headers. Matches the File button's top so the two align;
         a theme can drop the top to 0 to let the tabs meet the title bar. -->
    <Thickness x:Key="RibbonKit.Metrics.TabStripMargin">2,4,4,0</Thickness>
    <SolidColorBrush x:Key="RibbonKit.Brushes.Group.Separator" Color="#E0E0E0" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.ScreenTip.Background" Color="#FFFFFF" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.ScreenTip.Border" Color="#D1D1D1" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Backstage.ItemHoverBackground" Color="#2B7FC7" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Backstage.ItemSelectedBackground" Color="#0A5799" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Backstage.ContentBackground" Color="#FFFFFF" />
    <!-- Classic2010 selected-item glass marker + dialog primary (OK) button fill. Non-2010
         themes keep a flat accent OK button (only the 2010 theme swaps in a glass gel). -->
    <LinearGradientBrush x:Key="RibbonKit.Brushes.Backstage.ItemSelectedGlass" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#3E9AD8" />
        <GradientStop Offset="0.5" Color="#1A7BC4" />
        <GradientStop Offset="1" Color="#0C5DA6" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="RibbonKit.Brushes.Dialog.PrimaryBackground" Color="#2B579A" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Dialog.PrimaryBorder" Color="#2B579A" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.CaptionButton.HoverBackground" Color="#E5E5E5" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.CaptionButton.PressedBackground" Color="#D6D6D6" />
    <!-- Safety-net defaults for the QAT-on-colored-band hover/pressed wash. The Ribbon
         overrides both keys per-button with the live caption/tab band brushes
         (Ribbon.UpdateQatButtonContext); these only surface if a trigger fires first. -->
    <SolidColorBrush x:Key="RibbonKit.Brushes.Qat.ColoredHoverBackground" Color="#2EFFFFFF" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.Qat.ColoredPressedBackground" Color="#4DFFFFFF" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.CaptionButton.CloseHoverBackground" Color="#E81123" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.CaptionButton.ClosePressedBackground" Color="#F1707A" />

    <!-- KeyTip badges (Alt access-key chips): a light box with a thin border and dark text. -->
    <SolidColorBrush x:Key="RibbonKit.Brushes.KeyTip.Background" Color="#EFEFEF" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.KeyTip.Border" Color="#A6A6A6" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.KeyTip.Foreground" Color="#1A1A1A" />

    <!-- Title bar band: light, matching the ribbon (Office 2024 has no colored band). -->
    <SolidColorBrush x:Key="RibbonKit.Brushes.TitleBar.Background" Color="#F3F3F3" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.TitleBar.Foreground" Color="#1A1A1A" />

    <!-- Application (File) button: a flat, tab-like button (NOT a solid accent block;
         that belongs to Office 2010/2013). Underline hover like the tabs; turns accent
         only while the backstage is open. -->
    <SolidColorBrush x:Key="RibbonKit.Brushes.ApplicationButton.Background" Color="Transparent" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.ApplicationButton.Foreground" Color="#1A1A1A" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.ApplicationButton.HoverBackground" Color="Transparent" />
    <!-- Mouse-down (pressed) fill for the File button. -->
    <SolidColorBrush x:Key="RibbonKit.Brushes.ApplicationButton.PressedBackground" Color="#DADADA" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.ApplicationButton.HoverUnderline" Color="#B8B8B8" />
    <!-- No File-button border (Office 2010 uses one). -->
    <SolidColorBrush x:Key="RibbonKit.Brushes.ApplicationButton.Border" Color="Transparent" />
    <Thickness x:Key="RibbonKit.Metrics.ApplicationButtonBorderThickness">0</Thickness>

    <system:Double x:Key="RibbonKit.Metrics.GroupsRowHeight">104</system:Double>

    <!-- Corner radii — rounded (modern Fluent look). Themes that want sharp corners
         (Office 2019/2013) set these to 0. -->
    <CornerRadius x:Key="RibbonKit.Metrics.ControlCornerRadius">4</CornerRadius>
    <CornerRadius x:Key="RibbonKit.Metrics.SmallControlCornerRadius">2</CornerRadius>
    <CornerRadius x:Key="RibbonKit.Metrics.PopupCornerRadius">6</CornerRadius>
    <CornerRadius x:Key="RibbonKit.Metrics.TabCornerRadius">4,4,0,0</CornerRadius>
    <CornerRadius x:Key="RibbonKit.Metrics.SplitLeftCornerRadius">4,0,0,4</CornerRadius>
    <CornerRadius x:Key="RibbonKit.Metrics.SplitRightCornerRadius">0,4,4,0</CornerRadius>

    <!-- Ribbon body as a floating rounded card (Office 2024/365 Fluent look):
         inset margin, all-around border, rounded corners. -->
    <Thickness x:Key="RibbonKit.Metrics.ContentBorderThickness">1</Thickness>
    <Thickness x:Key="RibbonKit.Metrics.ContentMargin">7,1,7,7</Thickness>
    <CornerRadius x:Key="RibbonKit.Metrics.ContentCornerRadius">8</CornerRadius>
    <!-- Card geometry when the QAT sits below the ribbon: top corners rounded, bottom
         square, and no bottom margin so the QAT bar connects flush. -->
    <CornerRadius x:Key="RibbonKit.Metrics.ContentCornerRadiusTop">8,8,0,0</CornerRadius>
    <Thickness x:Key="RibbonKit.Metrics.ContentMarginQatBelow">7,1,7,0</Thickness>

    <!-- Soft drop shadow that lifts the ribbon card. Flat themes zero its opacity. -->
    <DropShadowEffect x:Key="RibbonKit.Effects.ContentShadow"
                      BlurRadius="12" ShadowDepth="2" Direction="270"
                      Opacity="0.16" Color="#000000" RenderingBias="Performance" />

    <!-- Below-ribbon QAT: a full-width bar connecting flush under the card (flat top
         border to merge with the card's square bottom, rounded bottom corners). -->
    <Thickness x:Key="RibbonKit.Metrics.QatExtenderMargin">7,0,7,7</Thickness>
    <Thickness x:Key="RibbonKit.Metrics.QatExtenderBorderThickness">1,0,1,1</Thickness>
    <CornerRadius x:Key="RibbonKit.Metrics.QatExtenderCornerRadius">0,0,8,8</CornerRadius>

    <!-- When the ribbon is minimized the body card disappears and the QAT bar stands
         alone, so it becomes a fully rounded, fully bordered floating card with a small
         top gap (the space the card used to hold). -->
    <Thickness x:Key="RibbonKit.Metrics.QatExtenderMarginMinimized">7,1,7,7</Thickness>
    <Thickness x:Key="RibbonKit.Metrics.QatExtenderBorderThicknessMinimized">1</Thickness>
    <CornerRadius x:Key="RibbonKit.Metrics.QatExtenderCornerRadiusMinimized">8</CornerRadius>

    <!-- ============================================================
         MDI child-window chrome (MdiContainer/MdiChild). 2024: accent
         active caption, rounded corners matching the ribbon card.
         ============================================================ -->
    <SolidColorBrush x:Key="RibbonKit.Brushes.MdiChild.ActiveCaptionBackground" Color="#2B579A" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.MdiChild.ActiveCaptionForeground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.MdiChild.InactiveCaptionBackground" Color="#F3F3F3" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.MdiChild.InactiveCaptionForeground" Color="#616161" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.MdiChild.ActiveBorder" Color="#2B579A" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.MdiChild.InactiveBorder" Color="#D1D1D1" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.MdiClient.Background" Color="#E9E9E9" />

    <SolidColorBrush x:Key="RibbonKit.Brushes.MdiChild.CaptionButtonHoverBackground" Color="#26000000" />
    <SolidColorBrush x:Key="RibbonKit.Brushes.MdiChild.CaptionButtonPressedBackground" Color="#40000000" />
    <system:Double x:Key="RibbonKit.Metrics.MdiChild.CaptionHeight">30</system:Double>
    <CornerRadius x:Key="RibbonKit.Metrics.MdiChild.CornerRadius">8</CornerRadius>
    <CornerRadius x:Key="RibbonKit.Metrics.MdiChild.CaptionCornerRadius">7,7,0,0</CornerRadius>
    <!-- The close button's hover/pressed wash: rounded only at the caption's top-right
         so it never clips over the rounded child border. -->
    <CornerRadius x:Key="RibbonKit.Metrics.MdiChild.CloseButtonCornerRadius">0,7,0,0</CornerRadius>

</ResourceDictionary>
