<rk:RibbonWindow x:Class="RibbonKit.Showcase.Test1"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:rk="urn:ribbonkit"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 mc:Ignorable="d"
                 Title="RibbonKit Test"
                 Width="1080"
                 Height="680"
                 MinWidth="360"
                 WindowStartupLocation="CenterScreen"
                 UseLayoutRounding="True"
                 Background="White">
    <DockPanel>
        <rk:Ribbon DockPanel.Dock="Top" QuickAccessPosition="BelowRibbon">
            <rk:Ribbon.Backstage>
                <rk:Backstage Design="Modern" >
                    <rk:BackstageTabItem Header="Info"/>
                    <rk:BackstageTabItem Header="Page"/>
                    <rk:BackstageTabItem Header="Action" IsButton="True" Placement="Bottom"/>
                </rk:Backstage>
            </rk:Ribbon.Backstage>
            <rk:RibbonTab Header="Home">
                <rk:RibbonGroup Header="New Group">
                    <rk:RibbonButton Header="Button"/>
                </rk:RibbonGroup>
                <rk:RibbonGroup Header="Test Group">
                    <rk:RibbonButton Header="Test Button"/>
                </rk:RibbonGroup>
            </rk:RibbonTab>
            <rk:RibbonTab Header="Test Tab">
                <rk:RibbonGroup Header="New Group"/>
            </rk:RibbonTab>
        </rk:Ribbon>
    </DockPanel>
</rk:RibbonWindow>