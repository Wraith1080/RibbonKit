<rk:RibbonWindow x:Class="RibbonKit.Showcase.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:rk="urn:ribbonkit"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 mc:Ignorable="d"
                 Title="RibbonKit Showcase"
                 Width="1080"
                 Height="680"
                 MinWidth="360"
                 WindowStartupLocation="CenterScreen"
                 UseLayoutRounding="True"
                 Background="White">
    <DockPanel>
        <!-- QuickAccessPosition options: TabRow (next to File) or BelowRibbon (Office
             2024 default, shown here). A third placement — the title bar — is available
             via rk:RibbonWindow.TitleBarContent and auto-hides while the backstage is
             open. -->
        <rk:Ribbon x:Name="MainRibbon"
                   DockPanel.Dock="Top"
                   QuickAccessPosition="BelowRibbon"
                   QuickAccessCustomizeRequested="OnCustomizeQuickAccess"
                   RibbonCustomizeRequested="OnCustomizeRibbon"
                   d:IsBackstageOpen="false">
            <rk:Ribbon.Backstage>
                <!-- d:SelectedIndex previews a specific backstage page on the XAML designer
                     surface (paired with d:IsBackstageOpen above). Runtime is unaffected. -->
                <rk:Backstage x:Name="ShowcaseBackstage" Design="Modern" d:SelectedIndex="4">
                    <rk:BackstageTabItem Header="Home" Icon="{StaticResource Icon.Style}">
                        <StackPanel HorizontalAlignment="Left" MaxWidth="720">
                            <TextBlock Text="Good morning" FontSize="30" FontWeight="Light" Margin="0,0,0,20" />
                            <TextBlock Text="New" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,10" />
                            <WrapPanel Margin="0,0,0,28">
                                <Border Width="130" Height="168" Background="#FFFFFF" BorderBrush="#D1D1D1"
                                        BorderThickness="1" CornerRadius="2" Margin="0,0,16,0">
                                    <TextBlock Text="Blank document" HorizontalAlignment="Center"
                                               VerticalAlignment="Bottom" Margin="0,0,0,10" FontSize="12" />
                                </Border>
                                <Border Width="130" Height="168" Background="#1F3864" CornerRadius="2" Margin="0,0,16,0">
                                    <TextBlock Text="Report" Foreground="#FFFFFF" HorizontalAlignment="Center"
                                               VerticalAlignment="Bottom" Margin="0,0,0,10" FontSize="12" />
                                </Border>
                                <Border Width="130" Height="168" Background="#2E75B6" CornerRadius="2">
                                    <TextBlock Text="Newsletter" Foreground="#FFFFFF" HorizontalAlignment="Center"
                                               VerticalAlignment="Bottom" Margin="0,0,0,10" FontSize="12" />
                                </Border>
                            </WrapPanel>
                            <TextBlock Text="Recent" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,10" />
                            <TextBlock Text="Quarterly report.docx" Margin="0,5" Foreground="#1A1A1A" />
                            <TextBlock Text="Meeting notes.docx" Margin="0,5" Foreground="#1A1A1A" />
                            <TextBlock Text="RibbonKit roadmap.docx" Margin="0,5" Foreground="#1A1A1A" />
                        </StackPanel>
                    </rk:BackstageTabItem>
                    <rk:BackstageTabItem Header="Info">
                        <StackPanel MaxWidth="560" HorizontalAlignment="Left">
                            <TextBlock Text="Info" FontSize="28" FontWeight="Light" Margin="0,0,0,16" />
                            <TextBlock Text="RibbonKit Showcase Document" FontSize="16" FontWeight="SemiBold" />
                            <TextBlock Text="This is the backstage view — a full-window overlay opened by the File button, just like Office 2013 and later. Press Esc or click the back arrow to return."
                                       TextWrapping="Wrap" Foreground="#616161" Margin="0,8,0,0" />
                        </StackPanel>
                    </rk:BackstageTabItem>
                    <rk:BackstageTabItem Header="New" Icon="{StaticResource Icon.Picture}">
                        <StackPanel HorizontalAlignment="Left">
                            <TextBlock Text="New" FontSize="28" FontWeight="Light" Margin="0,0,0,16" />
                            <WrapPanel>
                                <Border Width="140" Height="180" Background="#F3F3F3" BorderBrush="#D1D1D1"
                                        BorderThickness="1" CornerRadius="4" Margin="0,0,16,16">
                                    <TextBlock Text="Blank document" HorizontalAlignment="Center"
                                               VerticalAlignment="Bottom" Margin="0,0,0,12" FontSize="12" />
                                </Border>
                                <Border Width="140" Height="180" Background="#F3F3F3" BorderBrush="#D1D1D1"
                                        BorderThickness="1" CornerRadius="4" Margin="0,0,16,16">
                                    <TextBlock Text="Report" HorizontalAlignment="Center"
                                               VerticalAlignment="Bottom" Margin="0,0,0,12" FontSize="12" />
                                </Border>
                                <Border Width="140" Height="180" Background="#F3F3F3" BorderBrush="#D1D1D1"
                                        BorderThickness="1" CornerRadius="4" Margin="0,0,16,16">
                                    <TextBlock Text="Letter" HorizontalAlignment="Center"
                                               VerticalAlignment="Bottom" Margin="0,0,0,12" FontSize="12" />
                                </Border>
                            </WrapPanel>
                        </StackPanel>
                    </rk:BackstageTabItem>
                    <rk:BackstageTabItem Header="Open" Icon="{StaticResource Icon.Table}">
                        <StackPanel HorizontalAlignment="Left" MaxWidth="560">
                            <TextBlock Text="Open" FontSize="28" FontWeight="Light" Margin="0,0,0,16" />
                            <TextBlock Text="Recent" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <TextBlock Text="Quarterly report.docx" Margin="0,4" Foreground="#1A1A1A" />
                            <TextBlock Text="Meeting notes.docx" Margin="0,4" Foreground="#1A1A1A" />
                            <TextBlock Text="RibbonKit roadmap.docx" Margin="0,4" Foreground="#1A1A1A" />
                        </StackPanel>
                    </rk:BackstageTabItem>

                    <!-- Footer: pinned to the bottom of the nav column (like Word). "Account" is a
                         page; "Options" and "Exit" are BUTTON items — clicking them runs an action
                         instead of switching pages. -->
                    <rk:BackstageTabItem Header="Account" Placement="Bottom" Icon="{StaticResource Icon.Account}">
                        <StackPanel HorizontalAlignment="Left" MaxWidth="560">
                            <TextBlock Text="Account" FontSize="28" FontWeight="Light" Margin="0,0,0,16" />
                            <TextBlock Text="RibbonKit User" FontSize="16" FontWeight="SemiBold" />
                            <TextBlock Text="user@ribbonkit.dev" Foreground="#616161" Margin="0,2,0,0" />
                            <TextBlock Text="This footer page is pinned to the bottom of the nav column via Placement=&quot;Bottom&quot;, just like Word's Account tab."
                                       TextWrapping="Wrap" Foreground="#616161" Margin="0,16,0,0" />
                        </StackPanel>
                    </rk:BackstageTabItem>
                    <rk:BackstageTabItem Header="Options" Placement="Bottom" IsButton="True"
                                         Icon="{StaticResource Icon.Gear}" Click="OnBackstageOptions" />
                    <rk:BackstageTabItem Header="Exit" Placement="Bottom" IsButton="True"
                                         Icon="{StaticResource Icon.Exit}" Click="OnBackstageExit" />
                </rk:Backstage>
            </rk:Ribbon.Backstage>

            <rk:Ribbon.QuickAccessItems>
                <rk:RibbonButton Size="Small" Icon="{StaticResource Icon.Save}"
                                 rk:Ribbon.CommandId="cmd.save"
                                 ScreenTipTitle="Save (Ctrl+S)" ScreenTipText="Save your document." />
                <rk:RibbonButton Size="Small" Icon="{StaticResource Icon.Undo}"
                                 rk:Ribbon.CommandId="cmd.undo"
                                 ScreenTipTitle="Undo (Ctrl+Z)" ScreenTipText="Undo your last action." />
                <rk:RibbonButton Size="Small" Icon="{StaticResource Icon.Redo}"
                                 rk:Ribbon.CommandId="cmd.redo"
                                 ScreenTipTitle="Redo (Ctrl+Y)" ScreenTipText="Redo the last undone action." />
            </rk:Ribbon.QuickAccessItems>

            <rk:RibbonTab Header="Home" rk:Ribbon.CommandId="tab.home">
                <!-- ResizeThenCollapse: buttons shrink in place first, then the group
                     collapses to a flyout button as the last step -->
                <rk:RibbonGroup Header="Clipboard"
                                rk:Ribbon.CommandId="group.home.clipboard"
                                Icon="{StaticResource Icon.Paste}"
                                ReductionMode="ResizeThenCollapse">
                    <rk:RibbonSplitButton Header="Paste"
                                          x:Name="DemoSplitTarget"
                                          rk:Ribbon.CommandId="cmd.paste"
                                          LargeIcon="{StaticResource Icon.Paste}"
                                          Icon="{StaticResource Icon.Paste}"
                                          SizeDefinition="Large, Medium, Small"
                                          ScreenTipTitle="Paste (Ctrl+V)"
                                          ScreenTipText="Click for a normal paste, or open the menu for more paste options.">
                        <rk:RibbonMenuItem Header="Paste" Icon="{StaticResource Icon.Paste}" />
                        <rk:RibbonMenuItem Header="Paste Special..." Icon="{StaticResource Icon.Copy}" />
                        <rk:RibbonMenuItem Header="Keep Text Only" />
                    </rk:RibbonSplitButton>
                    <StackPanel VerticalAlignment="Center">
                        <rk:RibbonButton Header="Cut" Size="Medium"
                                         x:Name="DemoButtonTarget"
                                         rk:Ribbon.CommandId="cmd.cut"
                                         Icon="{StaticResource Icon.Cut}"
                                         SizeDefinition="Medium, Medium, Small"
                                         ScreenTipTitle="Cut (Ctrl+X)"
                                         ScreenTipText="Remove the selection and put it on the Clipboard." rk:KeyTip.Keys="CU" />
                        <rk:RibbonButton Header="Copy" Size="Medium"
                                         rk:Ribbon.CommandId="cmd.copy"
                                         Icon="{StaticResource Icon.Copy}"
                                         SizeDefinition="Medium, Medium, Small"
                                         ScreenTipTitle="Copy (Ctrl+C)"
                                         ScreenTipText="Put a copy of the selection on the Clipboard." />
                        <rk:RibbonButton Header="Format Painter" Size="Medium"
                                         rk:Ribbon.CommandId="cmd.formatPainter"
                                         Icon="{StaticResource Icon.FormatPainter}"
                                         SizeDefinition="Medium, Medium, Small"
                                         rk:KeyTip.Keys="FP"
                                         ScreenTipTitle="Format Painter"
                                         ScreenTipText="Copy formatting from one place and apply it to another." />
                    </StackPanel>
                </rk:RibbonGroup>

                <!-- CanResize=False: this group never shrinks, no matter how narrow -->
                <rk:RibbonGroup Header="Font"
                                x:Name="DemoGroupTarget"
                                rk:Ribbon.CommandId="group.home.font"
                                Icon="{StaticResource Icon.Font}"
                                CanResize="False"
                                ShowDialogLauncher="True">
                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <rk:RibbonComboBox InputWidth="128"
                                               IsEditable="True"
                                               SelectedIndex="0"
                                               ScreenTipTitle="Font"
                                               ScreenTipText="Pick a font for your text.">
                                <ComboBoxItem Content="Calibri" />
                                <ComboBoxItem Content="Segoe UI" />
                                <ComboBoxItem Content="Arial" />
                                <ComboBoxItem Content="Times New Roman" />
                                <ComboBoxItem Content="Consolas" />
                                <ComboBoxItem Content="Georgia" />
                            </rk:RibbonComboBox>
                            <rk:RibbonComboBox InputWidth="48"
                                               Margin="4,0,0,0"
                                               SelectedIndex="2"
                                               ScreenTipTitle="Font Size"
                                               ScreenTipText="Change the size of your text.">
                                <ComboBoxItem Content="9" />
                                <ComboBoxItem Content="10" />
                                <ComboBoxItem Content="11" />
                                <ComboBoxItem Content="12" />
                                <ComboBoxItem Content="14" />
                                <ComboBoxItem Content="18" />
                                <ComboBoxItem Content="24" />
                            </rk:RibbonComboBox>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                        <rk:RibbonToggleButton Size="Small"
                                               rk:Ribbon.CommandId="cmd.bold"
                                               Icon="{StaticResource Icon.Bold}"
                                               ScreenTipTitle="Bold (Ctrl+B)"
                                               ScreenTipText="Make your text bold." />
                        <rk:RibbonToggleButton Size="Small"
                                               rk:Ribbon.CommandId="cmd.italic"
                                               Icon="{StaticResource Icon.Italic}"
                                               ScreenTipTitle="Italic (Ctrl+I)"
                                               ScreenTipText="Italicize your text." />
                        <rk:RibbonToggleButton Size="Small"
                                               rk:Ribbon.CommandId="cmd.underline"
                                               Icon="{StaticResource Icon.Underline}"
                                               ScreenTipTitle="Underline (Ctrl+U)"
                                               ScreenTipText="Underline your text." />
                        </StackPanel>
                    </StackPanel>
                </rk:RibbonGroup>

                <!-- Highest ReductionPriority shrinks first -->
                <!-- In-ribbon gallery with live preview: hover restyles the sample
                     text below, click commits, leaving reverts -->
                <rk:RibbonGroup Header="Styles" rk:Ribbon.CommandId="group.home.styles" Icon="{StaticResource Icon.Style}" ReductionPriority="10">
                    <!-- Width fits exactly 3 tile columns (3 × 78px tiles + 21px chrome/buttons) -->
                    <rk:InRibbonGallery x:Name="StylesGallery"
                                        Width="258"
                                        SelectedIndex="0"
                                        ItemPreview="OnStylePreview"
                                        ItemPreviewCancelled="OnStylePreviewCancelled"
                                        SelectionChanged="OnStyleCommitted">
                        <rk:RibbonGalleryItem Tag="Normal">
                            <StackPanel Width="64">
                                <TextBlock Text="AaBbCc" FontSize="14" HorizontalAlignment="Center" />
                                <TextBlock Text="Normal" FontSize="10" Foreground="#616161" HorizontalAlignment="Center" />
                            </StackPanel>
                        </rk:RibbonGalleryItem>
                        <rk:RibbonGalleryItem Tag="Heading 1">
                            <StackPanel Width="64">
                                <TextBlock Text="AaBbCc" FontSize="15" FontWeight="SemiBold" Foreground="#0F6CBD" HorizontalAlignment="Center" />
                                <TextBlock Text="Heading 1" FontSize="10" Foreground="#616161" HorizontalAlignment="Center" />
                            </StackPanel>
                        </rk:RibbonGalleryItem>
                        <rk:RibbonGalleryItem Tag="Heading 2">
                            <StackPanel Width="64">
                                <TextBlock Text="AaBbCc" FontSize="14" FontWeight="SemiBold" Foreground="#2B7FC7" HorizontalAlignment="Center" />
                                <TextBlock Text="Heading 2" FontSize="10" Foreground="#616161" HorizontalAlignment="Center" />
                            </StackPanel>
                        </rk:RibbonGalleryItem>
                        <rk:RibbonGalleryItem Tag="Title">
                            <StackPanel Width="64">
                                <TextBlock Text="AaBbCc" FontSize="17" FontWeight="Light" HorizontalAlignment="Center" />
                                <TextBlock Text="Title" FontSize="10" Foreground="#616161" HorizontalAlignment="Center" />
                            </StackPanel>
                        </rk:RibbonGalleryItem>
                        <rk:RibbonGalleryItem Tag="Subtitle">
                            <StackPanel Width="64">
                                <TextBlock Text="AaBbCc" FontSize="13" Foreground="#616161" HorizontalAlignment="Center" />
                                <TextBlock Text="Subtitle" FontSize="10" Foreground="#616161" HorizontalAlignment="Center" />
                            </StackPanel>
                        </rk:RibbonGalleryItem>
                        <rk:RibbonGalleryItem Tag="Quote">
                            <StackPanel Width="64">
                                <TextBlock Text="AaBbCc" FontSize="13" FontStyle="Italic" Foreground="#616161" HorizontalAlignment="Center" />
                                <TextBlock Text="Quote" FontSize="10" Foreground="#616161" HorizontalAlignment="Center" />
                            </StackPanel>
                        </rk:RibbonGalleryItem>
                        <rk:RibbonGalleryItem Tag="Strong">
                            <StackPanel Width="64">
                                <TextBlock Text="AaBbCc" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center" />
                                <TextBlock Text="Strong" FontSize="10" Foreground="#616161" HorizontalAlignment="Center" />
                            </StackPanel>
                        </rk:RibbonGalleryItem>
                        <rk:RibbonGalleryItem Tag="Emphasis">
                            <StackPanel Width="64">
                                <TextBlock Text="AaBbCc" FontSize="13" FontStyle="Italic" HorizontalAlignment="Center" />
                                <TextBlock Text="Emphasis" FontSize="10" Foreground="#616161" HorizontalAlignment="Center" />
                            </StackPanel>
                        </rk:RibbonGalleryItem>
                    </rk:InRibbonGallery>
                </rk:RibbonGroup>

                <!-- Shrinks after Styles; Clipboard (no priority) shrinks last, largest-first -->
                <rk:RibbonGroup Header="Editing" rk:Ribbon.CommandId="group.home.editing" Icon="{StaticResource Icon.Find}" ReductionPriority="5">
                    <StackPanel VerticalAlignment="Center">
                        <rk:RibbonButton Header="Find" Size="Medium"
                                         rk:Ribbon.CommandId="cmd.find"
                                         Icon="{StaticResource Icon.Find}"
                                         SizeDefinition="Medium, Medium, Small"
                                         ScreenTipTitle="Find (Ctrl+F)"
                                         ScreenTipText="Search for text in your document." />
                        <rk:RibbonButton Header="Replace" Size="Medium"
                                         rk:Ribbon.CommandId="cmd.replace"
                                         Icon="{StaticResource Icon.Replace}"
                                         SizeDefinition="Medium, Medium, Small"
                                         ScreenTipTitle="Replace (Ctrl+H)"
                                         ScreenTipText="Search for text and replace it with something else." />
                        <rk:RibbonDropDownButton Header="Select" Size="Medium"
                                                 rk:Ribbon.CommandId="cmd.select"
                                                 Icon="{StaticResource Icon.Select}"
                                                 SizeDefinition="Medium, Medium, Small"
                                                 ScreenTipTitle="Select"
                                                 ScreenTipText="Select text or objects in your document.">
                            <rk:RibbonMenuItem Header="Select All" />
                            <rk:RibbonMenuItem Header="Select Objects" Icon="{StaticResource Icon.Select}" />
                            <rk:RibbonMenuItem Header="Selection Pane..." />
                        </rk:RibbonDropDownButton>
                    </StackPanel>
                </rk:RibbonGroup>

                <!-- Demo: toggling this disables a plain button (Cut), a split button (Paste),
                     and a whole group (Font) at once, so the disabled/greyed states are visible. -->
                <rk:RibbonGroup Header="Demo" rk:Ribbon.CommandId="group.home.demo" Icon="{StaticResource Icon.Gear}" CanResize="False">
                    <rk:RibbonToggleButton Header="Disable Samples"
                                           x:Name="DisableSamplesToggle"
                                           LargeIcon="{StaticResource Icon.Gear}"
                                           Icon="{StaticResource Icon.Gear}"
                                           SizeDefinition="Large, Large, Medium"
                                           Click="OnToggleDisableSamples"
                                           ScreenTipTitle="Disable Samples"
                                           ScreenTipText="Toggle to disable the Cut button, the Paste split button, and the Font group — showing how disabled ribbon controls look." />
                </rk:RibbonGroup>
            </rk:RibbonTab>

            <rk:RibbonTab Header="Insert" rk:Ribbon.CommandId="tab.insert">
                <rk:RibbonGroup Header="Tables" rk:Ribbon.CommandId="group.insert.tables" Icon="{StaticResource Icon.Table}">
                    <rk:RibbonButton Header="Table"
                                     rk:Ribbon.CommandId="cmd.table"
                                     LargeIcon="{StaticResource Icon.Table}"
                                     Icon="{StaticResource Icon.Table}"
                                     SizeDefinition="Large, Medium, Small"
                                     ScreenTipTitle="Table"
                                     ScreenTipText="Insert a table into your document." />
                </rk:RibbonGroup>
                <rk:RibbonGroup Header="Illustrations" rk:Ribbon.CommandId="group.insert.illustrations" Icon="{StaticResource Icon.Picture}">
                    <rk:RibbonButton Header="Pictures"
                                     rk:Ribbon.CommandId="cmd.pictures"
                                     LargeIcon="{StaticResource Icon.Picture}"
                                     Icon="{StaticResource Icon.Picture}"
                                     SizeDefinition="Large, Medium, Small"
                                     ScreenTipTitle="Pictures"
                                     ScreenTipText="Insert pictures from your computer or the web." />
                    <!-- Simulates selecting a picture: shows the contextual tab -->
                    <rk:RibbonToggleButton Header="Select Picture"
                                           LargeIcon="{StaticResource Icon.Select}"
                                           Icon="{StaticResource Icon.Select}"
                                           SizeDefinition="Large, Medium, Small"
                                           Checked="OnPictureSelected"
                                           Unchecked="OnPictureDeselected"
                                           ScreenTipTitle="Select Picture"
                                           ScreenTipText="Toggle to show or hide the Picture Format contextual tab." />
                </rk:RibbonGroup>
                <rk:RibbonGroup Header="Links" rk:Ribbon.CommandId="group.insert.links" Icon="{StaticResource Icon.Link}">
                    <rk:RibbonButton Header="Link"
                                     rk:Ribbon.CommandId="cmd.link"
                                     LargeIcon="{StaticResource Icon.Link}"
                                     Icon="{StaticResource Icon.Link}"
                                     SizeDefinition="Large, Medium, Small"
                                     ScreenTipTitle="Link (Ctrl+K)"
                                     ScreenTipText="Create a link to a webpage or another place in your document." />
                </rk:RibbonGroup>
            </rk:RibbonTab>

            <rk:RibbonTab x:Name="PictureFormatTab"
                          Header="Picture Format"
                          IsContextual="True"
                          ContextualColor="#C43E96"
                          Visibility="Collapsed">
                <rk:RibbonGroup Header="Adjust" Icon="{StaticResource Icon.Sliders}">
                    <rk:RibbonButton Header="Corrections"
                                     LargeIcon="{StaticResource Icon.Sliders}"
                                     Icon="{StaticResource Icon.Sliders}"
                                     SizeDefinition="Large, Medium, Small"
                                     ScreenTipTitle="Corrections"
                                     ScreenTipText="Improve brightness, contrast, or sharpness." />
                    <rk:RibbonButton Header="Color"
                                     LargeIcon="{StaticResource Icon.ColorDrop}"
                                     Icon="{StaticResource Icon.ColorDrop}"
                                     SizeDefinition="Large, Medium, Small"
                                     ScreenTipTitle="Color"
                                     ScreenTipText="Change the color of your picture." />
                </rk:RibbonGroup>
                <rk:RibbonGroup Header="Size" Icon="{StaticResource Icon.Crop}">
                    <rk:RibbonButton Header="Crop"
                                     LargeIcon="{StaticResource Icon.Crop}"
                                     Icon="{StaticResource Icon.Crop}"
                                     SizeDefinition="Large, Medium, Small"
                                     ScreenTipTitle="Crop"
                                     ScreenTipText="Crop the picture to remove unwanted areas." />
                </rk:RibbonGroup>
            </rk:RibbonTab>

            <rk:RibbonTab Header="View" rk:Ribbon.CommandId="tab.view">
                <rk:RibbonGroup Header="Zoom" rk:Ribbon.CommandId="group.view.zoom" Icon="{StaticResource Icon.Zoom}">
                    <rk:RibbonButton Header="Zoom"
                                     rk:Ribbon.CommandId="cmd.zoom"
                                     LargeIcon="{StaticResource Icon.Zoom}"
                                     Icon="{StaticResource Icon.Zoom}"
                                     SizeDefinition="Large, Medium, Small"
                                     ScreenTipTitle="Zoom"
                                     ScreenTipText="Zoom the document to a specific level." />
                </rk:RibbonGroup>
                <!-- Runtime theme switch — same templates, different token dictionary -->
                <rk:RibbonGroup Header="Theme" rk:Ribbon.CommandId="group.view.theme" Icon="{StaticResource Icon.Palette}">
                    <rk:RibbonButton Header="Office 2024"
                                     LargeIcon="{StaticResource Icon.Palette}"
                                     Icon="{StaticResource Icon.Palette}"
                                     SizeDefinition="Large, Medium, Small"
                                     Click="OnApplyOffice2024"
                                     ScreenTipTitle="Office 2024 theme"
                                     ScreenTipText="Apply the modern light theme." />
                    <rk:RibbonButton Header="Office 2019"
                                     LargeIcon="{StaticResource Icon.Palette}"
                                     Icon="{StaticResource Icon.Palette}"
                                     SizeDefinition="Large, Medium, Small"
                                     Click="OnApplyOffice2019"
                                     ScreenTipTitle="Office 2019 theme"
                                     ScreenTipText="Apply the Office 2019 colorful theme (blue tab strip, flat)." />
                    <rk:RibbonButton Header="Office 2013"
                                     LargeIcon="{StaticResource Icon.Palette}"
                                     Icon="{StaticResource Icon.Palette}"
                                     SizeDefinition="Large, Medium, Small"
                                     Click="OnApplyOffice2013"
                                     ScreenTipTitle="Office 2013 theme"
                                     ScreenTipText="Apply the Office 2013 White theme (flat, white strip, solid File button)." />
                    <rk:RibbonButton Header="Office 2010"
                                     LargeIcon="{StaticResource Icon.Palette}"
                                     Icon="{StaticResource Icon.Palette}"
                                     SizeDefinition="Large, Medium, Small"
                                     Click="OnApplyOffice2010"
                                     ScreenTipTitle="Office 2010 theme"
                                     ScreenTipText="Apply the Office 2010 Blue theme (gradient silver-blue chrome, amber button highlights, solid blue File button)." />
                </rk:RibbonGroup>
                <!-- Accent customization: title-bar accent toggle + swappable accent color -->
                <rk:RibbonGroup Header="Accent" rk:Ribbon.CommandId="group.view.accent" Icon="{StaticResource Icon.ColorDrop}">
                    <rk:RibbonToggleButton Header="Colored Title Bar"
                                           Size="Large"
                                           LargeIcon="{StaticResource Icon.ColorDrop}"
                                           Icon="{StaticResource Icon.ColorDrop}"
                                           Checked="OnToggleAccentTitleBar"
                                           Unchecked="OnToggleAccentTitleBar"
                                           ScreenTipTitle="Colored title bar"
                                           ScreenTipText="Color the title bar with the accent color (best in the Office 2024 theme)." />
                    <!-- Accent swatches as a gallery: pick a color to recolor the theme -->
                    <rk:InRibbonGallery x:Name="AccentGallery"
                                        Width="150"
                                        VerticalAlignment="Center"
                                        SelectionChanged="OnAccentGalleryChanged">
                        <rk:RibbonGalleryItem Tag="reset" ToolTip="Theme default accent">
                            <Border Width="40" Height="22" CornerRadius="3"
                                    BorderThickness="1" BorderBrush="#B0B0B0" Background="Transparent">
                                <TextBlock Text="Auto" FontSize="9" Foreground="#616161"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </rk:RibbonGalleryItem>
                        <rk:RibbonGalleryItem Tag="#0F6CBD" ToolTip="Blue">
                            <Border Width="40" Height="22" CornerRadius="3" Background="#0F6CBD" />
                        </rk:RibbonGalleryItem>
                        <rk:RibbonGalleryItem Tag="#107C41" ToolTip="Green">
                            <Border Width="40" Height="22" CornerRadius="3" Background="#107C41" />
                        </rk:RibbonGalleryItem>
                        <rk:RibbonGalleryItem Tag="#038387" ToolTip="Teal">
                            <Border Width="40" Height="22" CornerRadius="3" Background="#038387" />
                        </rk:RibbonGalleryItem>
                        <rk:RibbonGalleryItem Tag="#8764B8" ToolTip="Purple">
                            <Border Width="40" Height="22" CornerRadius="3" Background="#8764B8" />
                        </rk:RibbonGalleryItem>
                        <rk:RibbonGalleryItem Tag="#C43E96" ToolTip="Magenta">
                            <Border Width="40" Height="22" CornerRadius="3" Background="#C43E96" />
                        </rk:RibbonGalleryItem>
                        <rk:RibbonGalleryItem Tag="#CA5010" ToolTip="Orange">
                            <Border Width="40" Height="22" CornerRadius="3" Background="#CA5010" />
                        </rk:RibbonGalleryItem>
                        <rk:RibbonGalleryItem Tag="#D13438" ToolTip="Red">
                            <Border Width="40" Height="22" CornerRadius="3" Background="#D13438" />
                        </rk:RibbonGalleryItem>
                    </rk:InRibbonGallery>
                </rk:RibbonGroup>
                <!-- Global animation level (per-action overrides available in the API) -->
                <rk:RibbonGroup Header="Motion" rk:Ribbon.CommandId="group.view.motion" Icon="{StaticResource Icon.Motion}">
                    <rk:RibbonButton Header="No Motion"
                                     LargeIcon="{StaticResource Icon.MotionOff}"
                                     Icon="{StaticResource Icon.MotionOff}"
                                     SizeDefinition="Large, Medium, Small"
                                     Click="OnAnimationOff"
                                     ScreenTipTitle="No motion"
                                     ScreenTipText="Turn every ribbon transition off — actions snap instantly." />
                    <rk:RibbonButton Header="Subtle"
                                     LargeIcon="{StaticResource Icon.MotionLow}"
                                     Icon="{StaticResource Icon.MotionLow}"
                                     SizeDefinition="Large, Medium, Small"
                                     Click="OnAnimationSubtle"
                                     ScreenTipTitle="Subtle motion (default)"
                                     ScreenTipText="Short, understated fades and small slides." />
                    <rk:RibbonButton Header="Expressive"
                                     LargeIcon="{StaticResource Icon.MotionHigh}"
                                     Icon="{StaticResource Icon.MotionHigh}"
                                     SizeDefinition="Large, Medium, Small"
                                     Click="OnAnimationExpressive"
                                     ScreenTipTitle="Expressive motion"
                                     ScreenTipText="Longer, more pronounced motion with springier easing." />
                    <rk:RibbonToggleButton Header="Respect System"
                                           Size="Large"
                                           IsChecked="True"
                                           LargeIcon="{StaticResource Icon.Gear}"
                                           Icon="{StaticResource Icon.Gear}"
                                           Checked="OnToggleRespectSystemMotion"
                                           Unchecked="OnToggleRespectSystemMotion"
                                           ScreenTipTitle="Respect system reduced motion"
                                           ScreenTipText="When on, a system-wide reduced-motion setting forces motion off." />
                </rk:RibbonGroup>
                <!-- Backstage design: modern (2024) light rail vs classic (2013) accent column -->
                <rk:RibbonGroup Header="Backstage" rk:Ribbon.CommandId="group.view.backstage" Icon="{StaticResource Icon.Backstage}">
                    <rk:RibbonToggleButton Header="Modern Backstage"
                                           Size="Large"
                                           IsChecked="True"
                                           LargeIcon="{StaticResource Icon.Backstage}"
                                           Icon="{StaticResource Icon.Backstage}"
                                           Checked="OnToggleBackstageDesign"
                                           Unchecked="OnToggleBackstageDesign"
                                           ScreenTipTitle="Modern backstage (Office 2024)"
                                           ScreenTipText="Toggle between the modern 2024 light rail and the classic 2013 accent column. Open the File menu to see it." />
                    <rk:RibbonToggleButton Header="Mica"
                                           Size="Large"
                                           LargeIcon="{StaticResource Icon.Mica}"
                                           Icon="{StaticResource Icon.Mica}"
                                           Checked="OnToggleMica"
                                           Unchecked="OnToggleMica"
                                           ScreenTipTitle="Mica backdrop (Windows 11)"
                                           ScreenTipText="Apply the Windows 11 Mica material behind the window and the backstage. Requires Windows 11 22H2+." />
                </rk:RibbonGroup>
                <rk:RibbonGroup Header="Application" rk:Ribbon.CommandId="group.view.application" Icon="{StaticResource Icon.Gear}">
                    <rk:RibbonButton Header="Options"
                                     rk:Ribbon.CommandId="cmd.options"
                                     Size="Large"
                                     LargeIcon="{StaticResource Icon.Gear}"
                                     Icon="{StaticResource Icon.Gear}"
                                     Click="OnOpenOptions"
                                     ScreenTipTitle="Options"
                                     ScreenTipText="Open the merged options dialog: the app's own pages plus the Quick Access Toolbar customization page. Also reachable by right-clicking any ribbon button." />
                </rk:RibbonGroup>
            </rk:RibbonTab>

        </rk:Ribbon>

        <Grid x:Name="MainContentArea" Background="White">
            <DockPanel>
                <!-- Word-like status bar, docked at the very bottom. A DockPanel items panel
                     lets the left cluster and the right (zoom) cluster split to the edges. -->
                <StatusBar DockPanel.Dock="Bottom"
                           Background="#F3F3F3"
                           BorderBrush="#E0E0E0"
                           BorderThickness="0,1,0,0"
                           Foreground="#444444"
                           FontSize="12">
                    <StatusBar.ItemsPanel>
                        <ItemsPanelTemplate>
                            <DockPanel LastChildFill="False" />
                        </ItemsPanelTemplate>
                    </StatusBar.ItemsPanel>
                    <StatusBarItem DockPanel.Dock="Left" Content="Page 1 of 1" Margin="8,0,0,0" />
                    <Separator DockPanel.Dock="Left" />
                    <StatusBarItem DockPanel.Dock="Left" Content="Words: 111" />
                    <Separator DockPanel.Dock="Left" />
                    <StatusBarItem DockPanel.Dock="Left" Content="English (United States)" />
                    <StatusBarItem DockPanel.Dock="Right" Content="100%" Margin="0,0,10,0" />
                    <Separator DockPanel.Dock="Right" />
                    <StatusBarItem x:Name="StatusReady" DockPanel.Dock="Right" Content="Ready" />
                </StatusBar>

                <!-- Document panel: a card with rounded TOP corners whose square bottom meets
                     the status bar. Hosts an editable RichTextBox; the panel supplies the
                     background + rounded corners, so the RichTextBox itself is borderless and
                     transparent. Keeps an opaque white fill so the Mica backdrop shows only in
                     the surrounding margin, not through the document. -->
                <!-- Margin 8 (user-tuned): aligns the panel's edges with the ribbon card's
                     inner edge (7px card margin + 1px border). -->
                <Border Margin="8,8,8,0"
                        Background="White"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        CornerRadius="8,8,0,0">
                    <RichTextBox x:Name="DocumentEditor"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="28,22"
                                 FontFamily="Segoe UI"
                                 FontSize="13"
                                 VerticalScrollBarVisibility="Auto">
                        <FlowDocument PagePadding="0" TextAlignment="Left">
                            <Paragraph FontSize="18" Foreground="#6B6B6B" Margin="0,0,0,12">RibbonKit — Phase 1: core ribbon skeleton</Paragraph>
                            <Paragraph FontSize="13" Foreground="#9A9A9A" Margin="0,0,0,6">Make the window narrower: groups collapse to flyout buttons by priority — Styles (10) → Editing (5) → Clipboard (default, resizes first) — Font never reduces (CanResize=False).</Paragraph>
                            <Paragraph FontSize="13" Foreground="#9A9A9A" Margin="0,0,0,6">Click a collapsed group button to open its flyout with the full group content.</Paragraph>
                            <Paragraph FontSize="13" Foreground="#9A9A9A" Margin="0,0,0,6">New: click the File button for the backstage view (Esc or the back arrow returns). Paste is a split button, Select is a dropdown, B/I/U are toggles, Font has combos and a ↘ launcher.</Paragraph>
                            <Paragraph FontSize="13" Foreground="#9A9A9A" Margin="0,0,0,18">Hover any button for its ScreenTip. Hover the Styles gallery for LIVE PREVIEW of the sentence below — click to commit, move away to revert.</Paragraph>
                            <Paragraph><Run x:Name="StylePreviewText" FontSize="14" Text="The quick brown fox jumps over the lazy dog." /></Paragraph>
                        </FlowDocument>
                    </RichTextBox>
                </Border>
            </DockPanel>
        </Grid>
    </DockPanel>
</rk:RibbonWindow>
